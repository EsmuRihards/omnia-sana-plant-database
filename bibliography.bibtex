  number   = {2},
  pages    = {231-239},
  doi      = {10.17344/acsi.2023.8046},
  note     = {REF-1056},
  study_type = {preclinical},
  abstract = {Comparative assessment of hydroalcoholic extracts of Stachys officinalis, S. palustris and S. sylvatica from Romania characterised their phenolic composition and antioxidant capacity, supporting the use of wood betony as an antioxidant herbal remedy.}
}

@article{hajdari2011stachys,
  author   = {Hajdari, A., Mustafa, B., Franz, C. and Novak, J.},
  title    = {Variability of essential oils of Betonica officinalis (Lamiaceae) from different wild populations in Kosovo},
