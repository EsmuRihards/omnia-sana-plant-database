  note     = {REF-1058},
  study_type = {preclinical},
  abstract = {The secretory structures and volatile fraction of Stachys officinalis subsp. officinalis from Italy were studied, relating the glandular trichomes to the essential-oil composition of wood betony.}
}

@article{benedec2023stachys,
  author   = {Benedec, D., Oniga, I., Hanganu, D., Tiperciuc, B. and others},
  title    = {Stachys Species: Comparative Evaluation of Phenolic Profile and Antimicrobial and Antioxidant Potential},
