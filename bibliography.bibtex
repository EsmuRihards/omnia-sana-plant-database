  study_type = {preclinical},
  abstract = {Berberine, the main protoberberine alkaloid of Mahonia aquifolium, showed broad antimicrobial activity against Gram-positive and Gram-negative bacteria, filamentous fungi and yeasts, characterising the antimicrobial basis of Oregon grape.}
}

@article{damjanovic2020mahonia,
  author   = {Damjanovic, A., Kolundzija, B., Matic, I.Z., Krivokuca, A. and others},
