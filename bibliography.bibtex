  note     = {REF-1065},
  study_type = {preclinical},
  abstract = {Comfrey root (Symphytum officinale), used topically in folk medicine, was studied for skin-microbiota metabolism of its natural products (phenolic acids, caffeic acid oligomers), characterising how the skin microbiome transforms comfrey constituents during external use.}
}

@article{trifan2020caffeic,
