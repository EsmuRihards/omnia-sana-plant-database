  note     = {REF-1171},
  study_type = {preclinical},
  abstract = {Selenium-enriched polysaccharides from shiitake (Lentinula edodes) showed selective immunosuppressive activity on human T lymphocytes and protected cells from oxidative stress, indicating immunomodulatory and cytoprotective bioactivity enhanced by selenium.}
}

@article{money2016mushrooms,
  author   = {Money, N.P.},
  title    = {Are mushrooms medicinal?},
  journal  = {Fungal Biology},
  year     = {2016},
  volume   = {120},
  number   = {4},
  pages    = {449-453},
  doi      = {10.1016/j.funbio.2016.01.006},
  note     = {REF-1172},
  study_type = {systematic-review},
  abstract = {This critical review evaluates the evidence for the medicinal use of mushrooms including shiitake (Lentinula edodes) and lentinan, cautioning that rigorous controlled trials are needed while acknowledging the pharmacological potential of fungal secondary metabolites.}
}

@article{gulliver2005mahonia,
  author   = {Gulliver, W.P. and Donsky, H.J.},
  title    = {A report on three recent clinical trials using Mahonia aquifolium 10% topical cream and a review of the worldwide clinical experience with Mahonia aquifolium for the treatment of plaque psoriasis},
