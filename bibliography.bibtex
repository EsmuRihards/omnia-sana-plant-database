  volume   = {8},
  number   = {2},
  pages    = {32},
  doi      = {10.3390/plants8020032},
  note     = {REF-1063},
  study_type = {systematic-review},
  abstract = {This review summarises the taxonomy and phytochemistry (essential oils, flavonoids, iridoids, fatty acids, amino acids) of ten Stachys taxa of the Balkan flora, including Stachys officinalis (L.) Trevis., to support intrageneric differentiation and use.}
}

@article{syarifah2023comfrey,
