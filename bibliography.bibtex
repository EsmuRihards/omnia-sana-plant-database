@article{saparkhanovich2026elymus,
  author   = {Zhakipbekov, K.S., Serikbayeva, E.A., Tleubayeva, M.I. et al.},
  title    = {Elymus repens (L.) Gould: Phytochemistry, Pharmacological Activities and Therapeutic Potential with Future Perspectives},
  journal  = {International Journal of Molecular Sciences},
  year     = {2026},
  volume   = {27},
  number   = {11},
  pages    = {4928},
  doi      = {10.3390/ijms27114928},
  note     = {REF-0710},
  study_type = {traditional},
  abstract = {Elymus repens (L.) Gould, commonly known as couch grass, is mainly distributed as a medicinal herb of great ethnopharmacological importance. This review presents the significance of nomenclature clarity, current insights on distribution, traditional use, phytochemistry and their biological activities. The bioactive compound composition displayed a variety of compounds including carbohydrates, phenolic acids, flavonoids, benzoxazinoids and volatile compounds, all of which contribute to its medicinal properties. The biological potential of this plant underlines diuretic, antiurolithiatic, anti-inflammatory, antioxidant and antidiabetic qualities. The reported data notably confirmed its potential in lowering renal calculi and alleviating associated symptoms.}
}

@article{bortolami2022elymus,
  author   = {Bortolami, M., Di Matteo, P., Rocco, D., Feroci, M. and Petrucci, R.},
  title    = {Metabolic Profile of Elymus repens (L.) P. Beauv. Rhizome Herbal Tea by HPLC-PDA-ESI-MS/MS Analysis},
  journal  = {Molecules},
  year     = {2022},
  volume   = {27},
  number   = {15},
  pages    = {4962},
  doi      = {10.3390/molecules27154962},
  note     = {REF-0711},
  study_type = {preclinical},
  abstract = {Elymus repens (couch grass) is a worldwide infesting rhizomatous plant with pharmacological applications. The aqueous extracts have been sparingly investigated, although the herbal tea is by far the most used formulation. The metabolic profile of the rhizome herbal tea was investigated by ESI-MS/MS and the phenolic profile by HPLC-PDA-ESI-MS/MS. The analysis evidenced at least 20 characteristic phenolic compounds, the most representative being caffeoyl and feruloyl quinic esters, followed by coumaric, caffeic and ferulic acids, and hesperidin among flavonoids.}
}

@article{kasote2017herbal,
  author   = {Kasote, D.M., Jagtap, S.D., Thapa, D., Khyade, M.S. and Russell, W.R.},
  title    = {Herbal remedies for urinary stones used in India and China: A review},
  journal  = {Journal of Ethnopharmacology},
  year     = {2017},
  volume   = {203},
  pages    = {55-68},
  doi      = {10.1016/j.jep.2017.03.038},
  note     = {REF-0712},
  study_type = {traditional},
  abstract = {Urolithiasis is a longstanding health problem. A comprehensive review of the scientific literature about antiurolithiatic plants was undertaken. Plants such as Phyllanthus niruri L. and Elymus repens (L.) Gould, as well as herbal products, have proved their utility as promising antiurolithiatic medicines in different phases of clinical trials. The majority of antiurolithiatic plants were found to either dissolve the stones or inhibit the process of urinary stone formation.}
}

@article{ziaulhaq2014rubus,
  author   = {Zia-Ul-Haq, M., Riaz, M., De Feo, V., Jaafar, H.Z.E. and Moga, M.},
  title    = {Rubus fruticosus L.: constituents, biological activities and health related uses},
  journal  = {Molecules},
  year     = {2014},
  volume   = {19},
  number   = {8},
  pages    = {10998-11029},
  doi      = {10.3390/molecules190810998},
  note     = {REF-0713},
  study_type = {traditional},
  abstract = {Rubus fruticosus L. is a shrub famous for its fruit, the blackberry. R. fruticosus contains vitamins, steroids and lipids in seed oil, and minerals, flavonoids, glycosides, terpenes, acids and tannins in aerial parts that possess diverse pharmacological activities such as antioxidant, anti-carcinogenic, anti-inflammatory, antimicrobial, anti-diabetic, anti-diarrheal, and antiviral. This review focuses on the nutrients and chemical constituents as well as the medicinal properties of different parts of R. fruticosus.}
}

@article{monforte2018rubus,
  author   = {Monforte, M.T., Smeriglio, A., Germanò, M.P., Pergolizzi, S., Circosta, C. and Galati, E.M.},
  title    = {Evaluation of antioxidant, antiinflammatory, and gastroprotective properties of Rubus fruticosus L. fruit juice},
  journal  = {Phytotherapy Research},
  year     = {2018},
  volume   = {32},
  number   = {7},
  pages    = {1404-1414},
  doi      = {10.1002/ptr.6078},
  note     = {REF-0714},
  study_type = {preclinical},
  abstract = {The juice of R. fruticosus (RFJ) fruits, containing mainly anthocyanins such as cyanidin derivatives, phenolic acids and flavonoids, showed significant antioxidant activity in DPPH, TEAC, FRAP, ORAC and beta-carotene bleaching assays. In vivo studies showed that RFJ significantly inhibits carrageenan-induced paw oedema (63-71%) in rats and possesses anti-inflammatory effects, and RFJ pretreatment was able to prevent the ethanol-induced ulcerogenic (gastroprotective) effect in rats.}
}

@article{barbieri2022rubus,
  author   = {Barbieri, F., Montanari, C., Šimat, V., Skroza, D., Čagalj, M. et al.},
  title    = {Effects of Rubus fruticosus and Juniperus oxycedrus derivatives on culturability and viability of Listeria monocytogenes},
  journal  = {Scientific Reports},
  year     = {2022},
  volume   = {12},
  number   = {1},
  pages    = {13158},
  doi      = {10.1038/s41598-022-17408-4},
  note     = {REF-0715},
  study_type = {preclinical},
  abstract = {Phenolic extracts and essential oils obtained from Mediterranean Rubus fruticosus leaves and Juniperus oxycedrus needles were evaluated for antimicrobial effects against Listeria monocytogenes. These plant derivatives affected the growth of L. monocytogenes, increasing the lag phase and decreasing the final cell load; R. fruticosus essential oil was the most effective, determining an initial decrease of cell counts of about 6 log cycles. The work highlights blackberry leaves as underused raw materials for food and other industries.}
}

@article{sharma2014acorus,
  author   = {Sharma, V., Singh, I. and Chaudhary, P.},
  title    = {Acorus calamus (The Healing Plant): a review on its medicinal potential, micropropagation and conservation},
  journal  = {Natural Product Research},
  year     = {2014},
  volume   = {28},
  number   = {18},
  pages    = {1454-1466},
  doi      = {10.1080/14786419.2014.915827},
  note     = {REF-0716},
  study_type = {traditional},
  abstract = {Acorus calamus L. is a well-known plant in Indian traditional medicine, highly valued as a rejuvenator for the brain and nervous system and a main medhya (memory-improving) drug. Rhizomes are widely used in the treatment of epilepsy, mental ailments, chronic diarrhoea, dysentery, fever, kidney and liver troubles, and rheumatism. A. calamus leaves, rhizomes and essential oil possess antispasmodic and carminative activities. The review describes chemical constituents, toxicology, ethnobotany and pharmacological properties.}
}

@article{khwairakpam2018acorus,
  author   = {Khwairakpam, A.D., Damayenti, Y.D., Deka, A., Monisha, J., Roy, N.K. et al.},
  title    = {Acorus calamus: a bio-reserve of medicinal values},
  journal  = {Journal of Basic and Clinical Physiology and Pharmacology},
  year     = {2018},
  volume   = {29},
  number   = {2},
  pages    = {107-122},
  doi      = {10.1515/jbcpp-2016-0132},
  note     = {REF-0717},
  study_type = {traditional},
  abstract = {Acorus calamus, commonly known as sweet flag, is a rhizomatous plant whose leaves and rhizomes are used traditionally for arthritis, neuralgia, diarrhoea, dyspepsia, kidney and liver troubles, eczema, sinusitis, asthma, fevers and bronchitis. Biochemical analysis has revealed a large number of secondary metabolites responsible for its medicinal properties. The review summarises the ethno-medicinal uses, botanical description, phytochemical constituents, biological activity and molecular targets of the plant.}
}

@article{ukkirapandian2022acorus,
  author   = {Ukkirapandian, K., Kayalvizhi, E., Udaykumar, K.P., Kandhi, S. and Muthulakshmi, R.},
  title    = {The Neuroprotective Role of Acorus calamus in Developmental and Histopathological Changes in Autism-Induced Wistar Rats},
  journal  = {Cureus},
  year     = {2022},
  volume   = {14},
  number   = {9},
  pages    = {e29717},
  doi      = {10.7759/cureus.29717},
  note     = {REF-0718},
  study_type = {preclinical},
  abstract = {A rat model of autism was created by administering sodium valproate in pregnancy. Autism-induced pups treated with an ethanolic extract of Acorus calamus (200 mg/kg) were compared with untreated controls. Neurodegenerative changes were well appreciated in the untreated autism group, with significant reduction in frontal-cortex neurons and cerebellar Purkinje cells, whereas the A. calamus-treated group did not show significant alteration, suggesting A. calamus in the early postnatal period protects brain morphology against autism pathology.}
}

@article{debia2025goutweed,
  author   = {Dębia, K., Dzięcioł, M., Wróblewska, A. and Janda-Milczarek, K.},
  title    = {Goutweed (Aegopodium podagraria L.): An Edible Weed with Health-Promoting Properties},
  journal  = {Molecules},
  year     = {2025},
  volume   = {30},
  number   = {7},
  pages    = {1603},
  doi      = {10.3390/molecules30071603},
  note     = {REF-0719},
  study_type = {traditional},
  abstract = {Goutweed (Aegopodium podagraria L.) is a medicinal perennial in the celery family (Apiaceae), also an edible plant of high nutritional value. In traditional folk medicine it was known as a remedy for gout (arthritis) and used to relieve rheumatism or sciatica. Specific metabolites include organic acids, flavonoids, coumarins, polyacetylenes and terpene components of essential oil. Its valuable medicinal properties include anti-inflammatory, antirheumatic, antioxidant, antibacterial, antifungal, diuretic, sedative and protective effects on the kidneys and liver.}
}

@article{engelhardt2022aegopodium,
  author   = {Engelhardt, L., Pöhnl, T. and Neugart, S.},
  title    = {Edible Wild Vegetables Urtica dioica L. and Aegopodium podagraria L.: Antioxidants Affected by Processing},
  journal  = {Plants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {20},
  pages    = {2710},
  doi      = {10.3390/plants11202710},
  note     = {REF-0720},
  study_type = {preclinical},
  abstract = {Urtica dioica L. and Aegopodium podagraria L. (stinging nettle and ground elder) are edible wild green vegetables rich in bioactive and antioxidant polyphenols, vitamins and minerals. Antioxidant activity assays (TEAC, DPPH, TPC) combined with HPLC were used to qualify and quantify their chemical compositions. Drying methods affected antioxidant activity, and cooking increased antioxidant activity due to higher concentrations of bioactive compounds released through rupture of cell structures.}
}

@article{jakubczyk2021aegopodium,
  author   = {Jakubczyk, K., Łukomska, A., Czaplicki, S., Wajs-Bonikowska, A., Gutowska, I. et al.},
  title    = {Bioactive Compounds in Aegopodium podagraria Leaf Extracts and Their Effects against Fluoride-Modulated Oxidative Stress in the THP-1 Cell Line},
  journal  = {Pharmaceuticals (Basel)},
  year     = {2021},
  volume   = {14},
  number   = {12},
  pages    = {1334},
  doi      = {10.3390/ph14121334},
  note     = {REF-0721},
  study_type = {preclinical},
  abstract = {Goutweed (Aegopodium podagraria L.) leaves contain polyacetylenes, essential oils, mono- and sesquiterpenes, vitamins, macro- and microelements and phenolic compounds. This study investigated the antioxidant properties of different goutweed leaf extracts and their effects on the THP-1 cell line. Ethanol extracts had a high content of polyphenols, polyacetylenes and essential oil and high antioxidant potential, with positive effects on antioxidant enzyme activity in cells under fluoride-induced oxidative stress.}
}

@article{gao2018arctigenin,
  author   = {Gao, Q., Yang, M. and Zuo, Z.},
  title    = {Overview of the anti-inflammatory effects, pharmacokinetic properties and clinical efficacies of arctigenin and arctiin from Arctium lappa L.},
  journal  = {Acta Pharmacologica Sinica},
  year     = {2018},
  volume   = {39},
  number   = {5},
  pages    = {787-801},
  doi      = {10.1038/aps.2018.32},
  note     = {REF-0722},
  study_type = {traditional},
  abstract = {Arctigenin and its glycoside arctiin are two major active ingredients of Arctium lappa L., a popular medicinal herb and health supplement frequently used in Asia. This article reviews their anti-inflammatory effects, pharmacokinetics and clinical efficacies. Arctigenin exhibits potent anti-inflammatory activities by inhibiting iNOS via modulation of several cytokines and may serve as a potential therapeutic compound against acute inflammation and various chronic diseases.}
}

@article{ahangarpour2017arctium,
  author   = {Ahangarpour, A., Heidari, H., Oroojan, A.A., Mirzavandi, F., Nasr Esfehani, K. and Dehghan Mohammadi, Z.},
  title    = {Antidiabetic, hypolipidemic and hepatoprotective effects of Arctium lappa root's hydro-alcoholic extract on nicotinamide-streptozotocin induced type 2 model of diabetes in male mice},
  journal  = {Avicenna Journal of Phytomedicine},
  year     = {2017},
  volume   = {7},
  number   = {2},
  pages    = {169-179},
  url      = {https://pubmed.ncbi.nlm.nih.gov/28348972/},
  note     = {REF-0723},
  study_type = {preclinical},
  abstract = {Arctium lappa (burdock) root has hypoglycemic and antioxidative effects and has been used for treatment of diabetes in traditional medicine. This study evaluated the antidiabetic and hypolipidemic properties of the root's hydro-alcoholic extract on nicotinamide-streptozotocin-induced type 2 diabetes in male mice. Administration of the extract significantly decreased triglyceride, VLDL, glucose and alkaline phosphatase, and increased insulin, HDL and leptin levels, indicating an antidiabetic effect through hypolipidemic and insulinotropic properties, and a hepatoprotective effect.}
}

@article{zeng2023arctium,
  author   = {Zeng, F., Li, Y., Zhang, X., Shen, L., Zhao, X. et al.},
  title    = {Immune regulation and inflammation inhibition of Arctium lappa L. polysaccharides by TLR4/NF-κB signaling pathway in cells},
  journal  = {International Journal of Biological Macromolecules},
  year     = {2023},
  volume   = {254},
  pages    = {127700},
  doi      = {10.1016/j.ijbiomac.2023.127700},
  note     = {REF-0724},
  study_type = {preclinical},
  abstract = {Arctium lappa L. polysaccharides (ALP) are important active ingredients of burdock roots. A crude polysaccharide was extracted and purified to 99% purity, and its immunomodulatory activity and intestinal anti-inflammatory effects were investigated in LPS-induced RAW264.7 macrophages and IL-1beta-induced Caco-2 colon cells. ALP possessed both antioxidant and anti-inflammatory effects, inhibiting pro-inflammatory cytokines (IL-8, IL-6, IL-1beta, TNF-alpha) by down-regulating the TLR4/NF-kappaB signaling pathway, indicating burdock as a source of bioactive polysaccharides for immune support.}
}

@article{toma2024arnica,
  author   = {Toma, C.C., Marrelli, M., Puticiu, M., Conforti, F. and Statti, G.},
  title    = {Effects of Arnica montana Phytotherapeutic and Homeopathic Formulations on Traumatic Injuries and Inflammatory Conditions: A Systematic Review},
  journal  = {Plants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {21},
  pages    = {3112},
  doi      = {10.3390/plants13213112},
  note     = {REF-0725},
  study_type = {systematic-review},
  abstract = {Arnica montana (Asteraceae) shows antioxidant, anti-inflammatory, antibacterial, antifungal and antitumor effects, and its formulations are mainly used for pain management. This systematic review summarizes studies on the use of Arnica products on pain and inflammatory signs due to traumatic injuries related to sport and surgical interventions as well as to arthritis and other inflammatory conditions. 42 eligible papers focusing on both Arnica alone and mixed formulations were selected, critically discussing in vitro, in vivo and clinical studies and reporting both positive and negative outcomes.}
}

@article{schmidt2023arnica,
  author   = {Schmidt, T.J.},
  title    = {Arnica montana L.: Doesn't Origin Matter?},
  journal  = {Plants (Basel)},
  year     = {2023},
  volume   = {12},
  number   = {20},
  pages    = {3532},
  doi      = {10.3390/plants12203532},
  note     = {REF-0726},
  study_type = {traditional},
  abstract = {Arnica montana L. has a long tradition in Europe as herbal medicine; Arnica flowers are monographed in the European Pharmacopoeia and a EU herbal monograph recommends topical use to treat blunt injuries and traumas, inflammations and rheumatic muscle and joint complaints. The main bioactive constituents are sesquiterpene lactones of the helenanolide type (esters of helenalin and 11alpha,13-dihydrohelenalin), which are the main active principles responsible for the drug's anti-inflammatory efficacy. The review summarizes botanical, phytochemical and pharmacological evidence, including chemotype differences by geographic origin.}
}

@article{dragos2017phytomedicine,
  author   = {Dragos, D., Gilca, M., Gaman, L., Vlad, A., Iosif, L. et al.},
  title    = {Phytomedicine in Joint Disorders},
  journal  = {Nutrients},
  year     = {2017},
  volume   = {9},
  number   = {1},
  pages    = {70},
  doi      = {10.3390/nu9010070},
  note     = {REF-0727},
  study_type = {traditional},
  abstract = {Chronic joint inflammatory disorders such as osteoarthritis and rheumatoid arthritis share an upsurge of inflammation and oxidative stress. Medicinal plants are a promising alternative to conventional medication, with a lower rate of adverse events and efficiency frequently comparable to conventional drugs. This review summarizes the available scientific information on joint-friendly medicinal plants tested in human studies, among them Arnica montana, used topically for inflammatory and rheumatic joint complaints.}
}

@article{batiha2020wormwood,
  author   = {Batiha, G.E.S., Olatunde, A., El-Mleeh, A., Hetta, H.F., Al-Rejaie, S. et al.},
  title    = {Bioactive Compounds, Pharmacological Actions, and Pharmacokinetics of Wormwood (Artemisia absinthium)},
  journal  = {Antibiotics (Basel)},
  year     = {2020},
  volume   = {9},
  number   = {6},
  pages    = {353},
  doi      = {10.3390/antibiotics9060353},
  note     = {REF-0728},
  study_type = {traditional},
  abstract = {Artemisia absinthium is a perennial shrubby plant widely used to treat several ailments. Traditionally it has been used for hepatitis, gastritis, jaundice, wound healing, dyspepsia, indigestion, flatulence, gastric pain, anemia and anorexia, and it possesses antioxidant, antifungal, antimicrobial, anthelmintic, anti-ulcer, hepatoprotective, neuroprotective, antidepressant, analgesic and immunomodulatory activity. Long-term use of the essential oil may be toxic (thujone). The review examines its phytoconstituents and biological activities.}
}

@article{wubuli2024absinthium,
  author   = {Wubuli, A., Abdulla, R., Zhao, J., Wu, T. and Aisa, H.A.},
  title    = {Exploring anti-inflammatory and antioxidant-related quality markers of Artemisia absinthium L. based on spectrum-effect relationship},
  journal  = {Phytochemical Analysis},
  year     = {2024},
  volume   = {35},
  number   = {5},
  pages    = {1152-1173},
  doi      = {10.1002/pca.3350},
  note     = {REF-0729},
  study_type = {preclinical},
  abstract = {Artemisia absinthium L. has a long history of use in treating liver inflammation and other diseases. Different batches of A. absinthium extracts possessed significant anti-inflammatory (inhibition of COX-2, 15-lipoxygenase and nitric oxide release in LPS-induced BV-2 cells) and antioxidant (DPPH, ABTS) activities. Chlorogenic acid, isochlorogenic acid A and isochlorogenic acid C were screened as the most promising active compounds and validated for their anti-inflammatory effects, providing quality markers for the herb.}
}

@article{rashidi2023absinthium,
  author   = {Rashidi, R., Akaberi, M., Gholoobi, A., Ghazavi, H. and Forouzanfar, F.},
  title    = {Artemisia absinthium Extract Attenuates the Quinolinic Acid-Induced Cell Injury in OLN-93 Cells},
  journal  = {Current Drug Discovery Technologies},
  year     = {2023},
  volume   = {20},
  number   = {4},
  pages    = {e300323215213},
  doi      = {10.2174/1570163820666230330105331},
  note     = {REF-0730},
  study_type = {preclinical},
  abstract = {Quinolinic acid (QA) accumulation is found in many neurodegenerative diseases. Artemisia absinthium has neuroprotective and antioxidant activities. In OLN-93 cells, pretreatment with A. absinthium extract prevented the loss of cell viability and reduced reactive oxygen species generation, lipid peroxidation and apoptosis in QA-injured cells, exerting a neuroprotective effect via oxidative stress and apoptosis modulation.}
}

@article{liu2022artemvulgaris,
  author   = {Liu, T., Chen, X., Hu, Y., Li, M., Wu, Y. et al.},
  title    = {Sesquiterpenoids and triterpenoids with anti-inflammatory effects from Artemisia vulgaris L.},
  journal  = {Phytochemistry},
  year     = {2022},
  volume   = {204},
  pages    = {113428},
  doi      = {10.1016/j.phytochem.2022.113428},
  note     = {REF-0731},
  study_type = {preclinical},
  abstract = {Eight undescribed sesquiterpenoids and two undescribed triterpenoids, together with thirteen known terpenoids, were isolated from the leaves of Artemisia vulgaris L. All isolates were evaluated for anti-inflammatory efficacy by detecting the inflammatory mediator NO in LPS-induced RAW264.7 cells; artemvulactone E exhibited a significant anti-inflammatory effect and dose-dependently reduced LPS-induced COX-2 protein expression.}
}

@article{trinh2024vulgaris,
  author   = {Trinh, P.T.N., Truc, N.C., Danh, T.T., Trang, N.T.T., Le Hang, D.T. et al.},
  title    = {A study on the antioxidant, anti-inflammatory, and xanthine oxidase inhibitory activity of the Artemisia vulgaris L. extract and its fractions},
  journal  = {Journal of Ethnopharmacology},
  year     = {2024},
  volume   = {334},
  pages    = {118519},
  doi      = {10.1016/j.jep.2024.118519},
  note     = {REF-0732},
  study_type = {preclinical},
  abstract = {Vietnamese people use mugwort (Artemisia vulgaris L.) to treat arthritis and gout. Ethanol extracts significantly decreased carrageenan-induced paw oedema in mice and showed significant antioxidant activity (DPPH, ABTS), and the ethyl acetate fraction displayed the most potent xanthine oxidase inhibition. Five flavonoids were isolated (luteolin, rutin, apigenin, myricetin, quercetin); the results support the use of mugwort to treat gout by suppressing xanthine oxidase and reducing uric acid production.}
}

@article{abiri2018vulgaris,
  author   = {Abiri, R., Silva, A.L.M., de Mesquita, L.S.S., de Mesquita, J.W.C., Atabaki, N. et al.},
  title    = {Towards a better understanding of Artemisia vulgaris: Botany, phytochemistry, pharmacological and biotechnological potential},
  journal  = {Food Research International},
  year     = {2018},
  volume   = {109},
  pages    = {403-415},
  doi      = {10.1016/j.foodres.2018.03.072},
  note     = {REF-0733},
  study_type = {traditional},
  abstract = {Artemisia vulgaris has a long history in the treatment of human ailments and possesses a broad spectrum of therapeutic properties including anti-malarial, anti-inflammatory, anti-hypertensive, antioxidant, anti-tumoral, immunomodulatory, hepatoprotective, anti-spasmodic and anti-septic activities. These are mainly attributed to flavonoids, sesquiterpene lactones, coumarins, acetylenes, phenolic acids and mono- and sesquiterpenes. The review highlights recent reports on the chemistry, biological activities and biotechnological production of bioactive compounds from this species.}
}

@article{warashina2017asclepias,
  author   = {Warashina, T. and Miyase, T.},
  title    = {New 8,12;8,20-diepoxy-8,14-secopregnane hexa- and hepta-glycosides from the roots of Asclepias tuberosa},
  journal  = {Journal of Natural Medicines},
  year     = {2017},
  volume   = {72},
  number   = {1},
  pages    = {347-356},
  doi      = {10.1007/s11418-017-1155-9},
  note     = {REF-0734},
  study_type = {preclinical},
  abstract = {Phytochemical investigation of the roots of Asclepias tuberosa (Asclepiadaceae) afforded eight new minor 8,12;8,20-diepoxy-8,14-secopregnane glycosides consisting of six or seven 2,6-dideoxy-hexopyranoses together with the aglycone tuberogenin. The structures were established using NMR, mass spectrometry and chemical evidence. These secopregnane-type glycosides, observed only in A. tuberosa, are considered characteristic phytochemicals of this plant (pleurisy root).}
}

@article{lockwood1848asclepias,
  author   = {Lockwood, T.L.},
  title    = {Asclepias Tuberosa, Butterfly-Weed, Milk-Weed, Pleurisy Root, White Root},
  journal  = {The Medical Examiner (Philadelphia)},
  year     = {1848},
  volume   = {4},
  number   = {42},
  pages    = {367-368},
  url      = {https://pubmed.ncbi.nlm.nih.gov/38120955/},
  note     = {REF-0735},
  study_type = {traditional},
  abstract = {A 19th-century North American materia-medica account of Asclepias tuberosa (butterfly weed, pleurisy root, white root), documenting its long-standing traditional use as a diaphoretic and expectorant remedy for pleurisy and respiratory complaints.}
}

@article{auyeung2016astragalus,
  author   = {Auyeung, K.K., Han, Q.B. and Ko, J.K.},
  title    = {Astragalus membranaceus: A Review of its Protection Against Inflammation and Gastrointestinal Cancers},
  journal  = {The American Journal of Chinese Medicine},
  year     = {2016},
  volume   = {44},
  number   = {1},
  pages    = {1-22},
  doi      = {10.1142/S0192415X16500014},
  note     = {REF-0736},
  study_type = {traditional},
  abstract = {Astragalus membranaceus is a major medicinal herb used in traditional Chinese medicine. Its major components are polysaccharides, flavonoids and saponins, and contemporary use focuses on immunomodulating, antioxidant, anti-inflammatory and anticancer effects. The review discusses how Astragalus and its saponins influence the immune system, modulate cancer signaling pathways and protect against gastrointestinal inflammation and cancers, and how it ameliorates the toxicity of concurrently administered orthodox drugs.}
}

@article{zhang2024astragaluscolitis,
  author   = {Zhang, Y., Ji, W., Qin, H., Chen, Z., Zhou, Y. et al.},
  title    = {Astragalus polysaccharides alleviate DSS-induced ulcerative colitis in mice by restoring SCFA production and regulating Th17/Treg cell homeostasis in a microbiota-dependent manner},
  journal  = {Carbohydrate Polymers},
  year     = {2024},
  volume   = {349},
  pages    = {122829},
  doi      = {10.1016/j.carbpol.2024.122829},
  note     = {REF-0737},
  study_type = {preclinical},
  abstract = {Astragalus polysaccharides (APS) ameliorated colonic injury and gut microbiota disruption and restored intestinal immune homeostasis in mice with DSS-induced colitis. APS increased SCFA-producing microbiota and SCFA production, dually inhibited NF-kappaB activation via the TLR4 and HDAC3 pathways and improved the Th17/Treg balance, indicating APS is a promising prebiotic agent that ameliorates colitis in a gut-microbiota-dependent manner.}
}

@article{abe2000asclepias,
  author   = {Abe, F. and Yamauchi, T.},
  title    = {An androstane bioside and 3'-thiazolidinone derivatives of doubly-linked cardenolide glycosides from the roots of Asclepias tuberosa},
  journal  = {Chemical & Pharmaceutical Bulletin},
  year     = {2000},
  volume   = {48},
  number   = {7},
  pages    = {991-993},
  doi      = {10.1248/cpb.48.991},
  note     = {REF-0738},
  study_type = {preclinical},
  abstract = {Steroidal compounds in the roots of Asclepias tuberosa were investigated. A new androstane glycoside termed ascandroside was isolated, along with doubly-linked cardenolide glycosides including 3'-spiro-linked thiazolidinone and S-oxythiazolidinone derivatives of delta5-calotropin, and nine glycosides of uzarigenin, coroglaucigenin and corotoxigenin. The work characterises the cardenolide (cardiac glycoside) chemistry that underlies the pharmacology and toxicity of pleurisy root.}
}

@article{xu2024astragaloside,
  author   = {Xu, B., Huang, J.P., Peng, G., Cao, W., Liu, Z. et al.},
  title    = {Total biosynthesis of the medicinal triterpenoid saponin astragalosides},
  journal  = {Nature Plants},
  year     = {2024},
  volume   = {10},
  number   = {11},
  pages    = {1826-1837},
  doi      = {10.1038/s41477-024-01827-4},
  note     = {REF-0739},
  study_type = {preclinical},
  abstract = {Astragalus membranaceus has been used in traditional Chinese medicine for over 2,000 years, and its major active triterpenoid saponins, astragalosides, have multiple health benefits. A chromosome-level genome assembly enabled discovery of a triterpenoid biosynthetic gene cluster and elucidation of the complete astragaloside biosynthetic pathway (selective hydroxylation, epoxidation and glycosylation by P450s, a dioxygenase and glycosyltransferases), and heterologous production of astragaloside IV, providing a foundation for addressing sourcing of these medicinal saponins.}
}

@article{calabrese2008bacopa,
  author   = {Calabrese, C., Gregory, W.L., Leo, M., Kraemer, D. et al.},
  title    = {Effects of a standardized Bacopa monnieri extract on cognitive performance, anxiety, and depression in the elderly: a randomized, double-blind, placebo-controlled trial},
  journal  = {Journal of Alternative and Complementary Medicine},
  year     = {2008},
  volume   = {14},
  number   = {6},
  pages    = {707-713},
  doi      = {10.1089/acm.2008.0018},
  note     = {REF-0740},
  study_type = {rct},
  abstract = {A randomized, double-blind, placebo-controlled trial evaluated a standardized Bacopa monnieri whole-plant dry extract on cognitive function, affect, safety and tolerability in healthy elderly participants. Bacopa improved measures of cognitive performance (e.g. delayed word recall and Stroop task) and reduced anxiety and depression scores relative to placebo, with good tolerability, supporting its traditional use as a memory and learning enhancer.}
}

@article{lorca2022nootropics,
  author   = {Lorca, C., Mulet, M., Arévalo-Caro, C., Sanchez, M.Á. et al.},
  title    = {Plant-derived nootropics and human cognition: A systematic review},
  journal  = {Critical Reviews in Food Science and Nutrition},
  year     = {2022},
  volume   = {63},
  number   = {22},
  pages    = {5521-5545},
  doi      = {10.1080/10408398.2021.2021137},
  note     = {REF-0741},
  study_type = {systematic-review},
  abstract = {Substances with modulatory capabilities on human cognition have been revered as nootropics, and the plant kingdom provides most of the currently available natural nootropics. This systematic review provides state-of-the-art information on plant-derived nootropics and their effects on human cognition, among them Bacopa monnieri, reviewing the clinical evidence for memory and cognitive enhancement.}
}

@article{fatima2022bacopa,
  author   = {Fatima, U., Roy, S., Ahmad, S., Ali, S. et al.},
  title    = {Pharmacological attributes of Bacopa monnieri extract: Current updates and clinical manifestation},
  journal  = {Frontiers in Nutrition},
  year     = {2022},
  volume   = {9},
  pages    = {972379},
  doi      = {10.3389/fnut.2022.972379},
  note     = {REF-0742},
  study_type = {traditional},
  abstract = {Bacopa monnieri has been used for centuries in Ayurvedic medicine as a memory and learning enhancer, sedative and anti-epileptic. This review highlights the health benefits of Bacopa monnieri extracts, focusing on anti-cancer and neurodegenerative diseases, and the molecular mechanisms underlying its cognition-enhancing, neuroprotective and therapeutic effects, as well as its toxicity, safety and synergistic potential.}
}

@article{rastogi2014betula,
  author   = {Rastogi, S., Pandey, M.M. and Kumar Singh Rawat, A.},
  title    = {Medicinal plants of the genus Betula — traditional uses and a phytochemical-pharmacological review},
  journal  = {Journal of Ethnopharmacology},
  year     = {2014},
  volume   = {159},
  pages    = {62-83},
  doi      = {10.1016/j.jep.2014.11.010},
  note     = {REF-0743},
  study_type = {traditional},
  abstract = {Trees and shrubs of the genus Betula (Betulaceae) inhabit temperate and boreal zones of the northern hemisphere. The healing properties of Betula bark, leaves and bark extracts have long been known in traditional medicine for skin diseases, rheumatism, gout and as a diuretic. This review compiles the traditional uses, phytochemistry (triterpenes such as betulin and betulinic acid, flavonoids, phenolics) and pharmacological activities of Betula species.}
}

@article{penkov2018betula,
  author   = {Penkov, D., Andonova, V., Delev, D. and Kostadinov, I.},
  title    = {Antioxidant Activity of Dry Birch (Betula pendula) Leaves Extract},
  journal  = {Folia Medica},
  year     = {2018},
  volume   = {60},
  number   = {4},
  pages    = {571-579},
  doi      = {10.2478/folmed-2018-0035},
  note     = {REF-0744},
  study_type = {preclinical},
  abstract = {Betula pendula has been used in traditional medicine since ancient times, and birch leaf extracts exhibit a number of pharmacological activities. This study evaluated the antioxidant activity of a dry birch leaf extract, which demonstrated significant free-radical-scavenging and antioxidant capacity attributable to its phenolic and flavonoid content.}
}

@article{sevastreberghian2023betula,
  author   = {Sevastre-Berghian, A.C., Ielciu, I., Bab, T., Olah, N.K. et al.},
  title    = {Betula pendula Leaf Extract Targets the Interplay between Brain Oxidative Stress, Inflammation, and NF-kB Pathways in Amyloid Abeta-Treated Rats},
  journal  = {Antioxidants (Basel)},
  year     = {2023},
  volume   = {12},
  number   = {12},
  pages    = {2110},
  doi      = {10.3390/antiox12122110},
  note     = {REF-0745},
  study_type = {preclinical},
  abstract = {Chemical analyses of a Betula pendula leaf extract revealed high amounts of polyphenol carboxylic acids and flavonoids. In amyloid-beta-treated rats, the leaf extract reduced brain oxidative stress and inflammation and modulated the NF-kB pathway, improving behavioural and biochemical markers, suggesting neuroprotective potential of the birch leaf extract.}
}

@article{pawlowska2020bistort,
  author   = {Pawłowska, K.A., Hałasa, R., Dudek, M.K., Majdan, M. et al.},
  title    = {Antibacterial and anti-inflammatory activity of bistort (Bistorta officinalis) aqueous extract and its major components: justification of the usage of the medicinal plant material as a traditional topical agent},
  journal  = {Journal of Ethnopharmacology},
  year     = {2020},
  volume   = {260},
  pages    = {113077},
  doi      = {10.1016/j.jep.2020.113077},
  note     = {REF-0746},
  study_type = {preclinical},
  abstract = {Bistort rhizome (Bistorta officinalis) is traditionally used in Europe and Asia for diarrhea and as a topical agent for skin conditions; it contains mostly condensed flavan-3-ol-derived tannins. The aqueous extract and its major components showed antibacterial and anti-inflammatory activity, justifying the traditional use of the rhizome as an astringent topical agent.}
}

@article{jovanovic2020bistort,
  author   = {Jovanović, M., Morić, I., Nikolić, B., Pavić, A. et al.},
  title    = {Anti-Virulence Potential and In Vivo Toxicity of Persicaria maculosa and Bistorta officinalis Extracts},
  journal  = {Molecules},
  year     = {2020},
  volume   = {25},
  number   = {8},
  pages    = {1811},
  doi      = {10.3390/molecules25081811},
  note     = {REF-0747},
  study_type = {preclinical},
  abstract = {The anti-virulence potential and safety of ethanol extracts of two medicinal plants, Persicaria maculosa and Bistorta officinalis, were evaluated for the first time. The extracts showed anti-virulence activity against bacterial pathogens together with a favourable in vivo toxicity (safety) profile, supporting their potential use as antimicrobial/anti-virulence agents.}
}

@article{duwiejua1994bistort,
  author   = {Duwiejua, M., Zeitlin, I.J., Waterman, P.G. and Gray, A.I.},
  title    = {Anti-inflammatory activity of Polygonum bistorta, Guaiacum officinale and Hamamelis virginiana in rats},
  journal  = {Journal of Pharmacy and Pharmacology},
  year     = {1994},
  volume   = {46},
  number   = {4},
  pages    = {286-290},
  doi      = {10.1111/j.2042-7158.1994.tb03795.x},
  note     = {REF-0748},
  study_type = {preclinical},
  abstract = {Aqueous ethanolic extract of Polygonum bistorta (Bistorta officinalis) significantly suppressed carrageenan-induced rat paw oedema in a dose-dependent manner and inhibited both the acute and chronic phases of adjuvant-induced arthritis; given after the onset of inflammation it reversed the course of the swelling. The results confirm that bistort rhizome contains anti-inflammatory substances, supporting its traditional anti-inflammatory and astringent use.}
}

@article{slama2024borago,
  author   = {Slama, M., Slougui, N., Benaissa, A., Nekkaa, A. et al.},
  title    = {Borago officinalis L.: A Review on Extraction, Phytochemical, and Pharmacological Activities},
  journal  = {Chemistry & Biodiversity},
  year     = {2024},
  volume   = {21},
  number   = {5},
  pages    = {e202301822},
  doi      = {10.1002/cbdv.202301822},
  note     = {REF-0749},
  study_type = {traditional},
  abstract = {Borago officinalis L. (Boraginaceae) is used in traditional medicine for respiratory disorders, colds, influenza, diarrhea, cramps, inflammation, palpitation, hypertension and menopausal symptoms. Its antioxidant, antimicrobial, anticancer, anti-inflammatory and anti-obesity activities relate to its rich content of phenolic acids, flavonoids, anthocyanins, alkaloids and terpenes from leaves, flowers, seeds and roots. The review summarizes extraction, phytochemistry, pharmacology and toxicity.}
}

@article{michalak2023borago,
  author   = {Michalak, M., Zagórska-Dziok, M., Klimek-Szczykutowicz, M. and Szopa, A.},
  title    = {Phenolic Profile and Comparison of the Antioxidant, Anti-Ageing, Anti-Inflammatory, and Protective Activities of Borago officinalis Extracts on Skin Cells},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {2},
  pages    = {868},
  doi      = {10.3390/molecules28020868},
  note     = {REF-0750},
  study_type = {preclinical},
  abstract = {Methanol and water-methanol extracts of borage (Borago officinalis) herb were analysed for phenolic profile and biological activity. Twelve flavonoids and phenolic acids were identified. In vitro tests on human keratinocytes and fibroblasts showed the extracts reduced intracellular reactive oxygen species, inhibited protein denaturation, lipoxygenase and proteinase (anti-inflammatory), and inhibited collagenase and elastase (anti-ageing), indicating borage extracts protect skin cells.}
}

@article{ghasemian2016borago,
  author   = {Ghasemian, M., Owlia, S. and Owlia, M.B.},
  title    = {Review of Anti-Inflammatory Herbal Medicines},
  journal  = {Advances in Pharmacological Sciences},
  year     = {2016},
  volume   = {2016},
  pages    = {9130979},
  doi      = {10.1155/2016/9130979},
  note     = {REF-0751},
  study_type = {traditional},
  abstract = {Inflammation underlies a wide range of diseases including rheumatic and immune-mediated conditions. This review introduces medicinal herbs whose anti-inflammatory effects have been evaluated in clinical and experimental studies, among them Borago officinalis (alongside Curcuma longa, Zingiber officinale, Rosmarinus officinalis, evening primrose and Devil's claw), supporting a multidimensional herbal approach to inflammation.}
}

@article{givol2019calendula,
  author   = {Givol, O., Kornhaber, R., Visentin, D., Cleary, M. et al.},
  title    = {A systematic review of Calendula officinalis extract for wound healing},
  journal  = {Wound Repair and Regeneration},
  year     = {2019},
  volume   = {27},
  number   = {5},
  pages    = {548-561},
  doi      = {10.1111/wrr.12737},
  note     = {REF-0752},
  study_type = {systematic-review},
  abstract = {This systematic review evaluated Calendula officinalis flower extract as monotherapy for wound healing in vivo, with 14 studies meeting inclusion criteria (7 animal experiments and 7 clinical trials). Acute wound healing showed faster resolution of the inflammation phase and increased granulation tissue with calendula. Clinical results for chronic wounds, burns and radiation dermatitis were mixed. The review identified evidence for beneficial effects of C. officinalis extract for wound healing, consistent with its traditional use.}
}

@article{shahane2023calendula,
  author   = {Shahane, K., Kshirsagar, M., Tambe, S., Jain, D. et al.},
  title    = {An Updated Review on the Multifaceted Therapeutic Potential of Calendula officinalis L.},
  journal  = {Pharmaceuticals (Basel)},
  year     = {2023},
  volume   = {16},
  number   = {4},
  pages    = {611},
  doi      = {10.3390/ph16040611},
  note     = {REF-0753},
  study_type = {traditional},
  abstract = {Calendula officinalis contains flavonoids, triterpenoids, glycosides, saponins, carotenoids, volatile oil and sterols, conferring anti-inflammatory, anti-cancer, antihelminthic, antidiabetic, wound-healing, hepatoprotective and antioxidant activities, and it is used in burns and gastrointestinal, gynecological, ocular and skin conditions. The review summarizes recent research on its therapeutic applications, molecular mechanisms and clinical studies.}
}

@article{saffari2016calendula,
  author   = {Saffari, E., Mohammad-Alizadeh-Charandabi, S., Adibpour, M., Mirghafourvand, M. et al.},
  title    = {Comparing the effects of Calendula officinalis and clotrimazole on vaginal Candidiasis: A randomized controlled trial},
  journal  = {Women & Health},
  year     = {2016},
  volume   = {57},
  number   = {10},
  pages    = {1145-1160},
  doi      = {10.1080/03630242.2016.1263272},
  note     = {REF-0754},
  study_type = {rct},
  abstract = {This triple-blind randomized controlled trial (n=150) compared Calendula officinalis vaginal cream with clotrimazole for vaginal Candidiasis. Calendula vaginal cream was effective in treating vaginal Candidiasis, with a delayed but greater long-term effect than clotrimazole at the second follow-up, and improved sexual function similarly in both groups, supporting the antifungal and anti-inflammatory use of calendula.}
}

@article{mancini2017greentea,
  author   = {Mancini, E., Beglinger, C., Drewe, J., Zanchi, D. et al.},
  title    = {Green tea effects on cognition, mood and human brain function: A systematic review},
  journal  = {Phytomedicine},
  year     = {2017},
  volume   = {34},
  pages    = {26-37},
  doi      = {10.1016/j.phymed.2017.07.008},
  note     = {REF-0755},
  study_type = {systematic-review},
  abstract = {A systematic review (PRISMA) of 21 studies, including 4 randomised controlled trials, on the effects of green tea (Camellia sinensis), l-theanine and epigallocatechin gallate on human neuropsychology, cognition and brain function. The reviewed studies showed green tea influences psychopathological symptoms (e.g. reduction of anxiety), cognition (benefits in memory and attention) and brain function; effects are attributed to the combined influence of caffeine and l-theanine rather than a single constituent.}
}

@article{musial2020catechins,
  author   = {Musial, C., Kuban-Jankowska, A. and Gorska-Ponikowska, M.},
  title    = {Beneficial Properties of Green Tea Catechins},
  journal  = {International Journal of Molecular Sciences},
  year     = {2020},
  volume   = {21},
  number   = {5},
  pages    = {1744},
  doi      = {10.3390/ijms21051744},
  note     = {REF-0756},
  study_type = {traditional},
  abstract = {Green tea (Camellia sinensis) is widely known for its anticancer and anti-inflammatory properties, the main antioxidant agents being catechins (epicatechin, epigallocatechin, epicatechin gallate and epigallocatechin gallate). Catechins strongly neutralise reactive oxygen and nitrogen species; epigallocatechin gallate presents the most potent anti-inflammatory and anticancer potential. The review summarises the anticancer effects and molecular signaling pathways of major green tea catechins.}
}

@article{ohishi2016greentea,
  author   = {Ohishi, T., Goto, S., Monira, P., Isemura, M. and Nakamura, Y.},
  title    = {Anti-inflammatory Action of Green Tea},
  journal  = {Anti-inflammatory & Anti-allergy Agents in Medicinal Chemistry},
  year     = {2016},
  volume   = {15},
  number   = {2},
  pages    = {74-90},
  doi      = {10.2174/1871523015666160915154443},
  note     = {REF-0757},
  study_type = {traditional},
  abstract = {Green tea and its major component epigallocatechin-3-gallate (EGCG) have anti-inflammatory effects, suppressing the expression of inflammatory cytokines and inflammation-related enzymes. Human, cellular and animal studies indicate beneficial effects against inflammatory diseases, largely explained by EGCG acting as an antioxidant scavenging reactive oxygen species and attenuating NF-kB activity. Care should be taken to avoid overdosage, which may cause hepatic injury.}
}

@article{rock2021cannabis,
  author   = {Rock, E.M. and Parker, L.A.},
  title    = {Constituents of Cannabis sativa},
  journal  = {Advances in Experimental Medicine and Biology},
  year     = {2021},
  volume   = {1264},
  pages    = {1-13},
  doi      = {10.1007/978-3-030-57369-0_1},
  note     = {REF-0758},
  study_type = {traditional},
  abstract = {The Cannabis sativa plant has been used medicinally and recreationally for thousands of years. There are more than 550 chemical compounds, with over 100 phytocannabinoids identified, including delta-9-tetrahydrocannabinol (THC) and cannabidiol (CBD), which act on cannabinoid and other receptors, plus more than 100 aromatic terpenes. Cannabis and its constituents have been indicated as therapeutic compounds in pain, anxiety, epilepsy, nausea and vomiting, and post-traumatic stress disorder.}
}

@article{castilloarellano2023cbd,
  author   = {Castillo-Arellano, J., Canseco-Alba, A., Cutler, S.J. and León, F.},
  title    = {The Polypharmacological Effects of Cannabidiol},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {7},
  pages    = {3271},
  doi      = {10.3390/molecules28073271},
  note     = {REF-0759},
  study_type = {traditional},
  abstract = {Cannabidiol (CBD) is a major phytocannabinoid of Cannabis sativa that does not induce intoxication. This review integrates the mechanisms of action of CBD on around 56 molecular targets (enzymes, ion channels and metabotropic receptors) and pharmacological implications in animal models and human diseases such as epilepsy, pain, neuropsychiatric disorders, Alzheimer's disease and inflammatory diseases, illustrating the polypharmacological nature of this natural product.}
}

@article{pagano2022cannabinoids,
  author   = {Pagano, C., Navarra, G., Coppola, L., Avilia, G. et al.},
  title    = {Cannabinoids: Therapeutic Use in Clinical Practice},
  journal  = {International Journal of Molecular Sciences},
  year     = {2022},
  volume   = {23},
  number   = {6},
  pages    = {3344},
  doi      = {10.3390/ijms23063344},
  note     = {REF-0760},
  study_type = {traditional},
  abstract = {Cannabinoids extracted from Cannabis sativa have therapeutic effects. FDA-approved drugs such as nabiximols (a THC/CBD mixture) are used for pain and spasticity in multiple sclerosis; dronabinol and nabilone for chemotherapy-induced nausea and vomiting; and dronabinol for anorexia in AIDS patients. The review highlights the therapeutic efficacy of natural and synthetic cannabinoids and their clinical relevance in cancer, neurodegenerative and dermatological diseases and viral infections.}
}

@article{wei2022capsella,
  author   = {Wei, Z.Z., Zhou, T.Q., Xia, Z.M., Liu, S.F. et al.},
  title    = {Four organosulfur compounds from the seeds of Capsella bursa-pastoris and their anti-inflammatory activities},
  journal  = {Natural Product Research},
  year     = {2022},
  volume   = {37},
  number   = {16},
  pages    = {2688-2696},
  doi      = {10.1080/14786419.2022.2130307},
  note     = {REF-0761},
  study_type = {preclinical},
  abstract = {Phytochemical investigation of the seeds of Capsella bursa-pastoris led to the isolation of four organosulfur compounds, including two new methylsulfinyl amides. Evaluated in LPS-induced RAW 264.7 cells, the compounds exhibited anti-inflammatory activity, decreasing nitric oxide release and the mRNA expression of inducible NO synthase (iNOS), COX-2 and IL-6.}
}

@article{jeong2023capsella,
  author   = {Jeong, Y., Lee, S.H., Lee, J., Kim, M.S. et al.},
  title    = {Water Extract of Capsella bursa-pastoris Mitigates Doxorubicin-Induced Cardiotoxicity by Upregulating Antioxidant Enzymes},
  journal  = {International Journal of Molecular Sciences},
  year     = {2023},
  volume   = {24},
  number   = {21},
  pages    = {15912},
  doi      = {10.3390/ijms242115912},
  note     = {REF-0762},
  study_type = {preclinical},
  abstract = {A hot-water extract of Capsella bursa-pastoris (CBW), containing flavonoids such as luteolin-7-O-glucoside and isoorientin, protected H9c2 cardiomyocytes and mouse hearts from doxorubicin-induced cardiotoxicity by increasing superoxide dismutase, reducing reactive oxygen species and recovering cardiac electrophysiology, without protecting breast cancer cells, suggesting potential as an adjunct that mitigates chemotherapy cardiotoxicity.}
}

@article{zhou2023capsella,
  author   = {Zhou, T.Q., Wei, Z.Z., Zhang, J.R., Dong, J.H. et al.},
  title    = {Phytochemical Constituents from the Seeds of Capsella bursa-pastoris and Their Antioxidant Activities},
  journal  = {Plant Foods for Human Nutrition},
  year     = {2023},
  volume   = {78},
  number   = {4},
  pages    = {776-782},
  doi      = {10.1007/s11130-023-01097-z},
  note     = {REF-0763},
  study_type = {preclinical},
  abstract = {Investigation of the seeds of Capsella bursa-pastoris yielded a new cyclobutane organic acid and fourteen known compounds (organosulfur compounds, quinonoids, flavonoids, sterols). Several compounds showed strong DPPH radical-scavenging and ferric-reducing antioxidant power close to or higher than trolox, and protected HT-22 neuronal cells from hydrogen-peroxide-induced oxidative damage.}
}

@article{keshavarz2013carum,
  author   = {Keshavarz, A., Minaiyan, M., Ghannadi, A. and Mahzouni, P.},
  title    = {Effects of Carum carvi L. (Caraway) extract and essential oil on TNBS-induced colitis in rats},
  journal  = {Research in Pharmaceutical Sciences},
  year     = {2013},
  volume   = {8},
  number   = {1},
  pages    = {1-8},
  url      = {https://pubmed.ncbi.nlm.nih.gov/24459470/},
  note     = {REF-0764},
  study_type = {preclinical},
  abstract = {Caraway (Carum carvi) has anti-inflammatory, spasmolytic, antimicrobial, antioxidant and carminative properties. Caraway hydroalcoholic extract and essential oil were tested in a TNBS-induced model of colitis in rats; at all doses tested they reduced colon tissue lesions and colitis indices (comparable to prednisolone and mesalazine references), supporting an anti-colitic and digestive benefit of caraway.}
}

@article{ghannay2022carum,
  author   = {Ghannay, S., Aouadi, K., Kadri, A. and Snoussi, M.},
  title    = {GC-MS Profiling, Vibriocidal, Antioxidant, Antibiofilm, and Anti-Quorum Sensing Properties of Carum carvi L. Essential Oil: In Vitro and In Silico Approaches},
  journal  = {Plants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {8},
  pages    = {1072},
  doi      = {10.3390/plants11081072},
  note     = {REF-0765},
  study_type = {preclinical},
  abstract = {Caraway essential oil (carvone/limonene chemotype) was active against all tested Vibrio species (bacteriostatic), exhibited antioxidant activity in four assays, and prevented bacterial cell-to-cell communication by inhibiting swarming motility and virulence-factor (elastase, protease, violacein) production, indicating antibacterial, antioxidant and anti-quorum-sensing potential of Carum carvi essential oil.}
}

@article{trifan2016carum,
  author   = {Trifan, A., Aprotosoaie, A.C., Cioancă, O., Hăcianu, M. et al.},
  title    = {Antioxidant Activity of Essential Oil From Carum carvi L. Cultivated in North-Eastern Romania},
  journal  = {Revista Medico-Chirurgicala a Societatii de Medici si Naturalisti din Iasi},
  year     = {2016},
  volume   = {120},
  number   = {3},
  pages    = {732-736},
  url      = {https://pubmed.ncbi.nlm.nih.gov/30152663/},
  note     = {REF-0766},
  study_type = {preclinical},
  abstract = {Essential oil isolated from dried caraway (Carum carvi) fruits, of the carvone chemotype (carvone 48.5%, limonene 44.4%), showed significant in vitro antioxidant activity in DPPH and ABTS radical-scavenging and reducing-power assays, suggesting potential as a natural alternative to conventional preservatives in food, cosmetic and pharmaceutical applications.}
}

@article{tuluce2011centaurium,
  author   = {Tuluce, Y., Ozkol, H., Koyuncu, I. and Ine, H.},
  title    = {Gastroprotective effect of small centaury (Centaurium erythraea L) on aspirin-induced gastric damage in rats},
  journal  = {Toxicology and Industrial Health},
  year     = {2011},
  volume   = {27},
  number   = {8},
  pages    = {760-768},
  doi      = {10.1177/0748233710397421},
  note     = {REF-0767},
  study_type = {preclinical},
  abstract = {The gastroprotective and antioxidant activity of a 50% aqueous-ethanolic Centaurium erythraea (small centaury) extract was investigated in an aspirin-induced acute gastric ulcer model in rats. The centaury extract significantly reduced the ulcer index by 77% versus aspirin alone, raised glutathione and vitamin A and lowered lipid peroxidation and myeloperoxidase, indicating protection against gastric damage through antioxidant activity, supporting its traditional digestive use.}
}

@article{chabane2023centaurium,
  author   = {Chabane, S., Boudjelal, A., Bouaziz-Terrachet, S., Spinozzi, E. et al.},
  title    = {Analgesic effect of Centaurium erythraea and molecular docking investigation of the major component swertiamarin},
  journal  = {Natural Product Research},
  year     = {2023},
  volume   = {38},
  number   = {24},
  pages    = {4511-4517},
  doi      = {10.1080/14786419.2023.2278160},
  note     = {REF-0768},
  study_type = {preclinical},
  abstract = {The ethanolic extract of the flowering aerial parts of Centaurium erythraea, characterised by the iridoid swertiamarin, was tested in pain models in Wistar rats. It significantly decreased acetic-acid-induced writhing (peripheral analgesia) and elevated the basal reaction time in the hot plate test (central analgesia); molecular docking showed good binding of swertiamarin to cyclooxygenase-2, justifying the traditional use of centaury as an analgesic remedy.}
}

@article{aksit2022centaurium,
  author   = {Akşit, H., Gözcü, S. and Altay, A.},
  title    = {Isolation and cytotoxic activities of undescribed iridoid and xanthone glycosides from Centaurium erythraea Rafn. (Gentianaceae)},
  journal  = {Phytochemistry},
  year     = {2022},
  volume   = {205},
  pages    = {113484},
  doi      = {10.1016/j.phytochem.2022.113484},
  note     = {REF-0769},
  study_type = {preclinical},
  abstract = {Several compounds, including secologanin derivatives and the xanthones erythraeaxanthone I and II, were isolated from the aerial parts of Centaurium erythraea and identified by NMR and mass spectrometry. Their cytotoxic potency was evaluated against human breast cancer (MCF-7, MDA-MB-453) and mouse fibroblast cell lines, with erythraeaxanthone II showing the most potent cytotoxic activity.}
}

@article{li2024chelidonium,
  author   = {Li, X.L., Sun, Y.P., Wang, M., Wang, Z.B. and Kuang, H.X.},
  title    = {Alkaloids in Chelidonium majus L.: a review of its phytochemistry, pharmacology and toxicology},
  journal  = {Frontiers in Pharmacology},
  year     = {2024},
  volume   = {15},
  pages    = {1440979},
  doi      = {10.3389/fphar.2024.1440979},
  note     = {REF-0770},
  study_type = {traditional},
  abstract = {Chelidonium majus has rich medicinal value, traditionally used to alleviate coughs, asthma, spasms and pain. It is abundant in alkaloids (94 isolated, including benzophenanthridine, protoberberine, aporphine and protopine types) which have anti-microbial, anti-inflammatory, anti-viral and anti-tumor effects. The review covers the phytochemistry, pharmacology and toxicology of C. majus alkaloids, noting the toxicity that limits internal use.}
}

@article{koriem2012chelidonium,
  author   = {Koriem, K.M.M., Arbid, M.S. and Asaad, G.F.},
  title    = {Chelidonium majus leaves methanol extract and its chelidonine alkaloid ingredient reduce cadmium-induced nephrotoxicity in rats},
  journal  = {Journal of Natural Medicines},
  year     = {2012},
  volume   = {67},
  number   = {1},
  pages    = {159-167},
  doi      = {10.1007/s11418-012-0667-6},
  note     = {REF-0771},
  study_type = {preclinical},
  abstract = {The kidney is a critical target for chronic cadmium toxicity. Methanol extract of Chelidonium majus leaves and its chelidonine alkaloid were evaluated in cadmium-intoxicated rats. Treatment shifted kidney weight, serum electrolytes, urinary volume, urea and creatinine towards normal values, with natriuretic and antidiuretic effects against cadmium-induced nephrotoxicity, supported by molecular and histological findings.}
}

@article{nawrot2017chelidonium,
  author   = {Nawrot, R.},
  title    = {Defense-related Proteins from Chelidonium majus L. as Important Components of its Latex},
  journal  = {Current Protein & Peptide Science},
  year     = {2017},
  volume   = {18},
  number   = {8},
  pages    = {864-880},
  doi      = {10.2174/1389203718666170406124013},
  note     = {REF-0772},
  study_type = {traditional},
  abstract = {This review covers pathogenesis- and defense-related proteins from the latex-bearing medicinal plant Chelidonium majus (Papaveraceae) in the context of latex activity, function, pharmacological activities and antiviral medicinal use. The latex-borne defense system is hypothesized to constitute a preformed immediate defense response against viral and non-viral pathogens, relevant to celandine's traditional antiviral (wart) use.}
}

@article{rezig2023cnicus,
  author   = {Rezig, K., Benkaci-Ali, F., Foucaunier, M.L., Laurent, S. et al.},
  title    = {HPLC/ESI-MS Characterization of Phenolic Compounds from Cnicus benedictus L. Roots: A Study of Antioxidant, Antibacterial, Anti-Inflammatory, and Anti-Alzheimer's Activity},
  journal  = {Chemistry & Biodiversity},
  year     = {2023},
  volume   = {21},
  number   = {1},
  pages    = {e202300724},
  doi      = {10.1002/cbdv.202300724},
  note     = {REF-0773},
  study_type = {preclinical},
  abstract = {The phenolic composition of Cnicus benedictus roots was characterised by HPLC-LC/MS, with trans-chalcone, 2,3-dihydroflavone, 3-hydroxyflavone, cinnamic acid and rutin as major components. The hydro-methanolic and hydro-ethanolic root extracts exhibited high anti-inflammatory activity (5-lipoxygenase inhibition), antioxidant and antibacterial activity (comparable to amoxicillin), and predicted anti-Alzheimer activity.}
}

@article{ahmadimoghaddam2020cnicus,
  author   = {Ahmadimoghaddam, D., Sadeghian, R., Ranjbar, A., Izadidastenaei, Z. and Mohammadi, S.},
  title    = {Antinociceptive activity of Cnicus benedictus L. leaf extract: a mechanistic evaluation},
  journal  = {Research in Pharmaceutical Sciences},
  year     = {2020},
  volume   = {15},
  number   = {5},
  pages    = {463-472},
  doi      = {10.4103/1735-5362.297849},
  note     = {REF-0774},
  study_type = {preclinical},
  abstract = {Cnicus benedictus has traditionally been used for stomachache pain. The leaf methanolic extract (CBHE) and its major constituent cnicin showed significant antinociceptive effects in writhing, tail-flick and formalin tests in mice. The mechanism involved opioidergic pathways and the L-arginine/NO/cGMP/ATP-sensitive potassium channel pathway, supporting the traditional analgesic and digestive use of blessed thistle.}
}

@article{zhang2024cnicus,
  author   = {Zhang, J., Shen, S., Zhu, S., Jia, F. et al.},
  title    = {Cnicus benedictus extract-loaded electrospun gelatin wound dressing for treating diabetic wounds: An in vitro and in vivo study},
  journal  = {Journal of Applied Biomaterials & Functional Materials},
  year     = {2024},
  volume   = {22},
  pages    = {22808000241245298},
  doi      = {10.1177/22808000241245298},
  note     = {REF-0775},
  study_type = {preclinical},
  abstract = {Cnicus benedictus extract was loaded into electrospun gelatin scaffolds for diabetic wound healing. The dressings showed anti-inflammatory properties and prevented bacterial penetration in vitro; in a rat model of diabetic wounds, extract-loaded scaffolds significantly increased wound-size reduction, collagen deposition and epithelial thickness and upregulated VEGF and IGF expression, supporting the traditional wound-healing use of blessed thistle.}
}

@article{lan2021cordycepin,
  author   = {Lan, T., Yu, Y., Zhang, J., Li, H. et al.},
  title    = {Cordycepin Ameliorates Nonalcoholic Steatohepatitis by Activation of the AMP-Activated Protein Kinase Signaling Pathway},
  journal  = {Hepatology},
  year     = {2021},
  volume   = {74},
  number   = {2},
  pages    = {686-703},
  doi      = {10.1002/hep.31749},
  note     = {REF-0776},
  study_type = {preclinical},
  abstract = {Cordycepin, a natural product isolated from Cordyceps militaris, was evaluated in mice with diet-induced nonalcoholic steatohepatitis (NASH). Cordycepin attenuated hepatic lipid accumulation, inflammation, liver injury and fibrosis through activation of the AMP-activated protein kinase (AMPK) signaling pathway, suggesting cordycepin as a potential AMPK-activating treatment for NASH.}
}

@article{wei2021cordycepin,
  author   = {Wei, P., Wang, K., Luo, C., Huang, Y. et al.},
  title    = {Cordycepin confers long-term neuroprotection via inhibiting neutrophil infiltration and neuroinflammation after traumatic brain injury},
  journal  = {Journal of Neuroinflammation},
  year     = {2021},
  volume   = {18},
  number   = {1},
  pages    = {137},
  doi      = {10.1186/s12974-021-02188-x},
  note     = {REF-0777},
  study_type = {preclinical},
  abstract = {Cordycepin, an extract from Cordyceps militaris, ameliorated long-term neurological deficits and reduced neuronal tissue loss in a mouse model of traumatic brain injury. It inhibited pro-inflammatory microglia/macrophage polarization, attenuated blood-brain-barrier breach and suppressed neutrophil infiltration, preserving white-matter integrity, indicating long-term neuroprotective and anti-neuroinflammatory effects.}
}

@article{tan2020cordycepin,
  author   = {Tan, L., Song, X., Ren, Y., Wang, M. et al.},
  title    = {Anti-inflammatory effects of cordycepin: A review},
  journal  = {Phytotherapy Research},
  year     = {2020},
  doi      = {10.1002/ptr.6890},
  note     = {REF-0778},
  study_type = {traditional},
  abstract = {Cordycepin is the major bioactive component extracted from Cordyceps militaris. This review summarises its anti-inflammatory and related effects, with protective activity in acute lung injury, asthma, rheumatoid arthritis, Parkinson's disease, hepatitis, atherosclerosis and atopic dermatitis, acting through NF-kB and other signaling pathways, and notes its immune-enhancing and antiviral potential.}
}

@article{santibanez2023coriander,
  author   = {Santibáñez, A., Jiménez-Ferrer, E., Angulo-Bejarano, P.I., Sharma, A. and Herrera-Ruiz, M.},
  title    = {Coriandrum sativum and Its Utility in Psychiatric Disorders},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {14},
  pages    = {5314},
  doi      = {10.3390/molecules28145314},
  note     = {REF-0779},
  study_type = {traditional},
  abstract = {Coriandrum sativum offers a rich source of metabolites, mainly terpenes and flavonoids, with in vitro and in vivo activity on central-nervous-system disorder models. Some compounds chemically interact with GABA, 5-HT and NMDA receptors, key to the pathophysiology of psychiatric and neurological diseases, supporting coriander as a potential anxiolytic, antidepressant, antiepileptic and sleep enhancer.}
}

@article{wei2019coriander,
  author   = {Wei, J.N., Liu, Z.H., Zhao, Y.P., Zhao, L.L. et al.},
  title    = {Phytochemical and bioactive profile of Coriandrum sativum L.},
  journal  = {Food Chemistry},
  year     = {2019},
  volume   = {286},
  pages    = {260-267},
  doi      = {10.1016/j.foodchem.2019.01.171},
  note     = {REF-0780},
  study_type = {traditional},
  abstract = {Coriandrum sativum is well known for its food and medicine uses. The main bioactive constituents are essential oil, fatty acids, tocol, sterol and carotenoids. Coriander and its extracts possess varying degrees of antioxidative and antimicrobial activities on account of their active constituents. The review summarises the general usages, chemical compositions, bioactivities and safety considerations of coriander.}
}

@article{hosseini2021coriander,
  author   = {Hosseini, M., Boskabady, M.H. and Khazdair, M.R.},
  title    = {Neuroprotective effects of Coriandrum sativum and its constituent, linalool: A review},
  journal  = {Avicenna Journal of Phytomedicine},
  year     = {2021},
  volume   = {11},
  number   = {5},
  pages    = {436-450},
  doi      = {10.22038/AJP.2021.55681.2786},
  note     = {REF-0781},
  study_type = {traditional},
  abstract = {Coriander (Coriandrum sativum) is traditionally used for digestive problems, flatulence, diarrhea and colic. Antioxidant, diuretic, cholesterol-lowering, anxiolytic, sedative-hypnotic and anticonvulsant activities were reported for the seeds and leaves; its main component linalool shows anti-anxiety, sedative, anticonvulsant and anti-Alzheimer's activities. The review summarises the neuropharmacological and antioxidant/anti-inflammatory effects of coriander.}
}

@article{fong2002hawthorn,
  author   = {Fong, H.H.S. and Bauman, J.L.},
  title    = {Hawthorn},
  journal  = {Journal of Cardiovascular Nursing},
  year     = {2002},
  volume   = {16},
  number   = {4},
  pages    = {1-8},
  doi      = {10.1097/00005082-200207000-00002},
  note     = {REF-0782},
  study_type = {traditional},
  abstract = {Crataegus laevigata, C. monogyna and related species (hawthorn) have been used to treat cardiovascular diseases. Clinical studies show standardized extracts are promising adjunctive agents for left ventricular dysfunction, consistently improving exercise tolerance and symptoms of mild to moderate heart failure, with preliminary evidence of improved left ventricular ejection fraction.}
}

@article{orhan2018hawthorn,
  author   = {Orhan, I.E.},
  title    = {Phytochemical and Pharmacological Activity Profile of Crataegus oxyacantha L. (Hawthorn) - A Cardiotonic Herb},
  journal  = {Current Medicinal Chemistry},
  year     = {2018},
  volume   = {25},
  number   = {37},
  pages    = {4854-4865},
  doi      = {10.2174/0929867323666160919095519},
  note     = {REF-0783},
  study_type = {traditional},
  abstract = {Crataegus oxyacantha (= C. laevigata) is a medicinally recognised hawthorn species in the European Pharmacopoeia, standardized to oligomeric procyanidins. It is used for heart failure (NYHA stages I-II), angina pectoris, hypertension with myocardial insufficiency and mild cardiac-rhythm alterations, and shows positive inotropic, negative chronotropic, ACE-inhibitory, anti-inflammatory and antihyperlipidemic effects supporting its cardioactive efficacy.}
}

@article{ahmadipour2024hawthorn,
  author   = {Ahmadipour, B., Kalantar, M., Abaszadeh, S. and Hassanpour, H.},
  title    = {Antioxidant and antihyperlipidemic effects of hawthorn extract (Crataegus oxyacantha) in broiler chickens},
  journal  = {Veterinary Medicine and Science},
  year     = {2024},
  volume   = {10},
  number   = {3},
  pages    = {e1414},
  doi      = {10.1002/vms3.1414},
  note     = {REF-0784},
  study_type = {preclinical},
  abstract = {Hawthorn extract (Crataegus oxyacantha) added to drinking water improved growth performance and decreased abdominal fat in broiler chickens. It lowered circulating malondialdehyde, triacylglycerol, total cholesterol and LDL-cholesterol, raised ferric-reducing antioxidant power and HDL, and upregulated antioxidant enzymes (catalase, SOD, glutathione peroxidase), demonstrating antioxidant and antihyperlipidemic effects.}
}

@article{amrati2024monogyna,
  author   = {Ez-Zahra Amrati, F., Mssillou, I., Boukhira, S., Djiddi Bichara, M. et al.},
  title    = {Phenolic Composition of Crataegus monogyna Jacq. Extract and Its Anti-Inflammatory, Hepatoprotective, and Antileukemia Effects},
  journal  = {Pharmaceuticals (Basel)},
  year     = {2024},
  volume   = {17},
  number   = {6},
  pages    = {786},
  doi      = {10.3390/ph17060786},
  note     = {REF-0785},
  study_type = {preclinical},
  abstract = {A hydroethanolic extract of Crataegus monogyna leaves and stems was profiled by UHPLC (procyanidin, quercetin, catechin) and tested for anti-inflammatory, hepatoprotective and anticancer activity. The 1000 mg/kg dose inhibited carrageenan-induced paw edema by 99% after 6 h in rats, the extract displayed hepatoprotective properties against acetaminophen-induced hepatotoxicity, and it showed cytotoxic activity against K-562 and HL-60 myeloleukemia cells.}
}

@article{lis2019monogyna,
  author   = {Lis, M., Szczypka, M., Suszko-Pawłowska, A., Sokół-Łętowska, A. et al.},
  title    = {Hawthorn (Crataegus monogyna) Phenolic Extract Modulates Lymphocyte Subsets and Humoral Immune Response in Mice},
  journal  = {Planta Medica},
  year     = {2019},
  volume   = {86},
  number   = {2},
  pages    = {160-168},
  doi      = {10.1055/a-1045-5437},
  note     = {REF-0786},
  study_type = {preclinical},
  abstract = {Crataegus monogyna phenolic extract was administered orally to mice and its effect on lymphocyte subsets in lymphoid organs and on humoral immune response to sheep red blood cells was assessed. The extract modulated thymocyte and T/B splenocyte populations and, at ten doses, elevated plaque-forming cells and anti-SRBC hemagglutinin titer, indicating that hawthorn extract may act as an immunomodulator.}
}

@article{paun2024monogyna,
  author   = {Paun, G., Neagu, E., Albu, C., Alecu, A. et al.},
  title    = {Antioxidant and Antidiabetic Activity of Crataegus monogyna L. and Cornus mas Fruit Extracts},
  journal  = {Molecules},
  year     = {2024},
  volume   = {29},
  number   = {15},
  pages    = {3595},
  doi      = {10.3390/molecules29153595},
  note     = {REF-0787},
  study_type = {preclinical},
  abstract = {Polyphenol- and vitamin-C-rich fruit extracts of Crataegus monogyna and Cornus mas were prepared by green extraction methods. The extracts showed antioxidant activity (DPPH, reducing power) and antidiabetic activity by inhibiting alpha-amylase and alpha-glucosidase and by stimulating insulin secretion in beta-TC-6 cells under normal and hyperglycemic conditions, indicating hawthorn fruit as a source of antioxidant and antidiabetic bioactive molecules.}
}

@article{shafiee2025saffron,
  author   = {Shafiee, A., Jafarabady, K., Seighali, N., Mohammadi, I. et al.},
  title    = {Effect of Saffron Versus Selective Serotonin Reuptake Inhibitors (SSRIs) in Treatment of Depression and Anxiety: A Meta-analysis of Randomized Controlled Trials},
  journal  = {Nutrition Reviews},
  year     = {2025},
  volume   = {83},
  number   = {3},
  pages    = {e751-e761},
  doi      = {10.1093/nutrit/nuae076},
  note     = {REF-0788},
  study_type = {systematic-review},
  abstract = {This systematic review and meta-analysis of randomized controlled trials compared saffron (Crocus sativus) with SSRIs in adults with depression or anxiety. Meta-analysis of 8 depression trials and 4 anxiety trials found no significant difference between saffron and SSRIs in reducing depressive or anxiety symptoms, while participants receiving saffron had fewer adverse events, suggesting saffron is a potential SSRI alternative with a better tolerability profile.}
}

@article{lopresti2014saffron,
  author   = {Lopresti, A.L. and Drummond, P.D.},
  title    = {Saffron (Crocus sativus) for depression: a systematic review of clinical studies and examination of underlying antidepressant mechanisms of action},
  journal  = {Human Psychopharmacology},
  year     = {2014},
  volume   = {29},
  number   = {6},
  pages    = {517-527},
  doi      = {10.1002/hup.2434},
  note     = {REF-0789},
  study_type = {systematic-review},
  abstract = {A systematic review of six randomized, double-blind clinical trials of saffron for depression. In placebo-comparison trials saffron had large treatment effects, and compared with antidepressant medications it had similar antidepressant efficacy. Saffron's antidepressant effects are potentially due to its serotonergic, antioxidant, anti-inflammatory, neuro-endocrine and neuroprotective actions, providing initial support for its use in mild-to-moderate depression.}
}

@article{chen2022saffron,
  author   = {Chen, Z., Gu, J., Lin, S., Xu, Z. et al.},
  title    = {Saffron essential oil ameliorates CUMS-induced depression-like behavior in mice via the MAPK-CREB1-BDNF signaling pathway},
  journal  = {Journal of Ethnopharmacology},
  year     = {2022},
  volume   = {300},
  pages    = {115719},
  doi      = {10.1016/j.jep.2022.115719},
  note     = {REF-0790},
  study_type = {preclinical},
  abstract = {Saffron (Crocus sativus) has a long history in the treatment of depression. In mice exposed to chronic unpredictable mild stress, inhaled saffron essential oil improved depression-like behaviors, raised serum 5-HT, dopamine, BDNF and GABA, and ameliorated hippocampal neuronal damage, acting mainly through upregulation of the MAPK-CREB1-BDNF signaling pathway.}
}

@article{zeng2022curcumin,
  author   = {Zeng, L., Yang, T., Yang, K., Yu, G. et al.},
  title    = {Efficacy and Safety of Curcumin and Curcuma longa Extract in the Treatment of Arthritis: A Systematic Review and Meta-Analysis of Randomized Controlled Trials},
  journal  = {Frontiers in Immunology},
  year     = {2022},
  volume   = {13},
  pages    = {891822},
  doi      = {10.3389/fimmu.2022.891822},
  note     = {REF-0791},
  study_type = {systematic-review},
  abstract = {A systematic review and meta-analysis of 29 randomized controlled trials (2396 participants) across five types of arthritis (ankylosing spondylitis, rheumatoid arthritis, osteoarthritis, juvenile idiopathic arthritis and gout/hyperuricemia). Curcumin and Curcuma longa extract (120-1500 mg, 4-36 weeks) were safe and improved the severity of inflammation and pain in arthritis patients.}
}

@article{zeng2021curcumin,
  author   = {Zeng, L., Yu, G., Hao, W., Yang, K. and Chen, H.},
  title    = {The efficacy and safety of Curcuma longa extract and curcumin supplements on osteoarthritis: a systematic review and meta-analysis},
  journal  = {Bioscience Reports},
  year     = {2021},
  volume   = {41},
  number   = {6},
  pages    = {BSR20210817},
  doi      = {10.1042/BSR20210817},
  note     = {REF-0792},
  study_type = {systematic-review},
  abstract = {A systematic review and meta-analysis of 15 randomized controlled trials (1621 participants) of Curcuma longa extract and curcumin for osteoarthritis. Compared with placebo, they decreased the VAS and WOMAC pain, function and stiffness scores with adverse events comparable to placebo, and showed effects on joint pain, function and stiffness similar to NSAIDs but with fewer adverse events; use for more than 12 weeks is recommended.}
}

@article{marton2021curcumin,
  author   = {Marton, L.T., Pescinini-E-Salzedas, L.M., Camargo, M.E.C., Barbalho, S.M. et al.},
  title    = {The Effects of Curcumin on Diabetes Mellitus: A Systematic Review},
  journal  = {Frontiers in Endocrinology},
  year     = {2021},
  volume   = {12},
  pages    = {669448},
  doi      = {10.3389/fendo.2021.669448},
  note     = {REF-0793},
  study_type = {systematic-review},
  abstract = {A systematic review of sixteen studies on Curcuma longa / curcumin in diabetes mellitus. Curcumin's anti-diabetic activity may be due to its capacity to suppress oxidative stress and inflammation; it significantly reduced fasting blood glucose, glycated hemoglobin and body mass index, and nanocurcumin reduced triglycerides, total and LDL cholesterol, C-reactive protein and malondialdehyde, supporting its use in the management of diabetes.}
}

@article{depypere2013menopause,
  author   = {Depypere, H.T. and Comhaire, F.H.},
  title    = {Herbal preparations for the menopause: beyond isoflavones and black cohosh},
  journal  = {Maturitas},
  year     = {2013},
  volume   = {77},
  number   = {2},
  pages    = {191-194},
  doi      = {10.1016/j.maturitas.2013.11.001},
  note     = {REF-0794},
  study_type = {traditional},
  abstract = {A minireview of the evidence for herbal preparations used for menopausal symptoms beyond isoflavones and black cohosh. Randomized controlled trials find that Mediterranean pine bark, linseed and Maca reduce vasomotor symptoms, while animal and human studies suggest Dioscorea villosa (wild yam) and others may protect against osteoporosis and breast and gynecological cancers, though further evidence is required.}
}

@article{cai2020diosgenin,
  author   = {Cai, B., Zhang, Y., Wang, Z., Xu, D. et al.},
  title    = {Therapeutic Potential of Diosgenin and Its Major Derivatives against Neurological Diseases: Recent Advances},
  journal  = {Oxidative Medicine and Cellular Longevity},
  year     = {2020},
  volume   = {2020},
  pages    = {3153082},
  doi      = {10.1155/2020/3153082},
  note     = {REF-0795},
  study_type = {traditional},
  abstract = {Diosgenin, a steroidal sapogenin abundant in medicinal herbs such as Dioscorea villosa (wild yam) and a major starting material for steroidal drugs, has wide-ranging pharmacological activities. This review summarises the therapeutic potential of diosgenin and its derivatives against neurological disorders including Parkinson's disease, Alzheimer's disease, brain injury, neuroinflammation and ischemia, mediated through multiple signaling pathways.}
}

@article{raj2023dioscorea,
  author   = {Raj, P.S., Bergfeld, W.F., Belsito, D.V., Cohen, D.E. et al.},
  title    = {Safety Assessment of Dioscorea Villosa (Wild Yam) Root Extract as Used in Cosmetics},
  journal  = {International Journal of Toxicology},
  year     = {2023},
  volume   = {42},
  number   = {3_suppl},
  pages    = {29S-31S},
  doi      = {10.1177/10915818231204230},
  note     = {REF-0796},
  study_type = {traditional},
  abstract = {The Expert Panel for Cosmetic Ingredient Safety reviewed updated information on Dioscorea villosa (wild yam) root extract and reaffirmed its original conclusion that the extract is safe as a cosmetic ingredient in the current practices of use and concentration, supporting the topical safety profile of wild yam preparations.}
}

@article{karschvolk2014echinacea,
  author   = {Karsch-Völk, M., Barrett, B., Kiefer, D., Bauer, R. et al.},
  title    = {Echinacea for preventing and treating the common cold},
  journal  = {Cochrane Database of Systematic Reviews},
  year     = {2014},
  volume   = {2},
  number   = {2},
  pages    = {CD000530},
  doi      = {10.1002/14651858.CD000530.pub3},
  note     = {REF-0797},
  study_type = {systematic-review},
  abstract = {A Cochrane systematic review of 24 double-blind trials (4631 participants) comparing mono-preparations of Echinacea with placebo for the common cold, including seven trials of preparations based on the aerial parts of Echinacea purpurea. Individual prevention trials consistently showed positive (if non-significant) trends, with a post-hoc pooled relative risk reduction of 10-20%; adverse events did not differ significantly from placebo.}
}

@article{kamin2025phytotherapy,
  author   = {Kamin, W., Seifert, G., Zwiauer, K., Bonhoeffer, J. et al.},
  title    = {Phytotherapy for acute respiratory tract infections in children: a systematically conducted, comprehensive review},
  journal  = {Frontiers in Pediatrics},
  year     = {2025},
  volume   = {13},
  pages    = {1423250},
  doi      = {10.3389/fped.2025.1423250},
  note     = {REF-0798},
  study_type = {systematic-review},
  abstract = {A systematically conducted review (PRISMA) of 45 reports on phytopharmaceuticals for paediatric acute respiratory tract infections, including various purple coneflower (Echinacea purpurea) preparations alongside ivy leaf, African geranium and others. The review presents the available efficacy and tolerability evidence for these herbal medicines as alternatives to reduce inappropriate antibiotic use in children.}
}

@article{fashner2012coldtreatment,
  author   = {Fashner, J., Ericson, K. and Werner, S.},
  title    = {Treatment of the common cold in children and adults},
  journal  = {American Family Physician},
  year     = {2012},
  volume   = {86},
  number   = {2},
  pages    = {153-159},
  url      = {https://pubmed.ncbi.nlm.nih.gov/22962927/},
  note     = {REF-0799},
  study_type = {traditional},
  abstract = {A clinical review of treatments for the common cold. For adults, nonsteroidal anti-inflammatory drugs and some herbal preparations, including Echinacea purpurea, improve symptoms, whereas Echinacea angustifolia preparations are ineffective; the review summarises the evidence and safety of symptomatic cold treatments in children and adults.}
}

@article{li2022eleutherococcus,
  author   = {Li, X.T., Zhou, J.C., Zhou, Y., Ren, Y.S. et al.},
  title    = {Pharmacological effects of Eleutherococcus senticosus on the neurological disorders},
  journal  = {Phytotherapy Research},
  year     = {2022},
  volume   = {36},
  number   = {9},
  pages    = {3490-3504},
  doi      = {10.1002/ptr.7555},
  note     = {REF-0800},
  study_type = {traditional},
  abstract = {Eleutherococcus senticosus is widely used in traditional medicine with anti-fatigue, sleep-improving and memory-enhancing effects. This review summarises its therapeutic effects on fatigue, depression, Alzheimer's disease, Parkinson's disease and cerebral ischemia, and the underlying mechanisms (anti-oxidative damage, anti-inflammation, neurotransmitter modulation, improvement of neuronal growth and anti-apoptosis), supporting its development as a neuroprotective phytotherapy agent.}
}

@article{li2021eleutherococcuspoly,
  author   = {Li, X., Chen, C., Leng, A. and Qu, J.},
  title    = {Advances in the Extraction, Purification, Structural Characteristics and Biological Activities of Eleutherococcus senticosus Polysaccharides},
  journal  = {Frontiers in Pharmacology},
  year     = {2021},
  volume   = {12},
  pages    = {753007},
  doi      = {10.3389/fphar.2021.753007},
  note     = {REF-0801},
  study_type = {traditional},
  abstract = {Eleutherococcus senticosus is a medicine-and-food plant with anti-tumor, anti-inflammatory, central-nervous-system and cardiovascular-protective, anti-radiation and anti-fatigue effects. This review focuses on its polysaccharides (ESPS), summarising progress in their extraction, separation, structural characterisation and biological activity as a basis for further development and utilisation of this medicinal and edible resource.}
}

@article{wrobelbiedrawa2024adaptogens,
  author   = {Wróbel-Biedrawa, D. and Podolak, I.},
  title    = {Anti-Neuroinflammatory Effects of Adaptogens: A Mini-Review},
  journal  = {Molecules},
  year     = {2024},
  volume   = {29},
  number   = {4},
  pages    = {866},
  doi      = {10.3390/molecules29040866},
  note     = {REF-0802},
  study_type = {traditional},
  abstract = {Adaptogens, including Eleutherococcus senticosus, exhibit complex nonspecific effects that increase the body's ability to adapt and survive stress. This mini-review presents the anti-neuroinflammatory potential of the most important adaptogenic plants: they display anti-inflammatory effects, regulating the gene expression of pro- and anti-inflammatory cytokines and modulating signaling pathways such as NF-kB, relevant to central-nervous-system disorders.}
}

@article{vitalone2018epilobium,
  author   = {Vitalone, A. and Allkanjari, O.},
  title    = {Epilobium spp: Pharmacology and Phytochemistry},
  journal  = {Phytotherapy Research},
  year     = {2018},
  volume   = {32},
  number   = {7},
  pages    = {1229-1240},
  doi      = {10.1002/ptr.6072},
  note     = {REF-0803},
  study_type = {traditional},
  abstract = {Epilobium species and their extracts are popular in folk medicine for a wide range of applications. This review analyses the pharmacological properties of Epilobium spp (anti-inflammatory, antioxidant, antitumor, antimicrobial, analgesic and antiandrogenic) and whether they justify the traditional use of willowherb, particularly for prostate conditions, noting that randomized controlled trials are still needed.}
}

@article{cicero2019nutraceutical,
  author   = {Cicero, A.F.G., Allkanjari, O., Busetto, G.M., Cai, T. et al.},
  title    = {Nutraceutical treatment and prevention of benign prostatic hyperplasia and prostate cancer},
  journal  = {Archivio Italiano di Urologia e Andrologia},
  year     = {2019},
  volume   = {91},
  number   = {3},
  pages    = {139-152},
  doi      = {10.4081/aiua.2019.3.139},
  note     = {REF-0804},
  study_type = {traditional},
  abstract = {This review covers medicinal plants used for prostate diseases such as benign prostatic hyperplasia, prostatitis and chronic pelvic pain syndrome, whose desired pharmacological properties are anti-androgenic, anti-estrogenic, antiproliferative, antioxidant and anti-inflammatory. Alongside Serenoa repens, Pygeum africanum and Urtica dioica, Epilobium spp is highlighted as a promising plant for prostatic disease, supporting the traditional use of willowherb for prostate health.}
}

@article{vlase2024epilobium,
  author   = {Vlase, A.M., Toiu, A., Gligor, O., Muntean, D. et al.},
  title    = {Investigation of Epilobium hirsutum L. Optimized Extract's Anti-Inflammatory and Antitumor Potential},
  journal  = {Plants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {2},
  pages    = {198},
  doi      = {10.3390/plants13020198},
  note     = {REF-0805},
  study_type = {preclinical},
  abstract = {An optimized extract of Epilobium hirsutum (a willowherb congener) was tested in animal models. In carrageenan-induced paw inflammation it showed anti-inflammatory properties comparable to indomethacin, and in an Ehrlich ascites carcinoma model it reduced tumor-associated inflammation and oxidative stress, indicating potential as a natural adjuvant against inflammation and oxidative stress.}
}

@article{rolland1991eschscholzia,
  author   = {Rolland, A., Fleurentin, J., Lanhers, M.C., Younos, C. et al.},
  title    = {Behavioural effects of the American traditional plant Eschscholzia californica: sedative and anxiolytic properties},
  journal  = {Planta Medica},
  year     = {1991},
  volume   = {57},
  number   = {3},
  pages    = {212-216},
  doi      = {10.1055/s-2006-960076},
  note     = {REF-0806},
  study_type = {preclinical},
  abstract = {An aqueous extract of Eschscholzia californica, traditionally used by Californian populations for its analgesic and sedative properties, reduced behavioural parameters in mice at doses above 100 mg/kg and induced sleep, validating its sedative properties; at 25 mg/kg it produced anxiolytic (anticonflict) effects without toxic effects, supporting the traditional sedative/anxiolytic use of California poppy.}
}

@article{rolland2001eschscholzia,
  author   = {Rolland, A., Fleurentin, J., Lanhers, M.C., Misslin, R. and Mortier, F.},
  title    = {Neurophysiological effects of an extract of Eschscholzia californica Cham. (Papaveraceae)},
  journal  = {Phytotherapy Research},
  year     = {2001},
  volume   = {15},
  number   = {5},
  pages    = {377-381},
  doi      = {10.1002/ptr.884},
  note     = {REF-0807},
  study_type = {preclinical},
  abstract = {An aqueous-alcohol extract of Eschscholzia californica was evaluated for its mechanism of sedative and anxiolytic action. The extract appeared to possess affinity for the benzodiazepine receptor (flumazenil, a benzodiazepine antagonist, suppressed its sedative and anxiolytic effects) and induced peripheral analgesic effects, but had no antidepressant, neuroleptic or antihistaminic effects, clarifying the basis of California poppy's calming action.}
}

@article{kalyniukova2025eschscholzia,
  author   = {Kalyniukova, A., Ahmed, S., Ak, G., Saka, E. et al.},
  title    = {Comprehensive Metabolomic Profiling and Biological Activity Analysis of Eschscholzia californica Extracts Using LC-ESI-QTOF-MS},
  journal  = {Food Science & Nutrition},
  year     = {2025},
  volume   = {13},
  number   = {9},
  pages    = {e70885},
  doi      = {10.1002/fsn3.70885},
  note     = {REF-0808},
  study_type = {preclinical},
  abstract = {LC-ESI-QTOF-MS profiling of Eschscholzia californica aerial-part extracts identified 70 compounds including rutin, quinoline alkaloids, morphine derivatives and scoulerine. Extracts showed antioxidant, anti-acetylcholinesterase, anti-tyrosinase and anti-glucosidase activity, and in silico studies showed protopine, rutin, eschscholtzidine, boldine and scoulerine inhibit insomnia-related DRD5, DRD4 and SERT proteins, supporting the plant's traditional use for sleep.}
}

@article{cmikova2023eucalyptus,
  author   = {Čmiková, N., Galovičová, L., Schwarzová, M., Vukic, M.D. et al.},
  title    = {Chemical Composition and Biological Activities of Eucalyptus globulus Essential Oil},
  journal  = {Plants (Basel)},
  year     = {2023},
  volume   = {12},
  number   = {5},
  pages    = {1076},
  doi      = {10.3390/plants12051076},
  note     = {REF-0809},
  study_type = {preclinical},
  abstract = {Eucalyptus globulus essential oil (EGEO), dominated by 1,8-cineole (63.1%), p-cymene, alpha-pinene and limonene (over 99% monoterpenes), was analysed for antimicrobial, antibiofilm, antioxidant and insecticidal activity. EGEO showed antioxidant capacity, antimicrobial activity (strongest against Gram-positive bacteria and microscopic fungi, especially in the vapour phase), antibiofilm activity and insecticidal activity.}
}

@article{elangovan2023eucalyptus,
  author   = {Elangovan, S. and Mudgil, P.},
  title    = {Antibacterial Properties of Eucalyptus globulus Essential Oil against MRSA: A Systematic Review},
  journal  = {Antibiotics (Basel)},
  year     = {2023},
  volume   = {12},
  number   = {3},
  pages    = {474},
  doi      = {10.3390/antibiotics12030474},
  note     = {REF-0810},
  study_type = {systematic-review},
  abstract = {A systematic review of 20 studies (2002-2022) on the antibacterial properties of Eucalyptus globulus essential oil against methicillin-resistant Staphylococcus aureus (MRSA). The findings suggest E. globulus essential oil has antibacterial properties against MRSA, which can be enhanced when used in combination with other essential oils and antibiotics, supporting its potential as an alternative antimicrobial agent.}
}

@article{zonfrillo2022eucalyptus,
  author   = {Zonfrillo, M., Andreola, F., Krasnowska, E.K., Sferrazza, G. et al.},
  title    = {Essential Oil from Eucalyptus globulus (Labill.) Activates Complement Receptor-Mediated Phagocytosis and Stimulates Podosome Formation in Human Monocyte-Derived Macrophages},
  journal  = {Molecules},
  year     = {2022},
  volume   = {27},
  number   = {11},
  pages    = {3488},
  doi      = {10.3390/molecules27113488},
  note     = {REF-0811},
  study_type = {preclinical},
  abstract = {Essential oil from Eucalyptus globulus, and its major component eucalyptol, stimulated the phagocytic activity of human monocyte-derived macrophages by activating complement-receptor-mediated phagocytosis and stimulating podosome formation, confirming the essential oil as a potent activator of innate cell-mediated immunity in addition to its known antiseptic and anti-inflammatory properties.}
}

@article{novy2015euphrasia,
  author   = {Novy, P., Davidova, H., Serrano-Rojero, C.S., Rondevaldova, J. et al.},
  title    = {Composition and Antimicrobial Activity of Euphrasia rostkoviana Hayne Essential Oil},
  journal  = {Evidence-Based Complementary and Alternative Medicine},
  year     = {2015},
  volume   = {2015},
  pages    = {734101},
  doi      = {10.1155/2015/734101},
  note     = {REF-0812},
  study_type = {preclinical},
  abstract = {Eyebright (Euphrasia rostkoviana, syn. E. officinalis) is traditionally used in Europe as an eyewash to treat eye ailments such as conjunctivitis and blepharitis associated with bacterial infections. This study characterised the essential oil (main constituents n-hexadecanoic acid, thymol, myristic acid, linalool and anethole) and showed antimicrobial activity against organisms associated with eye infections, especially Gram-positive bacteria, supporting the traditional ophthalmic use.}
}

@article{dambrosio2018euphrasia,
  author   = {D'Ambrosio, M., Ciocarlan, A. and Aricu, A.},
  title    = {Minor acetylated metabolites from Euphrasia rostkoviana},
  journal  = {Natural Product Research},
  year     = {2020},
  volume   = {34},
  number   = {2},
  pages    = {290-295},
  doi      = {10.1080/14786419.2018.1530227},
  note     = {REF-0813},
  study_type = {preclinical},
  abstract = {The phenylethanoids rostkovianoside and 6'-O-acetylcrassifolioside and the flavonoid rutin 3'''-acetate were isolated from the methanolic extract of the aerial parts of Euphrasia rostkoviana (syn. E. officinalis), and their structures elucidated by spectroscopic methods, characterising the phenylethanoid glycoside and flavonoid constituents of eyebright.}
}

@article{ververis2024euphrasia,
  author   = {Ververis, A., Kyriakou, S., Paraskeva, H., Panayiotidis, M.I. et al.},
  title    = {Chemical Characterization and Assessment of the Neuroprotective Potential of Euphrasia officinalis},
  journal  = {International Journal of Molecular Sciences},
  year     = {2024},
  volume   = {25},
  number   = {23},
  pages    = {12902},
  doi      = {10.3390/ijms252312902},
  note     = {REF-0814},
  study_type = {preclinical},
  abstract = {Eyebright (Euphrasia officinalis), used in folk medicine for eye disorders and memory loss, was extracted with solvents of different polarities. The extracts showed notable antioxidant capacity, and five extracts had significant anti-neurotoxic properties, enhancing cell viability by 17.5-22.6% in human neuroblastoma cells exposed to amyloid-beta peptides, highlighting the neuroprotective potential of eyebright.}
}

@article{samardzic2017filipendula,
  author   = {Samardžić, S., Arsenijević, J., Božić, D., Milenković, M. et al.},
  title    = {Antioxidant, anti-inflammatory and gastroprotective activity of Filipendula ulmaria (L.) Maxim. and Filipendula vulgaris Moench},
  journal  = {Journal of Ethnopharmacology},
  year     = {2017},
  volume   = {213},
  pages    = {132-137},
  doi      = {10.1016/j.jep.2017.11.013},
  note     = {REF-0815},
  study_type = {preclinical},
  abstract = {Meadowsweet (Filipendula ulmaria) is used in folk medicine for antirheumatic, antipyretic and anti-ulcer properties. Lyophilised flower infusions and isolated flavonoids (spiraeoside) and the tannin tellimagrandin II showed antioxidant (DPPH, FRAP) and anti-inflammatory activity (inhibition of eicosanoid biosynthesis in human platelets), and the infusions preserved gastric mucosal integrity in an ethanol-induced gastric injury model in rats, supporting the traditional use.}
}

@article{andonova2024meadowsweet,
  author   = {Andonova, T., Muhovski, Y., Apostolova, E., Naimov, S. et al.},
  title    = {DNA-Protective, Antioxidant and Anti-Carcinogenic Potential of Meadowsweet (Filipendula ulmaria) Dry Tincture},
  journal  = {Antioxidants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {10},
  pages    = {1200},
  doi      = {10.3390/antiox13101200},
  note     = {REF-0816},
  study_type = {preclinical},
  abstract = {A dry tincture of meadowsweet (Filipendula ulmaria) was analysed by HPLC (major phenolics: salicylic acid 18.84 mg/g, rutin, p-coumaric acid, quercetin, rosmarinic acid) and bioassayed. The high antioxidant potential was confirmed by four assays, and the study reported for the first time highly protective activity against oxidative DNA damage and an antiproliferative effect against hepatocellular carcinoma (HepG2) cells.}
}

@article{vanderauwera2023filipendula,
  author   = {Van der Auwera, A., Peeters, L., Foubert, K., Piazza, S. et al.},
  title    = {In Vitro Biotransformation and Anti-Inflammatory Activity of Constituents and Metabolites of Filipendula ulmaria},
  journal  = {Pharmaceutics},
  year     = {2023},
  volume   = {15},
  number   = {4},
  pages    = {1291},
  doi      = {10.3390/pharmaceutics15041291},
  note     = {REF-0817},
  study_type = {preclinical},
  abstract = {Filipendula ulmaria (meadowsweet) is widely used in phytotherapy against inflammatory diseases. An in vitro gastrointestinal biotransformation model showed glycosylated flavonoids (rutin, spiraeoside) decrease while aglycones (quercetin, apigenin, naringenin, kaempferol) increase in the colon; both the genuine and metabolised extracts inhibited COX-1 more than COX-2, indicating the anti-inflammatory activity arises from an additive/synergistic effect of constituents and gut-microbiota metabolites.}
}

@article{laanet2023galium,
  author   = {Laanet, P.R., Saar-Reismaa, P., Jõul, P., Bragina, O. and Vaher, M.},
  title    = {Phytochemical Screening and Antioxidant Activity of Selected Estonian Galium Species},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {6},
  pages    = {2867},
  doi      = {10.3390/molecules28062867},
  note     = {REF-0818},
  study_type = {preclinical},
  abstract = {Three Galium species from Estonia, including Galium aparine (cleavers), were characterised for non-volatile and volatile phytochemicals and antioxidant activity. High concentrations of polyphenols, flavonoids and iridoids were quantified (asperuloside, asperulosidic acid, chlorogenic acid as key compounds), and all Galium species exhibited strong antioxidant capacity (ORAC), supporting the antioxidant potential of cleavers.}
}

@article{antoniak2023galium,
  author   = {Antoniak, K., Studzińska-Sroka, E., Szymański, M., Dudek-Makuch, M. et al.},
  title    = {Antiangiogenic, Anti-Inflammatory and Antioxidant Properties of Bidens tripartita Herb, Galium verum Herb and Rumex hydrolapathum Root},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {13},
  pages    = {4966},
  doi      = {10.3390/molecules28134966},
  note     = {REF-0819},
  study_type = {preclinical},
  abstract = {Ethanolic extracts of three plants including Galium verum herb (a cleavers congener) were tested on endothelial cells. The Galium verum extract showed anti-inflammatory activity (reducing pro-inflammatory IL-8 and IL-6) and antioxidant activity (DPPH, FRAP) related to its polyphenol content, with effects on angiogenesis-related factors, indicating potential in disorders linked to inflammation and free-radical formation.}
}

@article{razzivina2024galium,
  author   = {Razzivina, V., Vasiljeva, A., Kronberga, A., Skudrins, G. et al.},
  title    = {Phenolic Content and Anti-Inflammatory Activity of Cultivated and Wild-Type Galium odoratum Extracts in Murine Bone Marrow-Derived Macrophages},
  journal  = {Antioxidants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {12},
  pages    = {1447},
  doi      = {10.3390/antiox13121447},
  note     = {REF-0820},
  study_type = {preclinical},
  abstract = {Galium odoratum (sweet woodruff, a cleavers congener) extracts from cultivated and wild plants were analysed. Phenolic content and antioxidant activity increased under sun-grown conditions (chlorogenic acid and rutin major contributors), and the extracts exhibited anti-inflammatory activity, reducing the M1 macrophage population, highlighting the antioxidant and anti-inflammatory potential of Galium species.}
}

@article{li2024ganoderma,
  author   = {Li, W., Zhou, Q., Lv, B., Li, N. et al.},
  title    = {Ganoderma lucidum Polysaccharide Supplementation Significantly Activates T-Cell-Mediated Antitumor Immunity and Enhances Anti-PD-1 Immunotherapy Efficacy in Colorectal Cancer},
  journal  = {Journal of Agricultural and Food Chemistry},
  year     = {2024},
  volume   = {72},
  number   = {21},
  pages    = {12072-12082},
  doi      = {10.1021/acs.jafc.3c08385},
  note     = {REF-0821},
  study_type = {preclinical},
  abstract = {Ganoderma lucidum (reishi) polysaccharide (GLP) significantly inhibited tumor growth and activated antitumor immunity in colorectal cancer: it increased cytotoxic CD8 T cells and Th1 helper cells while decreasing immunosuppressive Tregs, alleviated gut microbiota dysbiosis, increased short-chain fatty acid production, and enhanced the efficacy of anti-PD-1 immunotherapy, supporting reishi as an immunomodulatory prebiotic.}
}

@article{cai2017ganoderma,
  author   = {Cai, Q., Li, Y. and Pei, G.},
  title    = {Polysaccharides from Ganoderma lucidum attenuate microglia-mediated neuroinflammation and modulate microglial phagocytosis and behavioural response},
  journal  = {Journal of Neuroinflammation},
  year     = {2017},
  volume   = {14},
  number   = {1},
  pages    = {63},
  doi      = {10.1186/s12974-017-0839-0},
  note     = {REF-0822},
  study_type = {preclinical},
  abstract = {Ganoderma lucidum polysaccharides (GLP) down-regulated LPS- or amyloid-beta-induced pro-inflammatory cytokines and promoted anti-inflammatory cytokine expression in microglia, and attenuated inflammation-related microglial migration, morphological alterations and phagocytosis, suggesting the neuroprotective function of reishi polysaccharides is achieved through modulation of microglial inflammatory and behavioural responses.}
}

@article{zheng2023ganoderma,
  author   = {Zheng, G., Zhao, Y., Li, Z., Hua, Y. et al.},
  title    = {Ganoderma lucidum spore powder and derived triterpenes attenuate atherosclerosis and aortic calcification by stimulating ABCA1/G1-mediated macrophage cholesterol efflux and inactivating RUNX2-mediated VSMC osteogenesis},
  journal  = {Theranostics},
  year     = {2023},
  volume   = {13},
  number   = {4},
  pages    = {1325-1341},
  doi      = {10.7150/thno.80250},
  note     = {REF-0823},
  study_type = {preclinical},
  abstract = {Ganoderma lucidum spore powder (GLSP) and its triterpenes (ganoderic acids A, B, C6, G and ganodermanontriol) attenuated plaque area and aortic calcification in atherosclerotic mice by improving ABCA1/G1-mediated macrophage cholesterol efflux, reducing foam cells and inflammation, and inactivating RUNX2-mediated osteogenesis in vascular smooth muscle cells, suggesting reishi as a candidate against atherosclerosis and vascular calcification.}
}

@article{singh2019ginkgo,
  author   = {Singh, S.K., Srivastav, S., Castellani, R.J., Plascencia-Villa, G. and Perry, G.},
  title    = {Neuroprotective and Antioxidant Effect of Ginkgo biloba Extract Against AD and Other Neurological Disorders},
  journal  = {Neurotherapeutics},
  year     = {2019},
  volume   = {16},
  number   = {3},
  pages    = {666-674},
  doi      = {10.1007/s13311-019-00767-8},
  note     = {REF-0824},
  study_type = {traditional},
  abstract = {Ginkgo biloba extract (GBE) is one of the most investigated herbal remedies for cognitive disorders and Alzheimer's disease, taken as a dietary supplement to improve memory and age-related cognitive decline, although its efficacy remains controversial. This review summarises the potential use and antioxidant mechanisms of GBE in the prevention of Alzheimer's disease and other neurodegenerative disorders.}
}

@article{diamond2013ginkgo,
  author   = {Diamond, B.J. and Bailey, M.R.},
  title    = {Ginkgo biloba: indications, mechanisms, and safety},
  journal  = {Psychiatric Clinics of North America},
  year     = {2013},
  volume   = {36},
  number   = {1},
  pages    = {73-83},
  doi      = {10.1016/j.psc.2012.12.006},
  note     = {REF-0825},
  study_type = {traditional},
  abstract = {Ginkgo biloba special extract (EGb761) is used in most randomized controlled trials, with indications including cognition and memory in Alzheimer disease, age-associated dementia, cerebral insufficiency and intermittent claudication. Mechanisms include increasing cerebral blood flow and antioxidant, anti-inflammatory and antiplatelet effects. Possible interactions with warfarin, MAO inhibitors and other drugs are reviewed for safety.}
}

@article{pastorino2018liquorice,
  author   = {Pastorino, G., Cornara, L., Soares, S., Rodrigues, F. and Oliveira, M.B.P.P.},
  title    = {Liquorice (Glycyrrhiza glabra): A phytochemical and pharmacological review},
  journal  = {Phytotherapy Research},
  year     = {2018},
  volume   = {32},
  number   = {12},
  pages    = {2323-2339},
  doi      = {10.1002/ptr.6178},
  note     = {REF-0826},
  study_type = {traditional},
  abstract = {Glycyrrhiza glabra (liquorice) contains phytocompounds such as glycyrrhizin, 18-beta-glycyrrhetinic acid, glabrin A and B and isoflavones. Pharmacological experiments show extracts and pure compounds exhibit a broad range of biological properties including antibacterial, anti-inflammatory, antiviral, antioxidant and antidiabetic activities. The review provides a critical, updated overview of liquorice composition and biological activities and its therapeutic potential.}
}

@article{nazari2017licorice,
  author   = {Nazari, S., Rameshrad, M. and Hosseinzadeh, H.},
  title    = {Toxicological Effects of Glycyrrhiza glabra (Licorice): A Review},
  journal  = {Phytotherapy Research},
  year     = {2017},
  volume   = {31},
  number   = {11},
  pages    = {1635-1650},
  doi      = {10.1002/ptr.5893},
  note     = {REF-0827},
  study_type = {traditional},
  abstract = {This review gathers research on the toxicity of licorice (Glycyrrhiza glabra) and glycyrrhizin. G. glabra and glycyrrhizin salts are moderately toxic and need to be used with caution, especially in pregnancy. The most important side effects are hypertension and hypokalemia-induced secondary disorders, increased by prolonged use, decreased 11-beta-hydroxysteroid dehydrogenase activity, old age and female sex — key safety considerations for licorice use.}
}

@article{batiha2020licorice,
  author   = {El-Saber Batiha, G., Magdy Beshbishy, A., El-Mleeh, A., Abdel-Daim, M.M. and Prasad Devkota, H.},
  title    = {Traditional Uses, Bioactive Chemical Constituents, and Pharmacological and Toxicological Activities of Glycyrrhiza glabra L. (Fabaceae)},
  journal  = {Biomolecules},
  year     = {2020},
  volume   = {10},
  number   = {3},
  pages    = {352},
  doi      = {10.3390/biom10030352},
  note     = {REF-0828},
  study_type = {traditional},
  abstract = {Glycyrrhiza glabra (licorice) has been traditionally used to treat respiratory disorders, fever, stomach ulcers, rheumatism, skin diseases and jaundice. Chemical analysis revealed liquiritin, liquiritigenin, glycyrrhizin, isoangustone A and many other constituents. Pharmacological activities include antimicrobial, antiviral, antiparasitic, antioxidant, antifungal, anticarcinogenic, anti-inflammatory and cytotoxic effects. The review covers its phytochemistry, pharmacology, pharmacokinetics and toxicity.}
}

@article{tan2015ginkgo,
  author   = {Tan, M.S., Yu, J.T., Tan, C.C., Wang, H.F. et al.},
  title    = {Efficacy and adverse effects of Ginkgo biloba for cognitive impairment and dementia: a systematic review and meta-analysis},
  journal  = {Journal of Alzheimer's Disease},
  year     = {2015},
  volume   = {43},
  number   = {2},
  pages    = {589-603},
  doi      = {10.3233/JAD-140837},
  note     = {REF-0829},
  study_type = {systematic-review},
  abstract = {A systematic review and meta-analysis of nine randomized controlled trials (2561 patients, 22-26 weeks) of standardised Ginkgo biloba extract EGb761 for cognitive impairment and dementia. EGb761 at 240 mg/day was able to stabilise or slow decline in cognition, activities of daily living, behaviour and global clinical impression, especially in patients with neuropsychiatric symptoms, with no important safety concerns. (Note: the large negative GEM prevention RCT, DeKosky 2008, is already in the database.)}
}

@article{skowronska2025hamamelis,
  author   = {Skowrońska, W., Pawłowska, K.A., Obrębski, M., Piwowarski, J.P. et al.},
  title    = {Chemical composition, skin microbiota metabolism, antimicrobial potential and anti-inflammatory properties of witch hazel bark (Hamamelis virginiana L.)},
  journal  = {Journal of Ethnopharmacology},
  year     = {2025},
  volume   = {353},
  number   = {Pt B},
  pages    = {120433},
  doi      = {10.1016/j.jep.2025.120433},
  note     = {REF-0830},
  study_type = {preclinical},
  abstract = {Witch hazel (Hamamelis virginiana) bark, valued in traditional medicine for its astringent tannins, was studied for composition and activity. The aqueous extract and its key component hamamelitannin exhibited the most pronounced anti-inflammatory activity (reducing ROS and cytokine release in human neutrophils and keratinocytes), supported keratinocyte migration in a wound-healing assay and inhibited Staphylococcus aureus growth, supporting its use for skin inflammation and minor wounds.}
}

@article{piazza2022hamamelis,
  author   = {Piazza, S., Martinelli, G., Vrhovsek, U., Masuero, D. et al.},
  title    = {Anti-Inflammatory and Anti-Acne Effects of Hamamelis virginiana Bark in Human Keratinocytes},
  journal  = {Antioxidants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {6},
  pages    = {1119},
  doi      = {10.3390/antiox11061119},
  note     = {REF-0831},
  study_type = {preclinical},
  abstract = {A glycolic extract from Hamamelis virginiana bark (rich in hamamelitannin and proanthocyanidins) was evaluated against Cutibacterium acnes- and TNF-alpha-induced inflammation in human keratinocytes. The extract inhibited IL-6 and IL-8 release by partially impairing NF-kB activation and acting through antioxidant mechanisms, supporting the use of witch hazel for inflammatory skin conditions such as acne.}
}

@article{janarthanam2025hamamelitannin,
  author   = {Janarthanam, V.A., Rajan, P.S.S., Panda, S.P., Panigrahy, U.P. et al.},
  title    = {Hamamelitannin from Hamamelis virginiana Attenuates Ethanol-Induced Oxidative and Inflammatory Responses in Danio rerio Larvae},
  journal  = {Molecular Biotechnology},
  year     = {2025},
  volume   = {68},
  number   = {5},
  pages    = {2369-2385},
  doi      = {10.1007/s12033-025-01502-9},
  note     = {REF-0832},
  study_type = {preclinical},
  abstract = {Hamamelitannin, a gallotannin from Hamamelis virginiana bark, was evaluated against ethanol-induced inflammation in a zebrafish larvae model of alcoholic liver disorder. Co-treatment normalised antioxidant enzymes (SOD, CAT, GPx), reduced reactive oxygen species, lipid peroxidation and macrophage infiltration, and downregulated inflammatory mediators (iNOS, TNF-alpha, COX-2, IL-1beta), indicating hepatoprotective and anti-inflammatory properties of the witch hazel tannin.}
}

@article{sierocinski2021hedera,
  author   = {Sierocinski, E., Holzinger, F. and Chenot, J.F.},
  title    = {Ivy leaf (Hedera helix) for acute upper respiratory tract infections: an updated systematic review},
  journal  = {European Journal of Clinical Pharmacology},
  year     = {2021},
  volume   = {77},
  number   = {8},
  pages    = {1113-1122},
  doi      = {10.1007/s00228-021-03090-4},
  note     = {REF-0833},
  study_type = {systematic-review},
  abstract = {An updated systematic review of ivy leaf (Hedera helix) extract for acute upper respiratory tract infections and bronchitis, including six RCTs, one controlled clinical trial and four observational studies. All studies concluded ivy leaf extract is an effective and safe option for cough due to URTIs and bronchitis; three RCTs reported more rapid reduction in cough severity/frequency, though effects were minimal and of uncertain clinical importance, with no serious adverse effects reported.}
}

@article{baharara2021hedera,
  author   = {Baharara, H., Moghadam, A.T., Sahebkar, A., Emami, S.A. et al.},
  title    = {The Effects of Ivy (Hedera helix) on Respiratory Problems and Cough in Humans: A Review},
  journal  = {Advances in Experimental Medicine and Biology},
  year     = {2021},
  volume   = {1328},
  pages    = {361-376},
  doi      = {10.1007/978-3-030-73234-9_23},
  note     = {REF-0834},
  study_type = {traditional},
  abstract = {Hedera helix (ivy) leaf contains active saponins (alpha-hederin, hederacosides B-D) and has been used for cough and respiratory problems. Approved by the German Commission E, it possesses antispasmodic, spasmolytic, antimicrobial, anti-inflammatory, anthelmintic, antioxidative and antitumor activities. This review focuses on the respiratory (expectorant, antitussive) effects of tablet and liquid ivy-leaf formulations.}
}

@article{song2015hedera,
  author   = {Song, K.J., Shin, Y.J., Lee, K.R., Lee, E.J. et al.},
  title    = {Expectorant and antitussive effect of Hedera helix and Rhizoma coptidis extracts mixture},
  journal  = {Yonsei Medical Journal},
  year     = {2015},
  volume   = {56},
  number   = {3},
  pages    = {819-824},
  doi      = {10.3349/ymj.2015.56.3.819},
  note     = {REF-0835},
  study_type = {preclinical},
  abstract = {The expectorant (phenol-red tracheal secretion) and antitussive (citric-acid-induced cough) effects of Hedera helix and Rhizoma coptidis extracts were assessed in mice and guinea pigs. Hedera helix extract significantly increased tracheal secretion and inhibited cough, and a 3:1 mixture with Rhizoma coptidis showed optimal, dose-dependent expectorant and antitussive effects, supporting the traditional use of ivy leaf for respiratory complaints.}
}

@article{liu2024seabuckthorn,
  author   = {Liu, L., Wen, T., Xiao, Y., Chen, H. et al.},
  title    = {Sea buckthorn extract mitigates chronic obstructive pulmonary disease by suppression of ferroptosis via scavenging ROS and blocking p53/MAPK pathways},
  journal  = {Journal of Ethnopharmacology},
  year     = {2024},
  volume   = {336},
  pages    = {118726},
  doi      = {10.1016/j.jep.2024.118726},
  note     = {REF-0836},
  study_type = {preclinical},
  abstract = {Sea buckthorn (Hippophae rhamnoides), a traditional Tibetan medicinal herb, exhibits protective effects against respiratory diseases. In bronchial epithelial cells and an LPS/elastase-induced COPD mouse model, sea buckthorn extract suppressed ferroptosis by directly scavenging reactive oxygen species and blocking the p53 and MAPK pathways, reducing lipid peroxides, cytokines and chemokines, supporting its clinical application in COPD.}
}

@article{wen2018seabuckthorn,
  author   = {Wen, P., Zhao, P., Qin, G., Tang, S. et al.},
  title    = {Genotoxicity and teratogenicity of seabuckthorn (Hippophae rhamnoides L.) berry oil},
  journal  = {Drug and Chemical Toxicology},
  year     = {2018},
  volume   = {43},
  number   = {4},
  pages    = {391-397},
  doi      = {10.1080/01480545.2018.1497047},
  note     = {REF-0837},
  study_type = {preclinical},
  abstract = {Seabuckthorn (Hippophae rhamnoides) has been used for centuries as a medicine and nutritional supplement, but safety data are limited. In three genotoxicity studies and a teratogenicity study, seabuckthorn berry oil showed no mutagenic activity (Ames test), no effect on sperm morphology or micronucleus rate, and no maternal or embryo toxicity, supporting the safe use of seabuckthorn berry oil for dietary consumption.}
}

@article{gong2020isorhamnetin,
  author   = {Gong, G., Guan, Y.Y., Zhang, Z.L., Rahman, K. et al.},
  title    = {Isorhamnetin: A review of pharmacological effects},
  journal  = {Biomedicine & Pharmacotherapy},
  year     = {2020},
  volume   = {128},
  pages    = {110301},
  doi      = {10.1016/j.biopha.2020.110301},
  note     = {REF-0838},
  study_type = {traditional},
  abstract = {Isorhamnetin is one of the most important active flavonoid ingredients in the fruits of Hippophae rhamnoides (sea buckthorn). This review summarises its pharmacological effects — cardiovascular and cerebrovascular protection, anti-tumor, anti-inflammatory, anti-oxidation, organ protection and prevention of obesity — and the underlying signaling mechanisms (PI3K/AKT, NF-kB, MAPK), underlining the medicinal value of this sea buckthorn constituent.}
}

@article{lee2024hops,
  author   = {Lee, H., Chung, S.H., Kwon, D.J., Nam, M.J. et al.},
  title    = {Sleep-enhancing effect of Hongcheon-hop (Humulus lupulus L.) extract containing xanthohumol and humulone through GABA-A receptor},
  journal  = {Journal of Ethnopharmacology},
  year     = {2024},
  volume   = {338},
  number   = {Pt 2},
  pages    = {119019},
  doi      = {10.1016/j.jep.2024.119019},
  note     = {REF-0839},
  study_type = {preclinical},
  abstract = {The bitter resins in hops (Humulus lupulus) modulate GABA receptors, producing sedative effects and enhancing sleep. A hop extract containing xanthohumol and humulone dose-dependently increased sleep duration in a pentobarbital model, enhanced non-rapid-eye-movement (deep delta-wave) sleep, and acted by binding the GABA site on the GABA-A receptor while increasing brain GABA and 5-HT receptor levels, supporting hops as a natural sleep aid.}
}

@article{kenda2021herbal,
  author   = {Kenda, M., Glavač, N.K., Nagy, M. and Sollner Dolenc, M.},
  title    = {Herbal Products Used in Menopause and for Gynecological Disorders},
  journal  = {Molecules},
  year     = {2021},
  volume   = {26},
  number   = {24},
  pages    = {7421},
  doi      = {10.3390/molecules26247421},
  note     = {REF-0840},
  study_type = {traditional},
  abstract = {A review of plants and derived products commonly used for menopausal symptoms and gynecological disorders, focusing on clinical data and safety. Black cohosh and red clover consistently reduced menopausal symptoms in clinical studies, while currently available data do not fully support the use of hops (Humulus lupulus), fenugreek, valerian and soybean for this indication, providing a balanced view of hops' estrogenic/menopausal use.}
}

@article{dietz2016botanicals,
  author   = {Dietz, B.M., Hajirahimkhan, A., Dunlap, T.L. and Bolton, J.L.},
  title    = {Botanicals and Their Bioactive Phytochemicals for Women's Health},
  journal  = {Pharmacological Reviews},
  year     = {2016},
  volume   = {68},
  number   = {4},
  pages    = {1026-1073},
  doi      = {10.1124/pr.115.010843},
  note     = {REF-0841},
  study_type = {traditional},
  abstract = {A comprehensive review of botanical dietary supplements for women's health. Among plant extracts with estrogenic activity proposed for menopausal symptom relief is Humulus lupulus (hops), alongside soy, red clover, kudzu and others; some have protective effects against osteoporosis and potential breast-cancer-preventive effects, while the review stresses that botanicals have not been rigorously tested for toxicity or drug interactions.}
}

@article{ng2017hypericum,
  author   = {Ng, Q.X., Venkatanarayanan, N. and Ho, C.Y.X.},
  title    = {Clinical use of Hypericum perforatum (St John's wort) in depression: A meta-analysis},
  journal  = {Journal of Affective Disorders},
  year     = {2017},
  volume   = {210},
  pages    = {211-221},
  doi      = {10.1016/j.jad.2016.12.048},
  note     = {REF-0842},
  study_type = {systematic-review},
  abstract = {A meta-analysis of 27 clinical trials (3808 patients) comparing St John's wort (Hypericum perforatum) with SSRIs in depression. St John's wort demonstrated comparable response and remission rates and significantly lower discontinuation/dropout than standard SSRIs, supporting comparable efficacy and safety for mild-to-moderate depression; evidence on long-term efficacy and use in severe depression remains limited.}
}

@article{kholghi2022hypericum,
  author   = {Kholghi, G., Arjmandi-Rad, S., Zarrindast, M.R. and Vaseghi, S.},
  title    = {St. John's wort (Hypericum perforatum) and depression: what happens to the neurotransmitter systems?},
  journal  = {Naunyn-Schmiedeberg's Archives of Pharmacology},
  year     = {2022},
  volume   = {395},
  number   = {6},
  pages    = {629-642},
  doi      = {10.1007/s00210-022-02229-z},
  note     = {REF-0843},
  study_type = {traditional},
  abstract = {St. John's wort (Hypericum perforatum) contains bioactive molecules including hyperforin and hypericin and has therapeutic effects on depression and other mood/psychiatric disorders. This review discusses the role of St John's wort in modulating depression with respect to neurotransmitter systems in the brain, concluding that it induces complex, sometimes inconsistent effects on neurotransmitter levels, with glutamate and acetylcholine highlighted for future study.}
}

@article{fughberman2000herbdrug,
  author   = {Fugh-Berman, A.},
  title    = {Herb-drug interactions},
  journal  = {Lancet},
  year     = {2000},
  volume   = {355},
  number   = {9198},
  pages    = {134-138},
  doi      = {10.1016/S0140-6736(99)06457-0},
  note     = {REF-0844},
  study_type = {traditional},
  abstract = {A review of herb-drug interactions. St John's wort (Hypericum perforatum) is prominently implicated: mild serotonin syndrome when combined with serotonin-reuptake inhibitors, and decreased bioavailability of digoxin, theophylline, cyclosporin and phenprocoumon. The review emphasises that health-care practitioners should caution patients against mixing herbs and pharmaceutical drugs — an important safety consideration for St John's wort use.}
}

@article{atazhanova2024hyssopus,
  author   = {Atazhanova, G., Ishmuratova, M., Levaya, Y., Smagulov, M. and Lakomkina, Y.},
  title    = {The Genus Hyssopus: Traditional Use, Phytochemicals and Pharmacological Properties},
  journal  = {Plants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {12},
  pages    = {1683},
  doi      = {10.3390/plants13121683},
  note     = {REF-0845},
  study_type = {traditional},
  abstract = {The genus Hyssopus includes seven plant species rich in various groups of biologically active substances with a wide spectrum of pharmacological action. This review provides a comprehensive overview of the botanical research, extraction methods, chemical composition (mono- and sesquiterpenoids, flavonoids, alkaloids) and pharmacological activity of Hyssopus plants, including Hyssopus officinalis, noting that composition depends on growth location, weather, chemotype and extraction method.}
}

@article{sharifirad2022hyssopus,
  author   = {Sharifi-Rad, J., Quispe, C., Kumar, M., Akram, M. et al.},
  title    = {Hyssopus Essential Oil: An Update of Its Phytochemistry, Biological Activities, and Safety Profile},
  journal  = {Oxidative Medicine and Cellular Longevity},
  year     = {2022},
  volume   = {2022},
  pages    = {8442734},
  doi      = {10.1155/2022/8442734},
  note     = {REF-0846},
  study_type = {traditional},
  abstract = {Hyssopus species are used as herbal remedies for cold, cough, loss of appetite, fungal infection and spasmodic conditions. The important active constituents of the essential oils are pinene, pinocamphone, isopinocamphone and other terpenoids, alongside flavonoids and phenolic acids. Extracts show antiviral and antifungal activities in vitro and plasma-membrane-relaxant, cytotoxic and sedative effects in vivo; the plant is considered relatively safe at culinary levels, though more safety studies are needed.}
}

@article{gharakhanibeni2022hyssop,
  author   = {Gharakhani-Beni, A., Ghasemi Pirbalouti, A., Javanmard, H., Soleymani, A. and Golparvar, A.},
  title    = {Chemical compositions, yield and antioxidant activity of the essential oil of hyssop (Hyssopus officinalis L.) under intercropping with fenugreek},
  journal  = {Natural Product Research},
  year     = {2022},
  volume   = {37},
  number   = {4},
  pages    = {675-680},
  doi      = {10.1080/14786419.2022.2078971},
  note     = {REF-0847},
  study_type = {preclinical},
  abstract = {The effect of intercropping hyssop (Hyssopus officinalis) with fenugreek on the hyssop essential oil was studied. Sole cropping gave the highest essential-oil yield and the highest contents of major constituents (cis- and trans-pinocamphone and beta-pinene), while intercropping with fenugreek increased the antioxidant activity of the hyssop essential oil, illustrating how cultivation conditions modulate hyssop's volatile composition and antioxidant capacity.}
}

@article{camilleri2024chaga,
  author   = {Camilleri, E., Blundell, R., Baral, B., Karpinski, T.M. et al.},
  title    = {A brief overview of the medicinal and nutraceutical importance of Inonotus obliquus (chaga) mushrooms},
  journal  = {Heliyon},
  year     = {2024},
  volume   = {10},
  number   = {15},
  pages    = {e35638},
  doi      = {10.1016/j.heliyon.2024.e35638},
  note     = {REF-0848},
  study_type = {traditional},
  abstract = {This review explores chaga mushrooms (Inonotus obliquus), focusing on their phytochemical composition, health-promoting attributes and mechanisms of action. It highlights chaga's anticancer, antioxidant, anti-diabetic, anti-inflammatory, antimicrobial and immunomodulating properties, underscoring its importance in the medicinal sector and its pharmacological potential.}
}

@article{lu2021chagapoly,
  author   = {Lu, Y., Jia, Y., Xue, Z., Li, N. et al.},
  title    = {Recent Developments in Inonotus obliquus (Chaga mushroom) Polysaccharides: Isolation, Structural Characteristics, Biological Activities and Application},
  journal  = {Polymers (Basel)},
  year     = {2021},
  volume   = {13},
  number   = {9},
  pages    = {1441},
  doi      = {10.3390/polym13091441},
  note     = {REF-0849},
  study_type = {traditional},
  abstract = {Inonotus obliquus (chaga) polysaccharide (IOPS) is one of the major bioactive components of chaga, possessing antitumor, antioxidant, anti-virus, hypoglycemic and hypolipidemic activities. This review summarises advances in the extraction, purification, structural characteristics and biological activities of IOPS and its possible mechanisms, suggesting IOPS as a potential candidate for the treatment of cancers and type 2 diabetes.}
}

@article{kobus2024chaga,
  author   = {Kobus, Z., Krzywicka, M., Blicharz-Kania, A., Bosacka, A. et al.},
  title    = {Impact of Incorporating Dried Chaga Mushroom (Inonotus obliquus) into Gluten-Free Bread on Its Antioxidant and Sensory Characteristics},
  journal  = {Molecules},
  year     = {2024},
  volume   = {29},
  number   = {16},
  pages    = {3801},
  doi      = {10.3390/molecules29163801},
  note     = {REF-0850},
  study_type = {preclinical},
  abstract = {Gluten-free bread enriched with chaga (Inonotus obliquus) mushroom flour showed increased polyphenol and flavonoid content and enhanced antioxidant activity (DPPH, FRAP), with the highest levels at 20% chaga, demonstrating the antioxidant value of chaga; however sensory acceptability limited practical addition to about 10%.}
}

@article{pepeljnjak2005juniper,
  author   = {Pepeljnjak, S., Kosalec, I., Kalodera, Z. and Blazević, N.},
  title    = {Antimicrobial activity of juniper berry essential oil (Juniperus communis L., Cupressaceae)},
  journal  = {Acta Pharmaceutica},
  year     = {2005},
  volume   = {55},
  number   = {4},
  pages    = {417-422},
  url      = {https://pubmed.ncbi.nlm.nih.gov/16375831/},
  note     = {REF-0851},
  study_type = {preclinical},
  abstract = {Juniper berry essential oil (main compounds alpha-pinene, beta-pinene, sabinene, limonene) was evaluated against sixteen bacterial species, seven yeast-like fungi, three yeasts and four dermatophytes. The oil showed similar bactericidal activity against Gram-positive and Gram-negative bacteria and strong fungicidal activity against yeasts and dermatophytes, with the strongest activity against Candida spp. and dermatophytes, supporting the antimicrobial use of juniper.}
}

@article{peruc2020juniper,
  author   = {Peruč, D., Tićac, B., Broznić, D., Maglica, Ž. et al.},
  title    = {Juniperus communis essential oil limits the biofilm formation of Mycobacterium avium and Mycobacterium intracellulare on polystyrene in a temperature-dependent manner},
  journal  = {International Journal of Environmental Health Research},
  year     = {2020},
  volume   = {32},
  number   = {1},
  pages    = {141-154},
  doi      = {10.1080/09603123.2020.1741519},
  note     = {REF-0852},
  study_type = {preclinical},
  abstract = {Juniperus communis essential oil was investigated against nontuberculous mycobacteria and their biofilm formation. The combination of the essential oil and increasing temperature synergistically reduced biofilm formation on a polystyrene surface, and a significant antibiofilm effect was found at subinhibitory concentrations, suggesting a potential role for juniper essential oil as an alternative disinfectant.}
}

@article{markovic2024juniper,
  author   = {Marković, T., Popović, S., Matić, S., Mitrović, M. et al.},
  title    = {Insights into Molecular Mechanisms of Anticancer Activity of Juniperus communis Essential Oil in HeLa and HCT 116 Cells},
  journal  = {Plants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {17},
  pages    = {2351},
  doi      = {10.3390/plants13172351},
  note     = {REF-0853},
  study_type = {preclinical},
  abstract = {Juniperus communis berry essential oil was studied for antitumor potential in cervical cancer HeLa and colorectal HCT 116 cells. It produced concentration-dependent reductions in cell viability and long-term cytotoxic effects, induced the intrinsic apoptosis pathway (cleaved caspase-3, increased Bax/Bcl-2, cytochrome C release) and arrested HeLa cells in the S phase, highlighting juniper berry essential oil as a natural agent with anticancer potential.}
}

@article{ullah2022lactuca,
  author   = {Ullah, M.I., Anwar, R., Kamran, S., Gul, B. et al.},
  title    = {Evaluation of the Anxiolytic and Anti-Epileptogenic Potential of Lactuca serriola Seed Using Pentylenetetrazol-Induced Kindling in Mice and Metabolic Profiling of Its Bioactive Extract},
  journal  = {Antioxidants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {11},
  pages    = {2232},
  doi      = {10.3390/antiox11112232},
  note     = {REF-0854},
  study_type = {preclinical},
  abstract = {Seed extracts of Lactuca serriola (prickly lettuce, a wild-lettuce congener) showed anxiolytic potential (increased open-arm time in the elevated plus maze, reduced head-dipping), sedative effects (reduced sleep latency and prolonged barbiturate sleep) and anti-epileptogenic activity (reduced seizure score in PTZ-kindling), with antioxidant effects in brain tissue, supporting the ethnopharmacological sedative use of wild lettuce.}
}

@article{lee2024lactuca,
  author   = {Lee, M., Park, J., Cho, W., Jun, Y. et al.},
  title    = {Lactuca L. Extract Enhances Sleep Duration Through Upregulation of Adenosine A1 Receptor and GABA-A Receptor Subunits in Pentobarbital-Injected Mice},
  journal  = {Journal of Medicinal Food},
  year     = {2024},
  volume   = {27},
  number   = {7},
  pages    = {661-668},
  doi      = {10.1089/jmf.2023.K.0250},
  note     = {REF-0855},
  study_type = {preclinical},
  abstract = {A Lactuca (lettuce) extract was investigated in pentobarbital-induced sleep in mice. The extract significantly reduced sleep latency and increased sleep duration, and increased the expression of the adenosine A1 receptor and several GABA-A receptor subunits in the brain, indicating it could be used to develop natural products that improve sleep quality and duration — a mechanism relevant to wild lettuce's traditional sedative use.}
}

@article{paulsen2015lettuce,
  author   = {Paulsen, E. and Andersen, K.E.},
  title    = {Lettuce contact allergy},
  journal  = {Contact Dermatitis},
  year     = {2015},
  volume   = {74},
  number   = {2},
  pages    = {67-75},
  doi      = {10.1111/cod.12458},
  note     = {REF-0856},
  study_type = {traditional},
  abstract = {Lettuce (Lactuca) and its varieties are a well-known, rarely reported cause of contact allergy, mostly occupational, with sesquiterpene lactones implicated. The review presents data on lettuce contact allergy and recommends patch testing with freshly cut lettuce supplemented with Compositae mix — a relevant safety/contraindication consideration for Compositae-sensitised individuals using wild lettuce preparations.}
}

@article{tan2023essentialoils,
  author   = {Tan, L., Liao, F.F., Long, L.Z., Ma, X.C. et al.},
  title    = {Essential oils for treating anxiety: a systematic review of randomized controlled trials and network meta-analysis},
  journal  = {Frontiers in Public Health},
  year     = {2023},
  volume   = {11},
  pages    = {1144404},
  doi      = {10.3389/fpubh.2023.1144404},
  note     = {REF-0857},
  study_type = {systematic-review},
  abstract = {A systematic review and network meta-analysis of 44 randomized controlled trials (3419 patients, 10 essential oils) for anxiety. Essential oils significantly reduced State and Trait Anxiety Inventory scores and lowered systolic blood pressure and heart rate; in the network analysis lavender (Lavandula angustifolia) was among the most effective and most recommended essential oils for treating anxiety.}
}

@article{doslucena2021lavender,
  author   = {Dos Reis Lucena, L., Dos Santos-Junior, J.G., Tufik, S. and Hachul, H.},
  title    = {Lavender essential oil on postmenopausal women with insomnia: Double-blind randomized trial},
  journal  = {Complementary Therapies in Medicine},
  year     = {2021},
  volume   = {59},
  pages    = {102726},
  doi      = {10.1016/j.ctim.2021.102726},
  note     = {REF-0858},
  study_type = {rct},
  abstract = {A double-blind randomized controlled trial of Lavandula angustifolia essential oil inhalation versus placebo for 29 days in 35 postmenopausal women with insomnia. Although no significant between-group difference was seen in the primary sleep-quality outcome, the lavender group showed a significant decrease in sleep-onset latency and depression levels, reduced hot flashes and increased sleep efficiency on polysomnography compared to baseline.}
}

@article{moss2003lavender,
  author   = {Moss, M., Cook, J., Wesnes, K. and Duckett, P.},
  title    = {Aromas of rosemary and lavender essential oils differentially affect cognition and mood in healthy adults},
  journal  = {International Journal of Neuroscience},
  year     = {2003},
  volume   = {113},
  number   = {1},
  pages    = {15-38},
  doi      = {10.1080/00207450390161903},
  note     = {REF-0859},
  study_type = {rct},
  abstract = {A randomized controlled trial assessed the olfactory impact of lavender (Lavandula angustifolia) and rosemary essential oils on cognition and mood in 144 healthy volunteers. Lavender produced a decrement in working-memory performance and slower reaction times compared with controls, but the lavender group was significantly more content than controls, indicating lavender aroma produces objective cognitive and subjective mood effects consistent with a calming/sedative action.}
}

@article{fierascu2019leonurus,
  author   = {Fierascu, R.C., Fierascu, I., Ortan, A., Fierascu, I.C. and others},
  title    = {Leonurus cardiaca L. as a Source of Bioactive Compounds: An Update of the European Medicines Agency Assessment Report (2010)},
  journal  = {BioMed Research International},
  year     = {2019},
  volume   = {2019},
  pages    = {4303215},
  doi      = {10.1155/2019/4303215},
  note     = {REF-0860},
  study_type = {traditional},
  abstract = {Leonurus cardiaca (motherwort) is a perennial herb native to Asia and southeastern Europe, historically used as a cardiotonic and for treating gynaecological afflictions such as amenorrhea, dysmenorrhea, menopausal anxiety and postpartum depression. This review updates the European Medicines Agency assessment report on motherwort herb, presenting progress made in 2010-2018 on the potential applications and scientific evidence supporting its traditional use.}
}

@article{wojtyniak2013leonurus,
  author   = {Wojtyniak, K., Szymanski, M. and Matlawska, I.},
  title    = {Leonurus cardiaca L. (motherwort): a review of its phytochemistry and pharmacology},
  journal  = {Phytotherapy Research},
  year     = {2013},
  volume   = {27},
  number   = {8},
  pages    = {1115-1120},
  doi      = {10.1002/ptr.4850},
  note     = {REF-0861},
  study_type = {traditional},
  abstract = {Leonurus cardiaca is a perennial plant indigenous to central Europe and Scandinavia, used in traditional medicine for cardiac and nervous complaints. This review summarises its phytochemistry (iridoids, diterpenoids, flavonoids, phenylpropanoids, alkaloids such as stachydrine and leonurine) and pharmacology, including cardioprotective, antioxidant, hypotensive and sedative activities.}
}

@article{kuchta2013stachydrine,
  author   = {Kuchta, K., Volk, R.B. and Rauwald, H.W.},
  title    = {Stachydrine in Leonurus cardiaca, Leonurus japonicus, Leonotis leonurus: detection and quantification by instrumental HPTLC and 1H-qNMR analyses},
  journal  = {Pharmazie},
  year     = {2013},
  volume   = {68},
  number   = {7},
  pages    = {534-540},
  url      = {https://pubmed.ncbi.nlm.nih.gov/23923634/},
  note     = {REF-0862},
  study_type = {preclinical},
  abstract = {Stachydrine, a pyrrolidinium alkaloid regarded as an essential active principle of the aerial parts of Leonurus species, was detected and quantified in Leonurus cardiaca, Leonurus japonicus and Leonotis leonurus using instrumental HPTLC and 1H-qNMR, providing analytical methods for standardising motherwort herbal preparations.}
}

@article{kuchta2012leonurine,
  author   = {Kuchta, K., Volk, R.B. and Rauwald, H.W.},
  title    = {Leonurus japonicus, Leonurus cardiaca, Leonotis leonurus: a novel HPLC study on the occurrence and content of the pharmacologically active guanidino derivative leonurine},
  journal  = {Pharmazie},
  year     = {2012},
  volume   = {67},
  number   = {12},
  pages    = {973-979},
  url      = {https://pubmed.ncbi.nlm.nih.gov/23346757/},
  note     = {REF-0863},
  study_type = {preclinical},
  abstract = {Leonurine is a pharmacologically active guanidine alkaloid exerting cardiovascular, hypotensive, uterotonic and neuroprotective effects. A novel HPLC method quantified leonurine in Leonurus cardiaca, Leonurus japonicus and Leonotis leonurus, informing the cardioactive use of motherwort.}
}

@article{koshovyi2021motherwort,
  author   = {Koshovyi, O., Raal, A., Kireyev, I., Tryshchuk, N. and others},
  title    = {Phytochemical and Psychotropic Research of Motherwort (Leonurus cardiaca L.) Modified Dry Extracts},
  journal  = {Plants (Basel)},
  year     = {2021},
  volume   = {10},
  number   = {2},
  pages    = {230},
  doi      = {10.3390/plants10020230},
  note     = {REF-0864},
  study_type = {preclinical},
  abstract = {Modified dry extracts of motherwort (Leonurus cardiaca) were studied for chemical composition and psychotropic activity. The extracts, enriched in phenolics and amino acids, showed sedative and anxiolytic activity in animal models, supporting the development of motherwort-based medicines with psychotropic (calming) activity.}
}

@article{angeloni2021leonurus,
  author   = {Angeloni, S., Spinozzi, E., Maggi, F., Sagratini, G. and others},
  title    = {Phytochemical Profile and Biological Activities of Crude and Purified Leonurus cardiaca Extracts},
  journal  = {Plants (Basel)},
  year     = {2021},
  volume   = {10},
  number   = {2},
  pages    = {195},
  doi      = {10.3390/plants10020195},
  note     = {REF-0865},
  study_type = {preclinical},
  abstract = {Leonurus cardiaca has been used in traditional medicine since antiquity for cardiac and gynecological disorders. Crude and purified extracts were profiled for phenolic and iridoid content and evaluated for antioxidant and enzyme-inhibitory (anti-inflammatory-relevant) activities, with purified fractions showing enhanced biological activity.}
}

@article{sadowska2019leonurus,
  author   = {Sadowska, B., Wieckowska-Szakiel, M., Paszkiewicz, M. and Rozalska, B.},
  title    = {Molecular Mechanisms of Leonurus cardiaca L. Extract Activity in Prevention of Staphylococcal Endocarditis - Study on in Vitro and ex Vivo Models},
  journal  = {Molecules},
  year     = {2019},
  volume   = {24},
  number   = {18},
  pages    = {3318},
  doi      = {10.3390/molecules24183318},
  note     = {REF-0866},
  study_type = {preclinical},
  abstract = {Leonurus cardiaca extract was studied for its potential to prevent staphylococcal infective endocarditis using in vitro and ex vivo models. The extract reduced Staphylococcus aureus adhesion, biofilm formation and virulence on heart-valve models, supporting a cardioprotective/anti-infective use of motherwort.}
}

@article{kuchta2025leonurus,
  author   = {Kuchta, K., Hladikova, J., Thomsen, M., Nguyen, A.D. and others},
  title    = {Phenolic and Iridoid Glycosides from Leonurus cardiaca L. and Their Effects on the alpha, delta, and gamma Subtypes of the PPAR System},
  journal  = {Molecules},
  year     = {2025},
  volume   = {30},
  number   = {2},
  pages    = {419},
  doi      = {10.3390/molecules30020419},
  note     = {REF-0867},
  study_type = {preclinical},
  abstract = {Leonurus cardiaca is known in Europe for its cardioactivity, also in relation to metabolic-syndrome risk factors. Phenolic and iridoid glycosides were isolated, including a novel phenylethanoid (cardiaphenyloside A), and tested on PPAR alpha, delta and gamma subtypes, identifying constituents that modulate the PPAR system relevant to anti-inflammatory and metabolic activity.}
}

@article{pereira2019leonurus,
  author   = {Pereira, O.R., Catarino, M.D., Afonso, A.F., Silva, A.M.S. and Cardoso, S.M.},
  title    = {Hepatoprotection of Leonurus cardiaca L., Leonurus japonicus Houtt. and Leonurus sibiricus L.},
  journal  = {Antioxidants (Basel)},
  year     = {2019},
  volume   = {8},
  number   = {8},
  pages    = {267},
  doi      = {10.3390/antiox8080267},
  note     = {REF-0868},
  study_type = {preclinical},
  abstract = {The phenolic composition of hydroethanolic extracts of Leonurus cardiaca, Leonurus japonicus and Leonurus sibiricus was determined and their hepatoprotective effects investigated in vitro. The extracts were rich in phenylethanoids and flavonoids and protected liver cells against oxidative damage, demonstrating antioxidant and hepatoprotective activity.}
}

@article{kuchta2014qnmr,
  author   = {Kuchta, K., Ortwein, J. and Rauwald, H.W.},
  title    = {1H-qNMR for direct quantification of stachydrine in Leonurus japonicus and L. cardiaca},
  journal  = {Fitoterapia},
  year     = {2014},
  volume   = {96},
  pages    = {8-17},
  doi      = {10.1016/j.fitote.2014.03.023},
  note     = {REF-0869},
  study_type = {preclinical},
  abstract = {1H-qNMR spectroscopy was applied to directly quantify the pharmacologically active alkaloid stachydrine in aerial parts of Leonurus japonicus and Leonurus cardiaca, providing a rapid quality-control method for motherwort raw material and preparations.}
}

@article{veldman2023respiratory,
  author   = {Veldman, J., Bordewijk, E., Lloyd, A.R., Vlieger, A.M. and others},
  title    = {Mechanistic Evidence of Andrographis paniculata, Pelargonium sidoides, Echinacea Species and a Combination of Hedera helix, Primula veris/elatior and Thymus vulgaris/zygis in the Treatment of Acute, Uncomplicated Respiratory Tract Infections: A Systematic Literature Review and Expert Interviews},
  journal  = {Pharmaceuticals (Basel)},
  year     = {2023},
  volume   = {16},
  number   = {9},
  pages    = {1206},
  doi      = {10.3390/ph16091206},
  note     = {REF-0870},
  study_type = {systematic-review},
  abstract = {This systematic literature review with expert interviews assessed mechanistic evidence for herbal treatments of acute uncomplicated respiratory tract infections, including the fixed combination of ivy (Hedera helix), primrose (Primula veris/elatior) and thyme. The combination provides secretolytic and spasmolytic effects from ivy with antibacterial effects from thyme, supporting expectorant use in upper respiratory tract infections.}
}

@article{baczek2017primula,
  author   = {Baczek, K.B., Kosakowska, O., Przybyl, J.L., Pioro-Jabrucka, E. and others},
  title    = {Phenolics in Primula veris L. and Primula elatior (L.) Hill Raw Materials},
  journal  = {International Journal of Analytical Chemistry},
  year     = {2017},
  volume   = {2017},
  pages    = {2871579},
  doi      = {10.1155/2017/2871579},
  note     = {REF-0871},
  study_type = {preclinical},
  abstract = {Primula veris and Primula elatior are medicinal plants used for herbal teas and preparations with antioxidant and expectorant activity. Flowers and roots of both species were analysed for phenolic content, with roots rich in saponins and the raw materials showing notable antioxidant activity, supporting their use in respiratory preparations.}
}

@article{prokofiev2023primula,
  author   = {Prokofiev, A.B., Latypova, G.M., Bondarenko, T.A., Romanenko, E.B. and others},
  title    = {Solid herbal extract of Primula veris L. improves morphofunctional condition of rats' myocardium in chronic alcohol intoxication},
  journal  = {Journal of Traditional and Complementary Medicine},
  year     = {2023},
  volume   = {13},
  number   = {3},
  pages    = {306-314},
  doi      = {10.1016/j.jtcme.2023.02.006},
  note     = {REF-0872},
  study_type = {preclinical},
  abstract = {A solid herbal extract of Primula veris was investigated in a rat model of chronic alcohol intoxication-induced heart damage. The extract improved the morphofunctional condition of the myocardium and reduced markers of oxidative stress, demonstrating cardioprotective and antioxidant effects of cowslip.}
}

@article{tarapatskyy2021primula,
  author   = {Tarapatskyy, M., Gumienna, A., Sowa, P., Kapusta, I. and Puchalski, C.},
  title    = {Bioactive Phenolic Compounds from Primula veris L.: Influence of the Extraction Conditions and Purification},
  journal  = {Molecules},
  year     = {2021},
  volume   = {26},
  number   = {4},
  pages    = {997},
  doi      = {10.3390/molecules26040997},
  note     = {REF-0873},
  study_type = {preclinical},
  abstract = {This study examined whether cowslip (Primula veris) is a rich source of bioactive substances obtainable by efficient extraction. Extraction conditions were optimised to recover phenolic compounds with antioxidant potential, identifying Primula veris flowers as a valuable source of bioactive phenolics for food and health applications.}
}

@article{trendafilova2025primula,
  author   = {Trendafilova, A., Ivanova, V., Todorova, M., Aneva, I. and others},
  title    = {Phytochemical Characterization and Anti-Biofilm Activity of Primula veris L. Roots},
  journal  = {Molecules},
  year     = {2025},
  volume   = {30},
  number   = {8},
  pages    = {1702},
  doi      = {10.3390/molecules30081702},
  note     = {REF-0874},
  study_type = {preclinical},
  abstract = {Three new triterpene saponins (primulasaponins III-V) were isolated from the roots of Bulgarian Primula veris together with the known primulasaponin I. The root saponin fraction showed anti-biofilm activity, consistent with the expectorant and antimicrobial use of cowslip root in respiratory preparations.}
}

@article{colombo2017primula,
  author   = {Colombo, P.S., Flamini, G., Rodondi, G., Giuliani, C. and others},
  title    = {Phytochemistry of European Primula species},
  journal  = {Phytochemistry},
  year     = {2017},
  volume   = {143},
  pages    = {132-144},
  doi      = {10.1016/j.phytochem.2017.07.005},
  note     = {REF-0875},
  study_type = {traditional},
  abstract = {The genus Primula is the largest among the Primulaceae, widespread in cold and temperate regions of the Northern Hemisphere. This review summarises the phytochemistry of European Primula species, including Primula veris, covering flavonoids, phenolic glycosides, triterpene saponins and volatile constituents relevant to their medicinal use.}
}

@article{latypova2019primula,
  author   = {Latypova, G.M., Bondarenko, T.A., Katayev, V.A., Romanenko, E.B. and others},
  title    = {Composition and cardioprotective effects of Primula veris L. solid herbal extract in experimental chronic heart failure},
  journal  = {Phytomedicine},
  year     = {2019},
  volume   = {54},
  pages    = {17-26},
  doi      = {10.1016/j.phymed.2018.09.015},
  note     = {REF-0876},
  study_type = {preclinical},
  abstract = {A solid herbal extract of Primula veris was characterised and tested in a model of experimental chronic heart failure. The extract, rich in flavonoids and phenolic acids, improved cardiac function and reduced oxidative stress, demonstrating cardioprotective and antioxidant effects.}
}

@article{brys2015primula,
  author   = {Brys, R. and Jacquemyn, H.},
  title    = {Disruption of the distylous syndrome in Primula veris},
  journal  = {Annals of Botany},
  year     = {2015},
  volume   = {115},
  number   = {1},
  pages    = {27-39},
  doi      = {10.1093/aob/mcu211},
  note     = {REF-0877},
  study_type = {preclinical},
  abstract = {Distyly is a floral polymorphism with two morphs differing in the reciprocal positioning of anthers and stigmas. This study of Primula veris populations examined the genetic and morphological disruption of the distylous syndrome, contributing to understanding of the reproductive biology and conservation of cowslip.}
}

@article{muller2006primula,
  author   = {Muller, A., Ganzera, M. and Stuppner, H.},
  title    = {Analysis of phenolic glycosides and saponins in Primula elatior and Primula veris (primula root) by liquid chromatography, evaporative light scattering detection and mass spectrometry},
  journal  = {Journal of Chromatography A},
  year     = {2006},
  volume   = {1112},
  number   = {1-2},
  pages    = {218-223},
  doi      = {10.1016/j.chroma.2005.10.067},
  note     = {REF-0878},
  study_type = {preclinical},
  abstract = {The first liquid-chromatographic method for the simultaneous determination of the bioactive saponins and phenolic glycosides in Primula elatior and Primula veris (primula root) was developed using evaporative light scattering detection and mass spectrometry, enabling quality control of the expectorant primula root drug.}
}

@article{graikou2023primula,
  author   = {Graikou, K., Damianakos, H., Ganos, C., Syklowska-Baranek, K. and others},
  title    = {Comparative Phytochemical Analyses of Flowers from Primula veris subsp. veris Growing Wild and from Ex Situ Cultivation in Greece},
  journal  = {Foods},
  year     = {2023},
  volume   = {12},
  number   = {13},
  pages    = {2623},
  doi      = {10.3390/foods12132623},
  note     = {REF-0879},
  study_type = {preclinical},
  abstract = {Flowers of Primula veris subsp. veris from wild populations and ex situ cultivation in Greece were compared phytochemically. Both sources were rich in flavonoids and phenolic compounds with antioxidant activity, supporting the sustainable cultivation of cowslip for medicinal and food use.}
}

@article{jesionek2019rhododendron,
  author   = {Jesionek, A., Kokotkiewicz, A., Mikosik-Roczynska, A., Ciesielska-Figlon, K. and others},
  title    = {Chemical variability of Rhododendron tomentosum (Ledum palustre) essential oils and their pro-apoptotic effect on lymphocytes and rheumatoid arthritis synoviocytes},
  journal  = {Fitoterapia},
  year     = {2019},
  volume   = {139},
  pages    = {104402},
  doi      = {10.1016/j.fitote.2019.104402},
  note     = {REF-0880},
  study_type = {preclinical},
  abstract = {Rhododendron tomentosum is traditionally used for rheumatic complaints, making it a candidate for rheumatoid arthritis (RA) treatment. Essential oils of defined chemotypes were tested on peripheral blood lymphocytes and RA synoviocytes; the oils dose-dependently inhibited lymphocyte proliferation and increased apoptosis/necrosis of RA synovial fibroblasts, supporting anti-arthritic activity.}
}

@article{kang2017rhododendron,
  author   = {Kang, J.Y., Tran, K.D., Seiff, S.R., Mack, W.P. and Lee, W.W.},
  title    = {Assessing the Effectiveness of Arnica montana and Rhododendron tomentosum (Ledum palustre) in the Reduction of Ecchymosis and Edema After Oculofacial Surgery: Preliminary Results},
  journal  = {Ophthalmic Plastic and Reconstructive Surgery},
  year     = {2017},
  volume   = {33},
  number   = {1},
  pages    = {47-52},
  doi      = {10.1097/IOP.0000000000000645},
  note     = {REF-0881},
  study_type = {clinical},
  abstract = {This retrospective study assessed topical Arnica montana and Rhododendron tomentosum (Ledum palustre) hydrogel pads for reducing postoperative ecchymosis (bruising) and edema (swelling) after oculofacial surgery in 27 patients. Patients using Arnica/Ledum showed significantly more frequent markedly accelerated healing than expected, with no adverse effects, suggesting the combination may reduce postoperative bruising and swelling.}
}

@article{vengryte2024labradortea,
  author   = {Vengryte, M. and Raudone, L.},
  title    = {Phytochemical Profiling and Biological Activities of Rhododendron subsect. Ledum: Discovering the Medicinal Potential of Labrador Tea Species in the Northern Hemisphere},
  journal  = {Plants (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {6},
  pages    = {901},
  doi      = {10.3390/plants13060901},
  note     = {REF-0882},
  study_type = {traditional},
  abstract = {Rhododendron subsect. Ledum comprises eight evergreen species collectively known as Labrador tea, including Rhododendron tomentosum. This review summarises their phytochemical constituents (flavonoids, phenolic acids, terpenoids) and biological activities, including antioxidant, anti-inflammatory, antimicrobial, antitumor, hypoglycemic, hepatoprotective, neuroprotective and cardioprotective effects.}
}

@article{iunusova2024ledum,
  author   = {Iunusova, D.R., Polezhaeva, M.A. and Marchuk, E.A.},
  title    = {Confusing boundaries of the Labrador tea species: dispersal history explains the lack of clear species structure},
  journal  = {Annals of Botany},
  year     = {2024},
  volume   = {134},
  number   = {6},
  pages    = {959-974},
  doi      = {10.1093/aob/mcae130},
  note     = {REF-0883},
  study_type = {preclinical},
  abstract = {The Labrador teas (genus Rhododendron, subsection Ledum) form a circumboreal species complex with no clear species boundaries. Using chloroplast and nuclear markers across 65 populations, this study reconstructed the phylogeny and dispersal history of subsect. Ledum, clarifying the taxonomy and biogeography of Rhododendron tomentosum and its relatives.}
}

@article{dampc2014labradortea,
  author   = {Dampc, A. and Luczkiewicz, M.},
  title    = {Labrador tea - the aromatic beverage and spice: a review of origin, processing and safety},
  journal  = {Journal of the Science of Food and Agriculture},
  year     = {2014},
  volume   = {95},
  number   = {8},
  pages    = {1577-1583},
  doi      = {10.1002/jsfa.6889},
  note     = {REF-0884},
  study_type = {traditional},
  abstract = {Labrador tea is made from the dried leaves of Rhododendron tomentosum and related species, rich in essential oil and ascorbic acid, with tonic, digestion-improving and relaxing activity. The review covers origin, processing and safety, noting that the beverage should not be drunk more than once daily because of ledol and grayanotoxin toxicity.}
}

@article{jaenson2005rhododendron,
  author   = {Jaenson, T.G.T., Palsson, K. and Borg-Karlson, A.K.},
  title    = {Evaluation of extracts and oils of tick-repellent plants from Sweden},
  journal  = {Medical and Veterinary Entomology},
  year     = {2005},
  volume   = {19},
  number   = {4},
  pages    = {345-352},
  doi      = {10.1111/j.1365-2915.2005.00578.x},
  note     = {REF-0885},
  study_type = {preclinical},
  abstract = {Leaves of Myrica gale, Rhododendron tomentosum (formerly Ledum palustre) and Artemisia absinthium were extracted and their essential oils tested for repellency against Ixodes ricinus tick nymphs. Rhododendron tomentosum oil at 10% showed 95% repellency, the strongest of the plants tested, supporting the traditional insect-repellent use of wild rosemary.}
}

@article{tattje1981ledum,
  author   = {Tattje, D.H.E. and Bos, R.},
  title    = {Composition of essential oil of Ledum palustre},
  journal  = {Planta Medica},
  year     = {1981},
  volume   = {41},
  number   = {3},
  pages    = {303-307},
  doi      = {10.1055/s-2007-971719},
  note     = {REF-0886},
  study_type = {preclinical},
  abstract = {The essential oil of Ledum palustre (Rhododendron tomentosum), obtained by steam distillation of leaf material, was separated into seventeen fractions and analysed by GLC and GC-MS. In total 80 components were identified, with principal components ledol, palustrol and myrtenal, characterising the volatile constituents responsible for the plant's activity.}
}

@article{zhang2019ledum,
  author   = {Zhang, K., Wang, J., Chen, L., Li, J. and others},
  title    = {Two new taraxerane-type triterpenes from Ledum palustre L.},
  journal  = {Natural Product Research},
  year     = {2019},
  volume   = {34},
  number   = {19},
  pages    = {2723-2728},
  doi      = {10.1080/14786419.2019.1586689},
  note     = {REF-0887},
  study_type = {preclinical},
  abstract = {Two new taraxerane-type triterpenes were isolated from Ledum palustre (Rhododendron tomentosum) and their structures confirmed by IR, HR-ESI-TOFMS and NMR. The compounds were evaluated for cell-growth-inhibitory (cytotoxic) activity against two cancer cell lines, adding to the known triterpenoid chemistry of the plant.}
}

@article{islam2013ledum,
  author   = {Islam, M.N., Khalil, M.I., Islam, M.A. and Gan, S.H.},
  title    = {Toxic compounds in honey},
  journal  = {Journal of Applied Toxicology},
  year     = {2013},
  volume   = {34},
  number   = {7},
  pages    = {733-742},
  doi      = {10.1002/jat.2952},
  note     = {REF-0888},
  study_type = {traditional},
  abstract = {Honey may contain naturally occurring toxins derived from the nectar of certain plants. Honey collected from Ledum palustre (Rhododendron tomentosum) and related Ericaceae such as Kalmia and Rhododendron can contain grayanotoxins, which may cause dizziness, nausea, palpitations and, rarely, severe poisoning - an important safety consideration for Labrador tea, which also contains grayanotoxin and ledol.}
}

@article{baananou2014ledum,
  author   = {Baananou, S., Bagdonaite, E., Marongiu, B., Piras, A. and others},
  title    = {Supercritical CO2 extract and essential oil of aerial part of Ledum palustre L. - Chemical composition and anti-inflammatory activity},
  journal  = {Natural Product Research},
  year     = {2014},
  volume   = {29},
  number   = {11},
  pages    = {999-1005},
  doi      = {10.1080/14786419.2014.965167},
  note     = {REF-0889},
  study_type = {preclinical},
  abstract = {The anti-inflammatory activity of supercritical-CO2 and hydrodistilled essential oils from the aerial parts of Ledum palustre (Rhododendron tomentosum) was evaluated. Both oils, dominated by ledol and ascaridole, significantly inhibited carrageenan-induced hind-paw oedema in rats (50-80%), comparable to the reference drugs piroxicam and ketoprofen, demonstrating the anti-inflammatory activity of the plant's essential oil.}
}

@article{jeong2020rumex,
  author   = {Jeong, D., Irfan, M., Kim, S.D., Kim, S. and others},
  title    = {Rumex acetosa modulates platelet function and inhibits thrombus formation in rats},
  journal  = {BMC Complementary Medicine and Therapies},
  year     = {2020},
  volume   = {20},
  number   = {1},
  pages    = {98},
  doi      = {10.1186/s12906-020-02889-5},
  note     = {REF-0890},
  study_type = {preclinical},
  abstract = {Rumex acetosa, used in medicinal treatment and food in Eastern Asia, was examined for antiplatelet activity. The extract markedly inhibited collagen-induced platelet aggregation and ATP release dose-dependently, suppressed intracellular calcium mobilisation and integrin activation, and attenuated MAPK and PI3K/Akt signalling, suggesting it may protect against platelet-related cardiovascular disease.}
}

@article{oh2025rumex,
  author   = {Oh, D.R., Kim, Y., Choi, E.J., Jung, M.A. and others},
  title    = {Rumex acetosa L. enhances learning and cognitive function by modulating NMDA receptor and BDNF pathways in vitro and in vivo},
  journal  = {Metabolic Brain Disease},
  year     = {2025},
  volume   = {40},
  number   = {5},
  pages    = {185},
  doi      = {10.1007/s11011-025-01608-8},
  note     = {REF-0891},
  study_type = {preclinical},
  abstract = {Rumex acetosa (sorrel), used as a vegetable and traditional medicine, was investigated for effects on cognition. The extract enhanced learning and memory in vitro and in vivo by modulating NMDA receptor signalling and BDNF pathways, indicating a neuroprotective and cognition-enhancing potential.}
}

@article{kang2023rumex,
  author   = {Kang, Y.M., Lee, K.Y., An, H.J. and others},
  title    = {Anti-Helicobacter pylori Activity of Six Major Compounds Isolated from Rumex acetosa},
  journal  = {ACS Omega},
  year     = {2023},
  volume   = {8},
  number   = {45},
  pages    = {42548-42554},
  doi      = {10.1021/acsomega.3c05282},
  note     = {REF-0892},
  study_type = {preclinical},
  abstract = {Gastric problems are often caused by Helicobacter pylori, and antibiotic resistance complicates treatment. Six major compounds isolated from Rumex acetosa were evaluated for anti-Helicobacter pylori activity, with several showing significant inhibitory activity, supporting the use of sorrel against H. pylori-related digestive complaints.}
}

@article{sun2015rumex,
  author   = {Sun, Y.Y., Su, X.H., Jin, J.Y., Zhou, J. and others},
  title    = {Rumex acetosa L. induces vasorelaxation in rat aorta via activation of PI3-kinase/Akt- and Ca2+-eNOS-NO signaling in endothelial cells},
  journal  = {Journal of Physiology and Pharmacology},
  year     = {2015},
  volume   = {66},
  number   = {6},
  pages    = {907-915},
  url      = {https://pubmed.ncbi.nlm.nih.gov/26769840/},
  note     = {REF-0893},
  study_type = {preclinical},
  abstract = {Rumex acetosa, an important traditional medicine, was tested for vascular effects. The extract induced endothelium-dependent vasorelaxation in rat aorta via activation of the PI3-kinase/Akt and Ca2+-eNOS-NO signalling pathways in endothelial cells, providing a mechanism for its cardiovascular use.}
}

@article{selbach2021rumex,
  author   = {Selbach, S., Klocke, A., Peters, U., Beckert, S. and others},
  title    = {Microbiological and Clinical Effects of a Proanthocyanidin-enriched Extract from Rumex acetosa in Periodontally Healthy Carriers of Porphyromonas gingivalis: a Randomized Controlled Pilot Study},
  journal  = {Planta Medica},
  year     = {2021},
  volume   = {89},
  number   = {11},
  pages    = {1052-1062},
  doi      = {10.1055/a-1728-2249},
  note     = {REF-0894},
  study_type = {rct},
  abstract = {A proanthocyanidin-enriched extract from Rumex acetosa inhibits adhesion of Porphyromonas gingivalis to host cells. This randomised placebo-controlled pilot trial of a mouth rinse containing the extract in healthy carriers of P. gingivalis analysed microbiological and clinical effects, supporting an antimicrobial role of sorrel against periodontal pathogens.}
}

@article{ahn2020rumex,
  author   = {Ahn, S.H., Jeon, J.H., Kim, H.J., Maeng, H.J. and others},
  title    = {Effect of Rumex acetosa Extract, a Herbal Drug, on the Absorption of Fexofenadine},
  journal  = {Pharmaceutics},
  year     = {2020},
  volume   = {12},
  number   = {6},
  pages    = {547},
  doi      = {10.3390/pharmaceutics12060547},
  note     = {REF-0895},
  study_type = {preclinical},
  abstract = {Herbal drugs may alter the pharmacokinetics of co-administered drugs. This study examined the effect of Rumex acetosa extract on the intestinal absorption of fexofenadine, showing the extract modulated transporter-mediated absorption - an important herb-drug interaction consideration for sorrel preparations.}
}

@article{feduraev2022rumex,
  author   = {Feduraev, P., Skrypnik, L., Nebreeva, S., Dzhobadze, G. and others},
  title    = {Variability of Phenolic Compound Accumulation and Antioxidant Activity in Wild Plants of Some Rumex Species (Polygonaceae)},
  journal  = {Antioxidants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {2},
  pages    = {311},
  doi      = {10.3390/antiox11020311},
  note     = {REF-0896},
  study_type = {preclinical},
  abstract = {Seven Rumex species, including Rumex acetosa, were analysed for phenolic composition and antioxidant activity. The leaves were rich in flavonoids (apigenin, luteolin, quercetin, kaempferol derivatives), catechins, proanthocyanidins and tannins, and several species - including sorrel relatives - showed high antioxidant activity by DPPH, ABTS and FRAP assays.}
}

@article{li2022rumex,
  author   = {Li, J.J., Li, Y.X., Li, N., Zhu, H.T. and others},
  title    = {The genus Rumex (Polygonaceae): an ethnobotanical, phytochemical and pharmacological review},
  journal  = {Natural Products and Bioprospecting},
  year     = {2022},
  volume   = {12},
  number   = {1},
  pages    = {21},
  doi      = {10.1007/s13659-022-00346-z},
  note     = {REF-0897},
  study_type = {traditional},
  abstract = {The genus Rumex (sorrel/dock), including Rumex acetosa, has been used as food and to treat skin diseases and bleeding after trauma. About 268 substances (anthraquinones, flavonoids, naphthalenes, stilbenes, tannins) have been characterised, and crude extracts and isolates display antibacterial, anti-inflammatory, antitumour, antioxidant and cardiovascular-protective activities.}
}

@article{mishra2018rumex,
  author   = {Prakash Mishra, A., Sharifi-Rad, M., Shariati, M.A., Mabkhot, Y.N. and others},
  title    = {Bioactive compounds and health benefits of edible Rumex species - A review},
  journal  = {Cellular and Molecular Biology},
  year     = {2018},
  volume   = {64},
  number   = {8},
  pages    = {27-34},
  url      = {https://pubmed.ncbi.nlm.nih.gov/29981688/},
  note     = {REF-0898},
  study_type = {traditional},
  abstract = {Edible and medicinal Rumex species (including sorrel) are rich in phenylpropanoids and anthraquinones responsible for anticancer, antioxidant, antifungal, antibacterial, anti-dysenteric, anti-inflammatory, antiulcer, antihypertensive and anticoagulant properties. This review focuses on preclinical evidence for the efficacy and safety of Rumex species used as traditional foods and herbal remedies.}
}

@article{pan2020rumex,
  author   = {Pan, Y., Zhao, X., Kim, S.H., Kang, S.A. and others},
  title    = {Anti-inflammatory effects of Beopje curly dock (Rumex crispus L.) in LPS-induced RAW 264.7 cells and its active compounds},
  journal  = {Journal of Food Biochemistry},
  year     = {2020},
  volume   = {44},
  number   = {7},
  pages    = {e13291},
  doi      = {10.1111/jfbc.13291},
  note     = {REF-0899},
  study_type = {preclinical},
  abstract = {Curly dock (Rumex crispus, a Rumex congener of sorrel) extracts were tested on LPS-induced inflammation in RAW 264.7 macrophages. The extracts significantly inhibited nitric oxide production and pro-inflammatory cytokine and gene expression via the NF-kappaB pathway, demonstrating anti-inflammatory activity within the Rumex genus.}
}

@article{oladeji2020stellaria,
  author   = {Oladeji, O.S., Oyebamiji, A.K.},
  title    = {Stellaria media (L.) Vill. - A plant with immense therapeutic potentials: phytochemistry and pharmacology},
  journal  = {Heliyon},
  year     = {2020},
  volume   = {6},
  number   = {6},
  pages    = {e04150},
  doi      = {10.1016/j.heliyon.2020.e04150},
  note     = {REF-0900},
  study_type = {traditional},
  abstract = {Stellaria media (chickweed), a Caryophyllaceae plant used as a therapeutic substance since antiquity, contains flavonoids, the oligosaccharide stellariose, anthraquinone derivatives, steroid saponins and phenolic compounds. These constituents display anti-obesity, antifungal, antibacterial, antioxidant, anti-proliferative, anti-inflammatory, analgesic, antidiabetic and anxiolytic activities.}
}

@article{demjan2021stellaria,
  author   = {Demjan, V., Sojka, L., Slezak, P., Kaprinay, B. and others},
  title    = {Stellaria media tea protects against diabetes-induced cardiac dysfunction in rats without affecting glucose tolerance},
  journal  = {Journal of Traditional and Complementary Medicine},
  year     = {2021},
  volume   = {12},
  number   = {3},
  pages    = {250-259},
  doi      = {10.1016/j.jtcme.2021.08.003},
  note     = {REF-0901},
  study_type = {preclinical},
  abstract = {Common chickweed (Stellaria media) tea has been used in folk medicine for metabolic diseases including diabetes. In a rat model of diabetes, chickweed tea protected against diabetes-induced cardiac dysfunction without affecting glucose tolerance, providing experimental support for a cardioprotective effect.}
}

@article{demjan2020stellaria,
  author   = {Demjan, V., Kaprinay, B., Sotnikova, R., Knezl, V. and others},
  title    = {Effect of Stellaria media Tea on Lipid Profile in Rats},
  journal  = {Evidence-Based Complementary and Alternative Medicine},
  year     = {2020},
  volume   = {2020},
  pages    = {5109328},
  doi      = {10.1155/2020/5109328},
  note     = {REF-0902},
  study_type = {preclinical},
  abstract = {Common chickweed (Stellaria media) has traditionally been used for hypercholesterolemia. In rats, administration of chickweed tea favourably affected the serum lipid profile, providing experimental evidence supporting its folk use for lipid-related conditions.}
}

@article{aleem2023stellaria,
  author   = {Aleem, M., Khan, R.A., Tabassum, N. and others},
  title    = {Phytochemical analysis and gastroprotective effect of Stellaria media (L.) Vill. methanolic extract on piroxicam-induced gastric ulcer in Wistar rats},
  journal  = {Pakistan Journal of Pharmaceutical Sciences},
  year     = {2023},
  volume   = {36},
  number   = {5},
  pages    = {1425-1434},
  url      = {https://pubmed.ncbi.nlm.nih.gov/37869918/},
  note     = {REF-0903},
  study_type = {preclinical},
  abstract = {Stellaria media has traditionally been used for inflammatory and gastrointestinal ailments. A methanolic extract was phytochemically characterised and tested against piroxicam-induced gastric ulcer in Wistar rats, where it exerted a significant gastroprotective and anti-inflammatory effect, reducing ulcer index and gastric damage.}
}

@article{cusumano2024stellaria,
  author   = {Cusumano, G., Flores, G.A., Venanzoni, R., Angelini, P. and others},
  title    = {Small Steps to the Big Picture for Health-Promoting Applications Through the Use of Chickweed (Stellaria media): In Vitro, In Silico, and Pharmacological Network Approaches},
  journal  = {Food Science & Nutrition},
  year     = {2024},
  volume   = {12},
  number   = {11},
  pages    = {9295-9313},
  doi      = {10.1002/fsn3.4505},
  note     = {REF-0904},
  study_type = {preclinical},
  abstract = {Chickweed (Stellaria media) extracts (ethyl acetate, ethanol, ethanol-water) were profiled chemically and investigated for biological properties using in vitro, in silico and pharmacological network approaches. The extracts were rich in phenolics and showed antioxidant and antimicrobial activity, supporting health-promoting applications of chickweed.}
}

@article{ahmad2022stellaria,
  author   = {Ahmad, S., Ullah, F., Ayaz, M., Sadiq, A. and others},
  title    = {Lipid peroxidation reduction and hippocampal and cortical neurons protection against ischemic damage in animal model using Stellaria media},
  journal  = {Saudi Journal of Biological Sciences},
  year     = {2022},
  volume   = {29},
  number   = {3},
  pages    = {1887-1892},
  doi      = {10.1016/j.sjbs.2021.10.033},
  note     = {REF-0905},
  study_type = {preclinical},
  abstract = {Stellaria media was evaluated for neuroprotection in a rat model of ischemia-reperfusion injury. The extract reduced lipid peroxidation and protected hippocampal and cortical neurons against oxidative ischemic damage, demonstrating antioxidant and neuroprotective activity.}
}

@article{chak2024stellaria,
  author   = {Chak, P., Kumar, S. and others},
  title    = {In Vitro COX Inhibitory Activity, LC-MS Analysis and Molecular Docking Study of Silene vulgaris and Stellaria media},
  journal  = {Cell Biochemistry and Biophysics},
  year     = {2024},
  volume   = {83},
  number   = {1},
  pages    = {1009-1020},
  doi      = {10.1007/s12013-024-01533-0},
  note     = {REF-0906},
  study_type = {preclinical},
  abstract = {Extracts of Stellaria media (and Silene vulgaris), Caryophyllaceae weeds, were assessed for in vitro cyclooxygenase (COX) inhibitory activity, characterised by LC-MS and studied by molecular docking. Stellaria media showed COX inhibition, providing a mechanistic basis for its traditional anti-inflammatory use.}
}

@article{chidrawar2011stellaria,
  author   = {Chidrawar, V.R., Patel, K.N., Sheth, N.R., Shiromwar, S.S. and Trivedi, P.},
  title    = {Antiobesity effect of Stellaria media against drug induced obesity in Swiss albino mice},
  journal  = {Ayu},
  year     = {2011},
  volume   = {32},
  number   = {4},
  pages    = {576-584},
  doi      = {10.4103/0974-8520.96137},
  note     = {REF-0907},
  study_type = {preclinical},
  abstract = {The whole plant of Stellaria media was tested for antiobesity activity in a progesterone-induced obesity model in female albino mice. Chickweed reduced body-weight gain and adipose accumulation, supporting the traditional use of the plant for weight management.}
}

@article{rogozhin2015stellaria,
  author   = {Rogozhin, E.A., Slezina, M.P., Slavokhotova, A.A., Istomina, E.A. and others},
  title    = {A novel antifungal peptide from leaves of the weed Stellaria media L.},
  journal  = {Biochimie},
  year     = {2015},
  volume   = {116},
  pages    = {125-132},
  doi      = {10.1016/j.biochi.2015.07.014},
  note     = {REF-0908},
  study_type = {preclinical},
  abstract = {A novel antimicrobial peptide, SmAMP3, was isolated from leaves of common chickweed (Stellaria media) and sequenced. The peptide showed strong antifungal activity against phytopathogenic fungi, illustrating the plant's defence chemistry and contributing to its known antimicrobial properties.}
}

@article{slavokhotova2017stellaria,
  author   = {Slavokhotova, A.A., Shelenkov, A.A., Andreev, Y.A. and Odintsova, T.I.},
  title    = {Defense peptide repertoire of Stellaria media predicted by high throughput next generation sequencing},
  journal  = {Biochimie},
  year     = {2017},
  volume   = {135},
  pages    = {15-27},
  doi      = {10.1016/j.biochi.2016.12.017},
  note     = {REF-0909},
  study_type = {preclinical},
  abstract = {Using high-throughput next-generation sequencing, the defence peptide repertoire of chickweed (Stellaria media) was characterised, revealing a diverse set of antimicrobial peptides. This work maps the molecular basis of the plant's antimicrobial defence chemistry.}
}

@article{ahmad2025tussilago,
  author   = {Ahmad, I., Kudaibergenova, B., Ahmad, M. and others},
  title    = {Coltsfoot (Tussilago farfara L.; Asteraceae): modern methods of extraction, phytochemistry, nanoparticles synthesis, ethnopharmacology, and biological activities},
  journal  = {Natural Product Research},
  year     = {2025},
  pages    = {1-20},
  doi      = {10.1080/14786419.2025.2548616},
  note     = {REF-0910},
  study_type = {traditional},
  abstract = {Tussilago farfara (coltsfoot) is a widely used medicinal plant traditionally used for respiratory, digestive and circulatory ailments. Its alkaloids, flavonoids and terpenoids contribute to neuroprotective, anti-inflammatory, antioxidant and anticancer activities. This review covers extraction methods, phytochemistry, nanoparticle synthesis, ethnobotany, pharmacology and toxicology (pyrrolizidine-alkaloid safety considerations).}
}

@article{chen2020tussilago,
  author   = {Chen, S., Dong, L., Quan, H., Zhou, X. and others},
  title    = {A review of the ethnobotanical value, phytochemistry, pharmacology, toxicity and quality control of Tussilago farfara L. (coltsfoot)},
  journal  = {Journal of Ethnopharmacology},
  year     = {2020},
  volume   = {267},
  pages    = {113478},
  doi      = {10.1016/j.jep.2020.113478},
  note     = {REF-0911},
  study_type = {traditional},
  abstract = {Tussilago farfara (coltsfoot, Kuan Dong Hua) has long been used to treat respiratory disorders and consumed as a vegetable. This review summarises its ethnobotanical value, phytochemistry (sesquiterpenoids, triterpenoids, flavonoids, pyrrolizidine alkaloids), pharmacology (anti-inflammatory, antioxidant, antitussive, neuroprotective), toxicity and quality control.}
}

@article{feng2022tussilago,
  author   = {Feng, J., Zhang, Y., Qin, X., Gao, T. and others},
  title    = {Novel Quinic Acid Glycerates from Tussilago farfara Inhibit Polypeptide GalNAc-Transferase},
  journal  = {ChemBioChem},
  year     = {2022},
  volume   = {23},
  number   = {3},
  pages    = {e202100539},
  doi      = {10.1002/cbic.202100539},
  note     = {REF-0912},
  study_type = {preclinical},
  abstract = {Novel quinic acid glycerates were isolated from Tussilago farfara and identified as inhibitors of human polypeptide N-acetylgalactosaminyltransferases (GalNAc-Ts), the initiating enzymes of mucin-type O-glycosylation, adding new bioactive constituents to the known chemistry of coltsfoot.}
}

@article{zhao2014tussilago,
  author   = {Zhao, J., Evangelopoulos, D., Bhakta, S., Gray, A.I. and Seidel, V.},
  title    = {Antitubercular activity of Arctium lappa and Tussilago farfara extracts and constituents},
  journal  = {Journal of Ethnopharmacology},
  year     = {2014},
  volume   = {155},
  number   = {1},
  pages    = {796-800},
  doi      = {10.1016/j.jep.2014.06.034},
  note     = {REF-0913},
  study_type = {preclinical},
  abstract = {Arctium lappa and Tussilago farfara are traditionally used as antitubercular remedies. Extracts and isolated constituents were screened against Mycobacterium tuberculosis; several fractions and compounds from coltsfoot showed antitubercular activity, supporting the traditional antimicrobial use of the plant.}
}

@article{avila2020tussilago,
  author   = {Avila, C., Breakspear, I., Hawrelak, J., Salmond, S. and Evans, S.},
  title    = {A systematic review and quality assessment of case reports of adverse events for borage (Borago officinalis), coltsfoot (Tussilago farfara) and comfrey (Symphytum officinale)},
  journal  = {Fitoterapia},
  year     = {2020},
  volume   = {142},
  pages    = {104519},
  doi      = {10.1016/j.fitote.2020.104519},
  note     = {REF-0914},
  study_type = {systematic-review},
  abstract = {Borage, coltsfoot (Tussilago farfara) and comfrey have long therapeutic histories but their safety is questioned due to unsaturated pyrrolizidine alkaloids. This systematic review assessed case reports of adverse events (notably hepatic veno-occlusive disease), informing the safe use and contraindications of coltsfoot.}
}

@article{lee2019tussilago,
  author   = {Lee, J., Park, S., Kim, M.J., Kwon, S.J. and others},
  title    = {Sesquiterpenoids from Tussilago farfara Flower Bud Extract for the Eco-Friendly Synthesis of Silver and Gold Nanoparticles Possessing Antibacterial and Anticancer Activities},
  journal  = {Nanomaterials (Basel)},
  year     = {2019},
  volume   = {9},
  number   = {6},
  pages    = {819},
  doi      = {10.3390/nano9060819},
  note     = {REF-0915},
  study_type = {preclinical},
  abstract = {Sesquiterpenoids from Tussilago farfara flower bud extract were used as reducing agents to synthesise silver and gold nanoparticles. The resulting nanoparticles displayed antibacterial and anticancer (cytotoxic) activities, illustrating the bioactivity of coltsfoot constituents.}
}

@article{bota2022tussilago,
  author   = {Bota, V.B., Neamtu, A.A., Olah, N.K., Chiselita, O. and others},
  title    = {A Comparative Analysis of the Anatomy, Phenolic Profile, and Antioxidant Capacity of Tussilago farfara L. Vegetative Organs},
  journal  = {Plants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {13},
  pages    = {1663},
  doi      = {10.3390/plants11131663},
  note     = {REF-0916},
  study_type = {preclinical},
  abstract = {Tussilago farfara is used in traditional medicine mainly for respiratory-tract pathology. This study compared the anatomy, phenolic profile and antioxidant capacity of coltsfoot vegetative organs, finding the leaves rich in phenolics with notable antioxidant activity.}
}

@article{boucher2020tussilago,
  author   = {Boucher, M.A., Cote, H., Pichette, A., Ripoll, L. and Legault, J.},
  title    = {Chemical composition and antibacterial activity of Tussilago farfara (L.) essential oil from Quebec, Canada},
  journal  = {Natural Product Research},
  year     = {2020},
  volume   = {34},
  number   = {4},
  pages    = {545-548},
  doi      = {10.1080/14786419.2018.1489384},
  note     = {REF-0917},
  study_type = {preclinical},
  abstract = {The essential oil of Tussilago farfara from Quebec, Canada was analysed by GC-FID and GC-MS and tested for antibacterial activity. The oil's chemical composition was characterised and it showed antibacterial activity, supporting the antimicrobial use of coltsfoot.}
}

@article{li2022tussilago,
  author   = {Li, Z.Y., Zhang, J., Zhang, Y.B., Yang, X.W. and others},
  title    = {Polyhydroxylated eudesmane sesquiterpenoids and sesquiterpenoid glucoside from the flower buds of Tussilago farfara},
  journal  = {Chinese Journal of Natural Medicines},
  year     = {2022},
  volume   = {20},
  number   = {4},
  pages    = {301-308},
  doi      = {10.1016/S1875-5364(21)60120-6},
  note     = {REF-0918},
  study_type = {preclinical},
  abstract = {Chemical fractionation of the flower buds of Tussilago farfara yielded a series of polar constituents including new polyhydroxylated eudesmane sesquiterpenoids and a sesquiterpenoid glucoside, expanding the characterised constituent chemistry of coltsfoot.}
}

@article{jang2016tussilago,
  author   = {Jang, H., Lee, J.W., Lee, C., Jin, Q. and others},
  title    = {Sesquiterpenoids from Tussilago farfara inhibit LPS-induced nitric oxide production in macrophage RAW 264.7 cells},
  journal  = {Archives of Pharmacal Research},
  year     = {2016},
  volume   = {39},
  number   = {1},
  pages    = {127-132},
  doi      = {10.1007/s12272-015-0667-7},
  note     = {REF-0919},
  study_type = {preclinical},
  abstract = {A new oplopane-type sesquiterpenoid (tussilagofarin) and a new chromone, together with 18 known compounds, were isolated from the flower buds of Tussilago farfara. Several sesquiterpenoids significantly inhibited LPS-induced nitric oxide production in RAW 264.7 macrophages, demonstrating the anti-inflammatory activity of coltsfoot constituents.}
}

@article{lazarova2024marrubium,
  author   = {Lazarova, M.I., Tsvetanova, E.R., Georgieva, A.P., Stefanova, M.O. and others},
  title    = {Marrubium vulgare Extract Improves Spatial Working Memory and Oxidative Stress Damage in Scopolamine-Treated Rats},
  journal  = {Journal of Alzheimer's Disease},
  year     = {2024},
  volume   = {99},
  number   = {s1},
  pages    = {S157-S169},
  doi      = {10.3233/JAD-231011},
  note     = {REF-0920},
  study_type = {preclinical},
  abstract = {Marrubium vulgare (white horehound) water extract was tested in scopolamine-induced dementia in rats. It significantly improved spatial working memory in the T-maze test, reduced hippocampal acetylcholinesterase activity and alleviated cortical oxidative stress, demonstrating antioxidant and memory-preserving (neuroprotective) effects.}
}

@article{rodriguez2016marrubium,
  author   = {Rodriguez Villanueva, J. and Martin Esteban, J.},
  title    = {An Insight into a Blockbuster Phytomedicine; Marrubium vulgare L. Herb. More of a Myth than a Reality?},
  journal  = {Phytotherapy Research},
  year     = {2016},
  volume   = {30},
  number   = {10},
  pages    = {1551-1558},
  doi      = {10.1002/ptr.5661},
  note     = {REF-0921},
  study_type = {traditional},
  abstract = {White horehound (Marrubium vulgare) has been traditionally used in Europe and the Mediterranean for respiratory diseases (acute/chronic bronchitis, colds, asthma), lack of appetite, dyspepsia, type II diabetes and as an antihypertensive. This review critically analyses the quality of the scientific evidence behind these ethnopharmacological uses of horehound.}
}

@article{acimovic2021marrubium,
  author   = {Acimovic, M., Ivanovic, S., Simic, K., Pezo, L. and others},
  title    = {Chemical Characterization of Marrubium vulgare Volatiles from Serbia},
  journal  = {Plants (Basel)},
  year     = {2021},
  volume   = {10},
  number   = {3},
  pages    = {600},
  doi      = {10.3390/plants10030600},
  note     = {REF-0922},
  study_type = {preclinical},
  abstract = {A total of 160 compounds were determined in the volatiles of Marrubium vulgare from Serbia over two years. The main components were beta-caryophyllene, germacrene D, alpha-humulene and delta-copaene (sesquiterpene hydrocarbons), and several chemotypes were defined, characterising the volatile constituent chemistry of horehound.}
}

@article{amri2017marrubium,
  author   = {Amri, B., Martino, E., Vitulo, F., Corana, F. and others},
  title    = {Marrubium vulgare L. Leave Extract: Phytochemical Composition, Antioxidant and Wound Healing Properties},
  journal  = {Molecules},
  year     = {2017},
  volume   = {22},
  number   = {11},
  pages    = {1851},
  doi      = {10.3390/molecules22111851},
  note     = {REF-0923},
  study_type = {preclinical},
  abstract = {A methanolic extract of Marrubium vulgare leaves was characterised phytochemically (quantifying marrubiin by NMR and drawing the HPLC-UV/MS fingerprint), and its antioxidant properties and wound-healing potential were evaluated, showing the extract promotes wound repair through its antioxidant constituents.}
}

@article{lazarova2024bmarrubium,
  author   = {Lazarova, M., Stefanova, M., Denev, P., Taseva, T. and others},
  title    = {Neuroprotective Effect of Marrubium vulgare Extract in Scopolamine-Induced Cognitive Impairment in Rats: Behavioral and Biochemical Approaches},
  journal  = {Biology (Basel)},
  year     = {2024},
  volume   = {13},
  number   = {6},
  pages    = {426},
  doi      = {10.3390/biology13060426},
  note     = {REF-0924},
  study_type = {preclinical},
  abstract = {A Marrubium vulgare extract standardised to marrubiin content alleviated scopolamine-induced memory impairment in rats, preserved hippocampal cholinergic function, increased brain noradrenaline and restored cortical pCREB expression, indicating neuroprotective effects via modulation of cholinergic and noradrenergic neurotransmission.}
}

@article{aitbaba2024marrubium,
  author   = {Aitbaba, A., Kabdy, H., Baslam, A., Azraida, H. and others},
  title    = {Chemical Investigation and Antinociceptive Activity Evaluation of Marrubium vulgare L. Aqueous Extract},
  journal  = {Chemistry & Biodiversity},
  year     = {2024},
  volume   = {21},
  number   = {5},
  pages    = {e202400228},
  doi      = {10.1002/cbdv.202400228},
  note     = {REF-0925},
  study_type = {preclinical},
  abstract = {The aqueous extract of Marrubium vulgare leaves, traditionally used for respiratory infections, inflammation and pain, was investigated for chemical composition, acute toxicity and antinociceptive effects. The extract (rich in marrubiin) showed significant antioxidant and robust antinociceptive (analgesic) activity in writhing, hot-plate and formalin tests, supporting its antispasmodic/pain-relieving use.}
}

@article{abidi2022marrubium,
  author   = {Abidi, A., Dhaouafi, J., Brinsi, C., Tounsi, H. and Sebai, H.},
  title    = {Tunisian Horehound (Marrubium vulgare) Aqueous Extract Improves Treatment of Bleomycin-Induced Lung Fibrosis in Rat},
  journal  = {Dose-Response},
  year     = {2022},
  volume   = {20},
  number   = {3},
  pages    = {15593258221119300},
  doi      = {10.1177/15593258221119300},
  note     = {REF-0926},
  study_type = {preclinical},
  abstract = {The aqueous extract of horehound (Marrubium vulgare), rich in polyphenols, was tested against bleomycin-induced pulmonary fibrosis in rats. It significantly reduced the inflammatory index and fibrosis score, decreased infiltration of inflammatory cells, and reversed oxidative-stress markers, demonstrating anti-inflammatory and antioxidant protection of lung tissue.}
}

@article{rezgui2021marrubium,
  author   = {Rezgui, M., Basma, M., Neng, N., Nogueira, J.M. and others},
  title    = {Evaluation of Marrubium vulgare Growing Wild in Tunisia for Its Potential as a Dietary Supplement},
  journal  = {Foods},
  year     = {2021},
  volume   = {10},
  number   = {11},
  pages    = {2864},
  doi      = {10.3390/foods10112864},
  note     = {REF-0927},
  study_type = {preclinical},
  abstract = {Methanolic extracts of Marrubium vulgare from five Tunisian locations were evaluated for antioxidant activity (ferric reducing power, radical scavenging, beta-carotene bleaching), total phenolic content, mineral composition and marrubiin content, showing horehound's antioxidant capacity and phytochemistry are strongly influenced by harvest site.}
}

@article{gourich2023marrubium,
  author   = {Gourich, A.A., Touijer, H., Drioiche, A., Asbabou, A. and others},
  title    = {Insight into biological activities of chemically characterized extract from Marrubium vulgare L. in vitro, in vivo and in silico approaches},
  journal  = {Frontiers in Chemistry},
  year     = {2023},
  volume   = {11},
  pages    = {1238346},
  doi      = {10.3389/fchem.2023.1238346},
  note     = {REF-0928},
  study_type = {preclinical},
  abstract = {Aqueous extracts of Marrubium vulgare were characterised phytochemically (rich in catechin and maleic acid) and evaluated for biological activities. The extract showed significant antioxidant capacity, antimitotic potential, antimicrobial properties and a potent antihyperglycemic effect with modulation of pancreatic alpha-amylase, supporting its traditional medicinal uses.}
}

@article{yousefi2016marrubium,
  author   = {Yousefi, K., Hamedeyazdan, S., Torbati, M. and Fathiazad, F.},
  title    = {Chromatographic Fingerprint Analysis of Marrubiin in Marrubium vulgare L. via HPTLC Technique},
  journal  = {Advanced Pharmaceutical Bulletin},
  year     = {2016},
  volume   = {6},
  number   = {1},
  pages    = {131-136},
  doi      = {10.15171/apb.2016.019},
  note     = {REF-0929},
  study_type = {preclinical},
  abstract = {Marrubiin, the major active diterpene of Marrubium vulgare, was quantified in the aerial parts (156 mg/g extract) by HPTLC densitometry, and the methanol extract showed strong DPPH radical-scavenging antioxidant activity associated with its phenolic and flavonoid content, providing a fingerprint for quality control of horehound preparations.}
}

@article{geissler2024nepeta,
  author   = {Geissler, M., Neubauer, C., Sheludko, Y.V. and Warzecha, H.},
  title    = {Nepeta cataria L. (catnip) can serve as a chassis for the engineering of secondary metabolic pathways},
  journal  = {Biotechnology Letters},
  year     = {2024},
  volume   = {46},
  number   = {5},
  pages    = {843-850},
  doi      = {10.1007/s10529-024-03489-w},
  note     = {REF-0930},
  study_type = {preclinical},
  abstract = {Nepeta cataria (catnip) was evaluated as a metabolic-engineering host. The plant was amenable to Agrobacterium-mediated transient expression and, when biosynthetic genes were introduced, produced cannabinoid-precursor olivetolic acid glycosides, demonstrating catnip's potential as a chassis for engineering secondary metabolic pathways.}
}

@article{lockhart2024nepeta,
  author   = {Lockhart, A., Simon, J.E. and Wu, Q.},
  title    = {Stability study of Nepeta cataria iridoids analyzed by LC/MS},
  journal  = {Phytochemical Analysis},
  year     = {2024},
  volume   = {35},
  number   = {7},
  pages    = {1674-1687},
  doi      = {10.1002/pca.3410},
  note     = {REF-0931},
  study_type = {preclinical},
  abstract = {The long-term stability of the bioactive iridoids (nepetalactones, nepetalic acid, dihydronepetalactone) of catnip (Nepeta cataria) was measured over two years under different storage conditions by UHPLC-MS, identifying degradative byproducts and showing that protecting catnip products from light is necessary to preserve nepetalactone content.}
}

@article{nadeem2022nepeta,
  author   = {Nadeem, A., Shahzad, H., Ahmed, B., Muntean, T. and others},
  title    = {Phytochemical profiling of antimicrobial and potential antioxidant plant: Nepeta cataria},
  journal  = {Frontiers in Plant Science},
  year     = {2022},
  volume   = {13},
  pages    = {969316},
  doi      = {10.3389/fpls.2022.969316},
  note     = {REF-0932},
  study_type = {preclinical},
  abstract = {Nepeta cataria extracts (methanol, ethanol, water, acetone, hexane) were profiled by GC/MS, revealing 247 identified metabolites. The extracts showed inhibitory activity against a set of microbes and antioxidant potential (DPPH, ORAC), confirming the antimicrobial and antioxidant properties of catnip.}
}

@article{tan2019nepeta,
  author   = {Tan, J., Li, J., Ma, J. and Qiao, F.},
  title    = {Hepatoprotective effect of essential oils of Nepeta cataria L. on acetaminophen-induced liver dysfunction},
  journal  = {Bioscience Reports},
  year     = {2019},
  volume   = {39},
  number   = {8},
  pages    = {BSR20190697},
  doi      = {10.1042/BSR20190697},
  note     = {REF-0933},
  study_type = {preclinical},
  abstract = {Essential oils from Nepeta cataria significantly attenuated acetaminophen-induced liver damage in mice by accelerating harmless acetaminophen metabolism (increasing UGT and SULT expression, inhibiting CYP2E1) and activating Nrf-2, demonstrating a hepatoprotective effect of catnip essential oil.}
}

@article{mollova2023nepeta,
  author   = {Mollova, S., Dzhurmanski, A., Fidan, H., Bojilov, D. and others},
  title    = {Chemical Composition of Essential Oils from Nepeta cataria L. Cultivated in Bulgaria and Their Antimicrobial and Antioxidant Activity},
  journal  = {ACS Omega},
  year     = {2023},
  volume   = {8},
  number   = {17},
  pages    = {15441-15449},
  doi      = {10.1021/acsomega.3c00704},
  note     = {REF-0934},
  study_type = {preclinical},
  abstract = {Essential oils of Nepeta cataria cultivated in Bulgaria were characterised (main components beta-citronellol, geraniol, neral, nerol) and tested for antimicrobial and antioxidant activity. The oils showed antibacterial activity and notable antioxidant capacity (DPPH, ABTS, FRAP, CUPRAC), supporting the antimicrobial use of catnip.}
}

@article{reichert2019nepeta,
  author   = {Reichert, W., Ejercito, J., Guda, T., Dong, X. and others},
  title    = {Repellency Assessment of Nepeta cataria Essential Oils and Isolated Nepetalactones on Aedes aegypti},
  journal  = {Scientific Reports},
  year     = {2019},
  volume   = {9},
  number   = {1},
  pages    = {1524},
  doi      = {10.1038/s41598-018-36814-1},
  note     = {REF-0935},
  study_type = {preclinical},
  abstract = {Essential oils of two Nepeta cataria (catnip) chemotypes and their isolated nepetalactone isomers were evaluated as mosquito repellents against Aedes aegypti. All samples achieved greater than 95% repellency and, at the lowest concentrations, were more effective than DEET, demonstrating the insect-repellent activity of catnip.}
}

@article{tiwari2023nepeta,
  author   = {Tiwari, G., Chaturvedi, T., Gupta, A.K., Lal, R.K. and others},
  title    = {Assessment of Genetic Diversity, Micromorphology and Antimicrobial Activity in Nepeta cataria L.},
  journal  = {Chemistry & Biodiversity},
  year     = {2023},
  volume   = {20},
  number   = {2},
  pages    = {e202200241},
  doi      = {10.1002/cbdv.202200241},
  note     = {REF-0936},
  study_type = {preclinical},
  abstract = {Thirteen half-sib genotypes of Nepeta cataria (catmint) were assessed for genetic diversity, essential-oil composition (nepetalactone-dominant) and micromorphology. The catmint oil showed promising antimicrobial potential against human pathogens, supporting both crop improvement and the antimicrobial use of catnip.}
}

@article{giarratana2017nepeta,
  author   = {Giarratana, F., Muscolino, D., Ziino, G., Lo Presti, V. and others},
  title    = {Activity of Catmint (Nepeta cataria) essential oil against Anisakis larvae},
  journal  = {Tropical Biomedicine},
  year     = {2017},
  volume   = {34},
  number   = {1},
  pages    = {22-31},
  url      = {https://pubmed.ncbi.nlm.nih.gov/33592976/},
  note     = {REF-0937},
  study_type = {preclinical},
  abstract = {Catnip (Nepeta cataria) essential oil was assayed in vitro against L3 larvae of Anisakis type 1, a fishborne zoonotic nematode. The oil caused complete inactivation of the parasites within 6-12 hours, showing significant antiparasitic (nematicidal) activity and suggesting potential as a larvicidal agent.}
}

@article{sarkar1995nepeta,
  author   = {Sarkar, M., Rashmi, R., Vikramaditya and Varma, P.N.},
  title    = {Pharmacognosy of Nepeta cataria},
  journal  = {Ancient Science of Life},
  year     = {1995},
  volume   = {14},
  number   = {4},
  pages    = {225-234},
  url      = {https://pubmed.ncbi.nlm.nih.gov/22556702/},
  note     = {REF-0938},
  study_type = {traditional},
  abstract = {Nepeta cataria (catnip), containing tannin and volatile oil, is described as aromatic, carminative, tonic, diaphoretic, refrigerant, emmenagogue, antiseptic and stimulant, and useful in infantile colic and hysteria. This pharmacognostic study details the leaf, stem and trichome anatomy and TLC/UV fingerprint of the herb.}
}

@article{bernardi2011nepeta,
  author   = {Bernardi, M.M., Kirsten, T.B., Lago, J.H.G., Giovani, T.M. and Massoco, C.O.},
  title    = {Nepeta cataria L. var. citriodora (Becker) increases penile erection in rats},
  journal  = {Journal of Ethnopharmacology},
  year     = {2011},
  volume   = {137},
  number   = {3},
  pages    = {1318-1322},
  doi      = {10.1016/j.jep.2011.07.061},
  note     = {REF-0939},
  study_type = {preclinical},
  abstract = {Catnip (Nepeta cataria), which induces pleasure in cats and humans, was fed to male rats and found to increase apomorphine-induced penile erection and slightly facilitate sexual behaviour, while decreasing general activity, an effect attributed to an action on dopaminergic systems.}
}

@article{shareef2024oxycoccus,
  author   = {Shareef, S.M., Khaleel, R.A. and Maryoosh, T.M.},
  title    = {Nephroprotective effect of cranberry (Vaccinium oxycoccos) in streptozocin-induced diabetic nephropathy in mice},
  journal  = {Drug Metabolism and Personalized Therapy},
  year     = {2024},
  volume   = {39},
  number   = {1},
  pages    = {35-45},
  doi      = {10.1515/dmpt-2023-0092},
  note     = {REF-0940},
  study_type = {preclinical},
  abstract = {A hydroalcoholic extract of cranberry (Vaccinium oxycoccos) was tested in streptozotocin-induced diabetic nephropathy in mice. The extract improved serum and urine renal parameters, raised antioxidant enzymes (SOD, GSH) and lowered inflammatory cytokines (TNF-alpha, IL-6, TGF-beta1), demonstrating antioxidant, anti-inflammatory and nephroprotective effects.}
}

@article{jurikova2018oxycoccus,
  author   = {Jurikova, T., Skrovankova, S., Mlcek, J., Balla, S. and Snopek, L.},
  title    = {Bioactive Compounds, Antioxidant Activity, and Biological Effects of European Cranberry (Vaccinium oxycoccos)},
  journal  = {Molecules},
  year     = {2018},
  volume   = {24},
  number   = {1},
  pages    = {24},
  doi      = {10.3390/molecules24010024},
  note     = {REF-0941},
  study_type = {traditional},
  abstract = {European cranberry (Vaccinium oxycoccos) fruit is a valuable source of antioxidants, especially anthocyanins, proanthocyanidins and quercetin. This review summarises its bioactive compounds and biological effects, including urinary-tract protection (proanthocyanidins), antibacterial and antifungal properties, and cardioprotective and anticancer activities.}
}

@article{sedbare2022oxycoccus,
  author   = {Sedbare, R., Raudone, L., Zvikas, V., Viskelis, J. and others},
  title    = {Development and Validation of the UPLC-DAD Methodology for the Detection of Triterpenoids and Phytosterols in Fruit Samples of Vaccinium macrocarpon Aiton and Vaccinium oxycoccos L.},
  journal  = {Molecules},
  year     = {2022},
  volume   = {27},
  number   = {14},
  pages    = {4403},
  doi      = {10.3390/molecules27144403},
  note     = {REF-0942},
  study_type = {preclinical},
  abstract = {A UPLC-DAD method was developed and validated for triterpene acids, neutral triterpenoids, phytosterols and squalene in cranberry, and applied to Vaccinium macrocarpon and Vaccinium oxycoccos fruit, peel, pulp and seeds. Ursolic acid was the dominant triterpenoid, with the highest triterpene content in the peels, characterising the triterpenoid chemistry of bog cranberry.}
}

@article{sedbare2023oxycoccus,
  author   = {Sedbare, R., Sprainaityte, S., Baublys, G., Viskelis, J. and Janulis, V.},
  title    = {Phytochemical Composition of Cranberry (Vaccinium oxycoccos L.) Fruits Growing in Protected Areas of Lithuania},
  journal  = {Plants (Basel)},
  year     = {2023},
  volume   = {12},
  number   = {10},
  pages    = {1974},
  doi      = {10.3390/plants12101974},
  note     = {REF-0943},
  study_type = {preclinical},
  abstract = {Fruits of Vaccinium oxycoccos are a source of bioactive compounds with antibacterial, antifungal and anti-inflammatory effects. Phytochemical analysis of bog cranberry from different Lithuanian wetlands quantified anthocyanins, flavonols, triterpenes, chlorogenic acid and proanthocyanidins, showing site-dependent variation and the need for standardisation of cranberry raw materials.}
}

@article{brown2012oxycoccus,
  author   = {Brown, P.N., Turi, C.E., Shipley, P.R. and Murch, S.J.},
  title    = {Comparisons of large (Vaccinium macrocarpon Ait.) and small (Vaccinium oxycoccos L., Vaccinium vitis-idaea L.) cranberry in British Columbia by phytochemical determination, antioxidant potential, and metabolomic profiling with chemometric analysis},
  journal  = {Planta Medica},
  year     = {2012},
  volume   = {78},
  number   = {6},
  pages    = {630-640},
  doi      = {10.1055/s-0031-1298239},
  note     = {REF-0944},
  study_type = {preclinical},
  abstract = {The chemical composition of the small cranberries Vaccinium oxycoccos and V. vitis-idaea was characterised and compared with the cultivated large cranberry V. macrocarpon. V. oxycoccos contained the five major cranberry anthocyanins plus serotonin, melatonin and ascorbic acid, and metabolomic profiling differentiated the species, with antioxidant activity correlating with vitamin C content.}
}

@article{harini2022oxycoccus,
  author   = {Harini, K., Janani, K., Teja, K.V., Mohan, C. and Sukumar, M.},
  title    = {Formulation and evaluation of oral disintegrating films using a natural ingredient against Streptococcus mutans},
  journal  = {Journal of Conservative Dentistry},
  year     = {2022},
  volume   = {25},
  number   = {2},
  pages    = {128-134},
  doi      = {10.4103/jcd.jcd_143_21},
  note     = {REF-0945},
  study_type = {preclinical},
  abstract = {Aqueous extracts of Vaccinium oxycoccos (and Plectranthus amboinicus) were incorporated into oral disintegrating films targeting the cariogenic bacterium Streptococcus mutans. The bog cranberry extract showed good antibacterial activity (MIC 50 ug/mL), supporting its use as a natural antimicrobial agent against oral pathogens.}
}

@article{cesoniene2011oxycoccus,
  author   = {Cesoniene, L., Daubaras, R., Jasutiene, I., Vencloviene, J. and Miliauskiene, I.},
  title    = {Evaluation of the biochemical components and chromatic properties of the juice of Vaccinium macrocarpon Aiton and Vaccinium oxycoccos L.},
  journal  = {Plant Foods for Human Nutrition},
  year     = {2011},
  volume   = {66},
  number   = {3},
  pages    = {238-244},
  doi      = {10.1007/s11130-011-0241-5},
  note     = {REF-0946},
  study_type = {preclinical},
  abstract = {Benzoic acid, total anthocyanins, soluble solids, titratable acidity and colour were measured in the juice of the American cranberry Vaccinium macrocarpon and the European cranberry Vaccinium oxycoccos. V. oxycoccos juice contained 17.5 mg/L benzoic acid and 42.5 mg/L anthocyanins, with six anthocyanins (peonidin-3-galactoside predominant), characterising the fruit's bioactive composition.}
}

@article{vanrossum2012oxycoccus,
  author   = {Van Rossum, F., Vereecken, N.J., Bredat, E. and Michez, D.},
  title    = {Pollen dispersal and fruit production in Vaccinium oxycoccos and comparison with its sympatric congener V. uliginosum},
  journal  = {Plant Biology},
  year     = {2012},
  volume   = {15},
  number   = {2},
  pages    = {344-352},
  doi      = {10.1111/j.1438-8677.2012.00646.x},
  note     = {REF-0947},
  study_type = {preclinical},
  abstract = {Pollen dispersal and fruit production were investigated in the insect-pollinated bog cranberry Vaccinium oxycoccos and compared with its sympatric congener V. uliginosum. Fluorescent-dye experiments showed mainly short-distance pollen dispersal and pollinator sharing, informing the reproductive biology and conservation of fragmented V. oxycoccos populations.}
}

@article{kawash2022oxycoccus,
  author   = {Kawash, J., Colt, K., Hartwick, N.T., Abramson, B.W. and others},
  title    = {Contrasting a reference cranberry genome to a crop wild relative provides insights into adaptation, domestication, and breeding},
  journal  = {PLoS One},
  year     = {2022},
  volume   = {17},
  number   = {3},
  pages    = {e0264966},
  doi      = {10.1371/journal.pone.0264966},
  note     = {REF-0948},
  study_type = {preclinical},
  abstract = {An updated chromosome-resolved reference genome of cranberry (Vaccinium macrocarpon) was compared with a high-quality draft genome of the circumboreal wild relative Vaccinium oxycoccos, which forms interspecific hybrids with V. macrocarpon. The comparison identified environmental-response and plant-architecture genes relevant to adaptation, domestication and breeding.}
}

@article{stobnicka2017oxycoccus,
  author   = {Stobnicka, A. and Gniewosz, M.},
  title    = {Antimicrobial protection of minced pork meat with the use of Swamp Cranberry (Vaccinium oxycoccos L.) fruit and pomace extracts},
  journal  = {Journal of Food Science and Technology},
  year     = {2017},
  volume   = {55},
  number   = {1},
  pages    = {62-71},
  doi      = {10.1007/s13197-017-2770-x},
  note     = {REF-0949},
  study_type = {preclinical},
  abstract = {Swamp cranberry (Vaccinium oxycoccos) fruit and pomace extracts, rich in organic acids, flavonols, terpenes and stilbenes, inhibited Gram-positive bacteria more strongly than Gram-negative and reduced pathogenic cells in minced pork by 4 log cycles, demonstrating the antibacterial activity and food-preservative potential of bog cranberry.}
}

@article{hack2023guarana,
  author   = {Hack, B., Penna, E.M., Talik, T., Chandrashekhar, R. and Millard-Stafford, M.},
  title    = {Effect of Guarana (Paullinia cupana) on Cognitive Performance: A Systematic Review and Meta-Analysis},
  journal  = {Nutrients},
  year     = {2023},
  volume   = {15},
  number   = {2},
  pages    = {434},
  doi      = {10.3390/nu15020434},
  note     = {REF-0950},
  study_type = {meta-analysis},
  abstract = {A systematic review and meta-analysis of eight placebo-controlled studies (328 participants) assessed whether acute guarana (Paullinia cupana) ingestion improves cognitive performance. Guarana produced a small effect on response time (faster performance) across cognitive tasks without affecting accuracy, an effect not clearly related to guarana dose or caffeine content.}
}

@article{dearaujo2021guarana,
  author   = {de Araujo, D.P., Pereira, P.T.V.T., Fontes, A.J.C., Marques, K.D.S. and others},
  title    = {The use of guarana (Paullinia cupana) as a dietary supplement for fatigue in cancer patients: a systematic review with a meta-analysis},
  journal  = {Supportive Care in Cancer},
  year     = {2021},
  volume   = {29},
  number   = {12},
  pages    = {7171-7182},
  doi      = {10.1007/s00520-021-06242-5},
  note     = {REF-0951},
  study_type = {meta-analysis},
  abstract = {This systematic review with meta-analysis assessed guarana (Paullinia cupana) for managing cancer-related fatigue across seven studies (427 patients). In the pooled breast-cancer analysis, guarana was not superior to placebo for reducing cancer-related fatigue, and the quality of evidence was very low, indicating the need for further well-designed studies.}
}

@article{aldhahrani2021guarana,
  author   = {Aldhahrani, A.},
  title    = {Protective effects of guarana (Paullinia cupana) against methotrexate-induced intestinal damage in mice},
  journal  = {Food Science & Nutrition},
  year     = {2021},
  volume   = {9},
  number   = {7},
  pages    = {3397-3404},
  doi      = {10.1002/fsn3.2101},
  note     = {REF-0952},
  study_type = {preclinical},
  abstract = {Guarana (Paullinia cupana) was tested against methotrexate-induced intestinal damage in mice. Pre-administration of guarana restored antioxidant capacity (glutathione, SOD), inhibited IL-1beta and myeloperoxidase, and reduced pro-apoptotic Bax/caspase-9 expression, protecting intestinal tissue against oxidative stress and inflammation.}
}

@article{sirena2024guarana,
  author   = {Sirena, D.H., Araujo, A.B., Silveira, A.B.T., Serafini, M.A. and others},
  title    = {Guarana (Paullinia cupana) as a potential tool for mesenchymal stromal cells priming in regenerative medicine},
  journal  = {Brazilian Journal of Medical and Biological Research},
  year     = {2024},
  volume   = {57},
  pages    = {e13286},
  doi      = {10.1590/1414-431X2024e13286},
  note     = {REF-0953},
  study_type = {preclinical},
  abstract = {Guarana (Paullinia cupana) and caffeine were evaluated as priming agents for mesenchymal stromal cells (MSCs). Guarana increased MSC viability, polarity, migration toward chemoattractant, antioxidant potential and extracellular-vesicle release while reducing autophagy, suggesting guarana could activate MSCs to improve cellular products for regenerative therapies.}
}

@article{torres2022guarana,
  author   = {Torres, E.A.F.S., Pinaffi-Langley, A.C.D.C., Figueira, M.S., Cordeiro, K.S. and others},
  title    = {Effects of the consumption of guarana on human health: A narrative review},
  journal  = {Comprehensive Reviews in Food Science and Food Safety},
  year     = {2022},
  volume   = {21},
  number   = {1},
  pages    = {272-295},
  doi      = {10.1111/1541-4337.12862},
  note     = {REF-0954},
  study_type = {traditional},
  abstract = {Guarana (Paullinia cupana), an Amazonian plant rich in methylxanthines and flavonoids, has been studied for stimulating, anti-inflammatory, antioxidant, anticancer, hypocholesterolemic and anti-obesity effects. This narrative review organises the available evidence on guarana and human health, noting the need for more human and mechanistic studies.}
}

@article{penna2024guarana,
  author   = {Penna, E.M., Harp, A., Hack, B., Talik, T.N. and Millard-Stafford, M.},
  title    = {Guarana (Paullinia cupana) but Not Low-Dose Caffeine Improves Cycling Time-Trial Performance Versus Placebo},
  journal  = {International Journal of Sport Nutrition and Exercise Metabolism},
  year     = {2024},
  volume   = {34},
  number   = {1},
  pages    = {30-37},
  doi      = {10.1123/ijsnem.2023-0148},
  note     = {REF-0955},
  study_type = {rct},
  abstract = {In a double-blind crossover trial, eleven endurance-trained participants ingested caffeine, guarana (Paullinia cupana, containing 130 mg caffeine) or placebo before cycling. Guarana improved 15-min time-trial work output versus placebo, with lower perceived exertion, indicating an ergogenic effect possibly involving central mechanisms reducing perceived effort.}
}

@article{lima2017guarana,
  author   = {Lima, N.D.S., Numata, E.P., Mesquita, L.M.S., Dias, P.H. and others},
  title    = {Modulatory Effects of Guarana (Paullinia cupana) on Adipogenesis},
  journal  = {Nutrients},
  year     = {2017},
  volume   = {9},
  number   = {6},
  pages    = {635},
  doi      = {10.3390/nu9060635},
  note     = {REF-0956},
  study_type = {preclinical},
  abstract = {Guarana (Paullinia cupana) had a dose-dependent triglyceride-reducing (anti-adipogenic) effect in 3T3-L1 cells, up-regulating anti-adipogenic genes and down-regulating pro-adipogenic genes via modulation of miRNAs and beta-catenin signalling, supporting its role in body-weight control and metabolic health.}
}

@article{lima2018guarana,
  author   = {Lima, N.D.S., Teixeira, L., Gambero, A. and Ribeiro, M.L.},
  title    = {Guarana (Paullinia cupana) Stimulates Mitochondrial Biogenesis in Mice Fed High-Fat Diet},
  journal  = {Nutrients},
  year     = {2018},
  volume   = {10},
  number   = {2},
  pages    = {165},
  doi      = {10.3390/nu10020165},
  note     = {REF-0957},
  study_type = {preclinical},
  abstract = {In high-fat-diet-fed mice, guarana (Paullinia cupana) reduced body weight, adipose depots, glycaemia and triglycerides, increased oxygen consumption and energy expenditure, and stimulated mitochondrial biogenesis in muscle and brown adipose tissue, demonstrating that guarana increases energy metabolism and helps control weight gain.}
}

@article{zamberlan2020guarana,
  author   = {Zamberlan, D.C., Arantes, L.P., Machado, M.L., da Silveira, T.L. and others},
  title    = {Guarana (Paullinia cupana Mart.) protects against amyloid-beta toxicity in Caenorhabditis elegans through heat shock protein response activation},
  journal  = {Nutritional Neuroscience},
  year     = {2020},
  volume   = {23},
  number   = {6},
  pages    = {444-454},
  doi      = {10.1080/1028415X.2018.1517473},
  note     = {REF-0958},
  study_type = {preclinical},
  abstract = {Chronic guarana (Paullinia cupana) ethanolic extract treatment decreased amyloid-beta aggregate formation in a Caenorhabditis elegans model of Alzheimer's disease, preventing behavioural deficits and oxidative damage through activation of the heat-shock-protein response, indicating neuroprotective potential against amyloidogenic neurodegeneration.}
}

@article{abboud2020guarana,
  author   = {Abboud, R.S., Ribeiro, I.C.A., Pereira, V.A., Correa, L.B.N. and others},
  title    = {Guarana (Paullinia cupana) consumption improves hepatic and renal parameters in alloxan-induced diabetic rats},
  journal  = {Nutricion Hospitalaria},
  year     = {2020},
  volume   = {37},
  number   = {2},
  pages    = {343-348},
  doi      = {10.20960/nh.02759},
  note     = {REF-0959},
  study_type = {preclinical},
  abstract = {Consumption of guarana (Paullinia cupana) by alloxan-induced diabetic rats beneficially affected hepatic (ALT, AST) and renal function parameters and improved the lipid profile, suggesting guarana could serve as supportive antioxidant therapy in the management of diabetes.}
}

@article{laanet2024plantago,
  author   = {Laanet, P.R., Bragina, O., Joul, P. and Vaher, M.},
  title    = {Plantago lanceolata and Plantago major Exhibit Antioxidant and Borrelia burgdorferi Inhibiting Activities},
  journal  = {International Journal of Molecular Sciences},
  year     = {2024},
  volume   = {25},
  number   = {13},
  pages    = {7112},
  doi      = {10.3390/ijms25137112},
  note     = {REF-0960},
  study_type = {preclinical},
  abstract = {Hydroalcoholic extracts of Plantago lanceolata and Plantago major, rich in plantamajoside and acteoside, showed considerable antioxidant activity and inhibited the Lyme-disease pathogen Borrelia burgdorferi, lowering bacterial viability and reducing biofilm formation, supporting the antibacterial and antioxidant use of plantain.}
}

@article{budzianowska2022plantago,
  author   = {Budzianowska, A. and Budzianowski, J.},
  title    = {A new flavonoid, a new phenylethanoid glycoside and related compounds isolated from the inflorescences of Plantago lanceolata L.},
  journal  = {Natural Product Research},
  year     = {2022},
  volume   = {36},
  number   = {15},
  pages    = {3813-3824},
  doi      = {10.1080/14786419.2021.1888289},
  note     = {REF-0961},
  study_type = {preclinical},
  abstract = {For the first time, the inflorescences of Plantago lanceolata (ribwort plantain) were studied for phenolic compounds, yielding two new compounds (a flavonoid and a phenylethanoid glycoside) along with fourteen known flavonoids and phenylethanoid glycosides, characterising constituents of medicinal and chemotaxonomic relevance.}
}

@article{gadermaier2014plantago,
  author   = {Gadermaier, G., Eichhorn, S., Vejvar, E., Weilnbock, L. and others},
  title    = {Plantago lanceolata: an important trigger of summer pollinosis with limited IgE cross-reactivity},
  journal  = {Journal of Allergy and Clinical Immunology},
  year     = {2014},
  volume   = {134},
  number   = {2},
  pages    = {472-475},
  doi      = {10.1016/j.jaci.2014.02.016},
  note     = {REF-0962},
  study_type = {preclinical},
  abstract = {This study identified Plantago lanceolata pollen as an important trigger of summer pollinosis (seasonal allergic rhinitis) with limited IgE cross-reactivity to other allergens, an important consideration for the allergenic potential and safe use of ribwort plantain.}
}

@article{sousa2014plantago,
  author   = {Sousa, R., Osorio, H., Duque, L., Ribeiro, H., Cruz, A. and Abreu, I.},
  title    = {Identification of Plantago lanceolata pollen allergens using an immunoproteomic approach},
  journal  = {Journal of Investigational Allergology and Clinical Immunology},
  year     = {2014},
  volume   = {24},
  number   = {3},
  pages    = {177-183},
  url      = {https://pubmed.ncbi.nlm.nih.gov/25011355/},
  note     = {REF-0963},
  study_type = {preclinical},
  abstract = {Using 1D/2D gel electrophoresis, immunoblotting and mass spectrometry with sera from sensitised patients, this study characterised the pollen allergen profile of Plantago lanceolata, identifying eight prominent IgE-reactive allergen groups relevant to seasonal respiratory allergy.}
}

@article{reza2021plantago,
  author   = {Reza, M.M., Redoy, M.R.A., Rahman, M.A., Ety, S. and others},
  title    = {Response of plantain (Plantago lanceolata L.) supplementation on nutritional, endo-parasitic, and endocrine status in lambs},
  journal  = {Tropical Animal Health and Production},
  year     = {2021},
  volume   = {53},
  number   = {1},
  pages    = {82},
  doi      = {10.1007/s11250-020-02514-0},
  note     = {REF-0964},
  study_type = {preclinical},
  abstract = {Dietary supplementation with plantain (Plantago lanceolata) improved growth and feed conversion in lambs, suppressed cholesterol, improved liver enzyme activity and was highly effective at suppressing gastrointestinal parasites (Paramphistomum and coccidia), demonstrating the anthelmintic and metabolic effects of ribwort plantain.}
}

@article{rahamouz2022plantago,
  author   = {Rahamouz-Haghighi, S., Bagheri, K., Mohsen-Pour, N. and Sharafi, A.},
  title    = {Evaluation of Cytotoxicity and Antibacterial Activities of Ribwort Plantain (Plantago lanceolata L.) Root Fractions and Phytochemical Analysis by Gas Chromatography-Mass Spectrometry},
  journal  = {Archives of Razi Institute},
  year     = {2022},
  volume   = {77},
  number   = {6},
  pages    = {2131-2143},
  doi      = {10.22092/ARI.2022.358045.2143},
  note     = {REF-0965},
  study_type = {preclinical},
  abstract = {Root fractions of ribwort plantain (Plantago lanceolata) were cytotoxic to HCT-116 colon cancer cells and showed antibacterial activity against gram-positive and gram-negative bacteria, with the dichloromethane extract most active, identifying the roots as a source of bioactive antibacterial metabolites.}
}

@article{kovac2015plantago,
  author   = {Kovac, I., Durkac, J., Holly, M., Jakubcova, K. and others},
  title    = {Plantago lanceolata L. water extract induces transition of fibroblasts into myofibroblasts and increases tensile strength of healing skin wounds},
  journal  = {Journal of Pharmacy and Pharmacology},
  year     = {2015},
  volume   = {67},
  number   = {1},
  pages    = {117-125},
  doi      = {10.1111/jphp.12316},
  note     = {REF-0966},
  study_type = {preclinical},
  abstract = {Plantago lanceolata water extract, traditionally used to stimulate wound healing, was applied to skin wounds in rats. Treated wounds contained more myofibroblasts, showed significantly higher contraction rates and increased tensile strength due to better-organised collagen, demonstrating that ribwort plantain improves skin wound healing.}
}

@article{jaric2017plantago,
  author   = {Jaric, S., Kostic, O., Mataruga, Z., Pavlovic, D. and others},
  title    = {Traditional wound-healing plants used in the Balkan region (Southeast Europe)},
  journal  = {Journal of Ethnopharmacology},
  year     = {2017},
  volume   = {211},
  pages    = {311-328},
  doi      = {10.1016/j.jep.2017.09.018},
  note     = {REF-0967},
  study_type = {traditional},
  abstract = {This ethnobotanical review of Balkan wound-healing plants identified Plantago lanceolata among the most commonly used species, and noted that its traditional wound-healing use is confirmed by laboratory studies, supporting the vulnerary application of ribwort plantain.}
}

@article{zeng2019aucubin,
  author   = {Zeng, X., Guo, F. and Ouyang, D.},
  title    = {A review of the pharmacology and toxicology of aucubin},
  journal  = {Fitoterapia},
  year     = {2019},
  volume   = {140},
  pages    = {104443},
  doi      = {10.1016/j.fitote.2019.104443},
  note     = {REF-0968},
  study_type = {traditional},
  abstract = {Aucubin, an iridoid glycoside prevalent in Plantago and other medicinal herbs, possesses antioxidant, anti-inflammatory, anti-fibrotic, hepatoprotective, neuroprotective and osteoprotective properties with good tolerance. This review summarises the source, biological activity, pharmacokinetics and toxicology of aucubin, a key bioactive constituent of plantain.}
}

@article{drava2019plantago,
  author   = {Drava, G., Cornara, L., Giordani, P. and Minganti, V.},
  title    = {Trace elements in Plantago lanceolata L., a plant used for herbal and food preparations: new data and literature review},
  journal  = {Environmental Science and Pollution Research International},
  year     = {2019},
  volume   = {26},
  number   = {3},
  pages    = {2305-2313},
  doi      = {10.1007/s11356-018-3740-1},
  note     = {REF-0969},
  study_type = {preclinical},
  abstract = {Plantago lanceolata, widely used in food and herbal preparations, was analysed for trace-element content (As, Cd, Cu, Fe, Pb, Zn and others) across rural, urban and industrial sites. Except near mines and smelters, metal content posed no particular health risk, informing the safe use and quality of ribwort plantain raw material.}
}

@article{bandick2023tormentil,
  author   = {Bandick, R., Busmann, L.V., Mousavi, S., Shayya, N.W. and others},
  title    = {Therapeutic Effects of Oral Application of Menthol and Extracts from Tormentil (Potentilla erecta), Raspberry Leaves and Loosestrife during Acute Murine Campylobacteriosis},
  journal  = {Pharmaceutics},
  year     = {2023},
  volume   = {15},
  number   = {10},
  pages    = {2410},
  doi      = {10.3390/pharmaceutics15102410},
  note     = {REF-0970},
  study_type = {preclinical},
  abstract = {In a murine model of acute Campylobacter jejuni infection, extracts of tormentil (Potentilla erecta) combined with menthol, raspberry leaves and loosestrife alleviated campylobacteriosis-induced diarrhoeal symptoms and lowered colonic T-cell numbers and pro-inflammatory cytokines, demonstrating anti-inflammatory and antidiarrhoeal effects.}
}

@article{fecka2015tormentil,
  author   = {Fecka, I., Kucharska, A.Z. and Kowalczyk, A.},
  title    = {Quantification of tannins and related polyphenols in commercial products of tormentil (Potentilla tormentilla)},
  journal  = {Phytochemical Analysis},
  year     = {2015},
  volume   = {26},
  number   = {5},
  pages    = {353-366},
  doi      = {10.1002/pca.2570},
  note     = {REF-0971},
  study_type = {preclinical},
  abstract = {Commercial tormentil (Potentilla erecta) rhizomes and tinctures were analysed for polyphenols, showing a high content of condensed and hydrolysable tannins (over 20% in rhizomes), with procyanidins B3 and C2, agrimoniin, galloylquinic acids and catechin as main components, underpinning the astringent activity of the herb.}
}

@article{marcinczyk2017tormentil,
  author   = {Marcinczyk, N., Jarmoc, D., Leszczynska, A., Zakrzeska, A. and others},
  title    = {Antithrombotic Potential of Tormentil Extract in Animal Models},
  journal  = {Frontiers in Pharmacology},
  year     = {2017},
  volume   = {8},
  pages    = {534},
  doi      = {10.3389/fphar.2017.00534},
  note     = {REF-0972},
  study_type = {preclinical},
  abstract = {Polyphenol-rich tormentil (Potentilla erecta) extract, with anti-inflammatory and antioxidant activities, was evaluated in a rat model of arterial thrombosis. The extract decreased thrombus weight, prolonged occlusion and bleeding time, reduced thromboxane production and inhibited platelet activation similarly to aspirin, demonstrating antithrombotic potential.}
}

@article{melzig2020tormentil,
  author   = {Melzig, M.F. and Bottger, S.},
  title    = {Tormentillae rhizoma - Review for an Underestimated European Herbal Drug},
  journal  = {Planta Medica},
  year     = {2020},
  volume   = {86},
  number   = {15},
  pages    = {1050-1057},
  doi      = {10.1055/a-1129-7214},
  note     = {REF-0973},
  study_type = {traditional},
  abstract = {Tormentil (Potentilla erecta) rhizome has been used since medieval times and has European pharmacopoeia and traditional-use monographs. This review summarises its phytochemistry and pharmacology, with ellagitannins as main ingredients, and concludes that in vitro and in vivo data support the traditional use for diarrhoea and mucosal inflammation.}
}

@article{marcinczyk2021tormentil,
  author   = {Marcinczyk, N., Golaszewska, A., Gromotowicz-Poplawska, A., Misztal, T. and others},
  title    = {Multidirectional Effects of Tormentil Extract on Hemostasis in Experimental Diabetes},
  journal  = {Frontiers in Pharmacology},
  year     = {2021},
  volume   = {12},
  pages    = {682987},
  doi      = {10.3389/fphar.2021.682987},
  note     = {REF-0974},
  study_type = {preclinical},
  abstract = {Ellagitannin- and procyanidin-rich tormentil (Potentilla erecta) extract was assessed in streptozotocin-induced diabetic rats and mice. It inhibited platelet activity and improved endothelial function and arterial blood flow, illustrating multidirectional effects of tormentil on haemostasis in diabetes.}
}

@article{hoffmann2020tormentil,
  author   = {Hoffmann, J., Gendrisch, F., Schempp, C.M. and Wolfle, U.},
  title    = {New Herbal Biomedicines for the Topical Treatment of Dermatological Disorders},
  journal  = {Biomedicines},
  year     = {2020},
  volume   = {8},
  number   = {2},
  pages    = {27},
  doi      = {10.3390/biomedicines8020027},
  note     = {REF-0975},
  study_type = {traditional},
  abstract = {This review of herbal biomedicines for skin disorders describes tormentil (Potentilla erecta) among the plant drugs used to treat atopic dermatitis and rosacea, alongside other herbs for psoriasis, herpes, acne and wound healing, summarising clinical and preclinical evidence for topical anti-inflammatory phytotherapy.}
}

@article{tomczyk2017tormentil,
  author   = {Tomczyk, M., Sosnowska, K., Pleszczynska, M., Strawa, J. and others},
  title    = {Hydrogel Containing an Extract of Tormentillae rhizoma for the Treatment of Biofilm-Related Oral Diseases},
  journal  = {Natural Product Communications},
  year     = {2017},
  volume   = {12},
  number   = {3},
  pages    = {417-421},
  url      = {https://pubmed.ncbi.nlm.nih.gov/30549900/},
  note     = {REF-0976},
  study_type = {preclinical},
  abstract = {Mucoadhesive hydrogels containing dried tormentil (Potentilla erecta) extract, rich in oligomeric proanthocyanidins and agrimoniin, significantly reduced cariogenic Streptococcus mutans biofilm formation, with complete inhibition at 2 mg/mL, supporting the use of tormentil for periodontal and oral diseases.}
}

@article{wan2014tormentil,
  author   = {Wan, P., Chen, H., Guo, Y. and Bai, A.P.},
  title    = {Advances in treatment of ulcerative colitis with herbs: from bench to bedside},
  journal  = {World Journal of Gastroenterology},
  year     = {2014},
  volume   = {20},
  number   = {39},
  pages    = {14099-14104},
  doi      = {10.3748/wjg.v20.i39.14099},
  note     = {REF-0977},
  study_type = {traditional},
  abstract = {This review of herbal treatments for ulcerative colitis discusses tormentil (Potentilla erecta) extracts among the herbs (with aloe vera, butyrate, wheatgrass and curcumin) showing potential effectiveness, summarising the bioactivity and clinical evidence for tormentil in inflammatory bowel disease.}
}

@article{wolfle2017tormentil,
  author   = {Wolfle, U., Hoffmann, J., Haarhaus, B., Rao Mittapalli, V. and Schempp, C.M.},
  title    = {Anti-inflammatory and vasoconstrictive properties of Potentilla erecta - A traditional medicinal plant from the northern hemisphere},
  journal  = {Journal of Ethnopharmacology},
  year     = {2017},
  volume   = {204},
  pages    = {86-94},
  doi      = {10.1016/j.jep.2017.03.058},
  note     = {REF-0978},
  study_type = {clinical},
  abstract = {Potentilla erecta (tormentil), traditionally used for inflammatory skin and mucosal disorders, strongly reduced IL-6, prostaglandin E2 and NF-kappaB activation in keratinocytes and showed a blanching (vasoconstrictive) effect comparable to hydrocortisone via NO scavenging and eNOS inhibition, supporting topical treatment of inflammatory skin disorders.}
}

@article{dong2016emodin,
  author   = {Dong, X., Fu, J., Yin, X., Cao, S. and others},
  title    = {Emodin: A Review of its Pharmacology, Toxicity and Pharmacokinetics},
  journal  = {Phytotherapy Research},
  year     = {2016},
  volume   = {30},
  number   = {8},
  pages    = {1207-1218},
  doi      = {10.1002/ptr.5631},
  note     = {REF-0979},
  study_type = {traditional},
  abstract = {Emodin, a natural anthraquinone derivative and a major bioactive constituent of Polygonum cuspidatum (Reynoutria japonica), possesses anticancer, hepatoprotective, anti-inflammatory, antioxidant and antimicrobial activities, but can also cause toxicity at high doses. This review summarises the pharmacology, toxicity and pharmacokinetics of emodin.}
}

@article{wang2022reynoutria,
  author   = {Wang, S., Yang, Y., Sun, L., Qiao, G. and others},
  title    = {Reynoutria japonica Houtt for Acute Respiratory Tract Infections in Adults and Children: A Systematic Review},
  journal  = {Frontiers in Pharmacology},
  year     = {2022},
  volume   = {13},
  pages    = {787032},
  doi      = {10.3389/fphar.2022.787032},
  note     = {REF-0980},
  study_type = {systematic-review},
  abstract = {This systematic review evaluated Reynoutria japonica (Huzhang) for acute respiratory tract infections in adults and children, finding evidence that Chinese herbal medicine containing Reynoutria japonica has anti-inflammatory and antiviral effects relevant to respiratory infection.}
}

@article{ke2023reynoutria,
  author   = {Ke, Y., Zhan, L., Lu, T., Zhou, C. and others},
  title    = {Advances for pharmacological activities of Polygonum cuspidatum (Reynoutria japonica) - A review},
  journal  = {Pharmaceutical Biology},
  year     = {2023},
  volume   = {61},
  number   = {1},
  pages    = {177-188},
  doi      = {10.1080/13880209.2022.2158349},
  note     = {REF-0981},
  study_type = {traditional},
  abstract = {Reynoutria japonica (Polygonum cuspidatum, Huzhang), whose root has a long history as a Chinese medicinal plant, has anti-inflammatory, antitumour, antioxidant, antiviral, cardioprotective and neuroprotective pharmacological activities. This review summarises advances in its pharmacological activities and active constituents (resveratrol, polydatin, emodin).}
}

@article{zhang2021reynoutria,
  author   = {Zhang, Q., Zhao, Y., Zhang, M., Zhang, Y. and others},
  title    = {Bioactive amides from Reynoutria japonica},
  journal  = {Journal of Asian Natural Products Research},
  year     = {2021},
  volume   = {23},
  number   = {3},
  pages    = {228-234},
  doi      = {10.1080/10286020.2021.1873298},
  note     = {REF-0982},
  study_type = {preclinical},
  abstract = {A pair of new amide enantiomers and two known amides were isolated from the rhizomes of Reynoutria japonica, with their structures established by UV, IR, HRESIMS and NMR, expanding the characterised bioactive constituent chemistry of Japanese knotweed.}
}

@article{lai2024reynoutria,
  author   = {Lai, Y., Zhou, C., Huang, P., Dong, Z. and others},
  title    = {Polygonum cuspidatum polysaccharide: A review of its extraction and purification, structure analysis, and biological activity},
  journal  = {Journal of Ethnopharmacology},
  year     = {2024},
  volume   = {331},
  pages    = {118079},
  doi      = {10.1016/j.jep.2024.118079},
  note     = {REF-0983},
  study_type = {traditional},
  abstract = {The dried roots and rhizomes of Polygonum cuspidatum (Reynoutria japonica) are used as medicinal herbs. This review summarises the extraction, purification, structure and biological activities of its polysaccharides, including antioxidant, anti-inflammatory, immunomodulatory and antitumour effects.}
}

@article{peng2013reynoutria,
  author   = {Peng, W., Qin, R., Li, X. and Zhou, H.},
  title    = {Botany, phytochemistry, pharmacology, and potential application of Polygonum cuspidatum Sieb. et Zucc.: a review},
  journal  = {Journal of Ethnopharmacology},
  year     = {2013},
  volume   = {148},
  number   = {3},
  pages    = {729-745},
  doi      = {10.1016/j.jep.2013.05.007},
  note     = {REF-0984},
  study_type = {traditional},
  abstract = {Polygonum cuspidatum (Reynoutria japonica, Huzhang) is a traditional Chinese medicinal herb. This review covers its botany, phytochemistry (resveratrol, polydatin, emodin, anthraquinones), and pharmacology, including anti-inflammatory, antioxidant, anticancer, cardiovascular-protective, antimicrobial and antiviral activities.}
}

@article{wang2023reynoutria,
  author   = {Wang, X., Liang, L., Yan, J., Li, Z. and others},
  title    = {Citri Reticulatae Pericarpium-Reynoutria japonica Houtt. herb pair suppresses breast cancer liver metastasis by targeting ECM1-mediated cholesterol biosynthesis pathway},
  journal  = {Phytomedicine},
  year     = {2023},
  volume   = {116},
  pages    = {154896},
  doi      = {10.1016/j.phymed.2023.154896},
  note     = {REF-0985},
  study_type = {preclinical},
  abstract = {A Citri Reticulatae Pericarpium-Reynoutria japonica herb pair suppressed breast cancer liver metastasis in models by targeting the ECM1-mediated cholesterol biosynthesis pathway, demonstrating an anticancer (anti-metastatic) effect of Reynoutria japonica.}
}

@article{jiang2020reynoutria,
  author   = {Jiang, Y., Liu, Y., Zhang, X. and others},
  title    = {New phenolic glycosides from Reynoutria japonica},
  journal  = {Journal of Asian Natural Products Research},
  year     = {2020},
  volume   = {22},
  number   = {1},
  pages    = {17-23},
  doi      = {10.1080/10286020.2019.1646730},
  note     = {REF-0986},
  study_type = {preclinical},
  abstract = {Two new isobenzofuranone derivatives and a new isocoumarin derivative were isolated from Reynoutria japonica and their structures elucidated by spectroscopic methods, adding new phenolic glycoside constituents to the characterised chemistry of Japanese knotweed.}
}

@article{liu2024reynoutria,
  author   = {Liu, Y., Wang, J., Li, Q. and others},
  title    = {The Possibility of Polygonum cuspidatum against Osteoarthritis based on Network Pharmacology},
  journal  = {Current Computer-Aided Drug Design},
  year     = {2024},
  volume   = {20},
  number   = {2},
  pages    = {121-133},
  doi      = {10.2174/1573409919666230403114131},
  note     = {REF-0987},
  study_type = {preclinical},
  abstract = {Using network pharmacology, this study explored the multicomponent, multitarget mechanism by which Polygonum cuspidatum (Reynoutria japonica) may act against osteoarthritis, identifying anti-inflammatory targets relevant to the treatment of joint disease.}
}

@article{espinosa2025reynoutria,
  author   = {Espinosa-Andrews, H., Morales-Hernandez, N., Garcia-Marquez, E. and others},
  title    = {Physicochemical and rheological characteristics of commercial Greek-style yogurt enriched with Polygonum cuspidatum roots or the P. cuspidatum beta-cyclodextrin inclusion complex},
  journal  = {Food Research International},
  year     = {2025},
  volume   = {203},
  pages    = {115854},
  doi      = {10.1016/j.foodres.2025.115854},
  note     = {REF-0988},
  study_type = {preclinical},
  abstract = {Greek-style yogurt was enriched with Polygonum cuspidatum (Reynoutria japonica) root powder or its beta-cyclodextrin inclusion complex, and the physicochemical and rheological effects were characterised, illustrating a functional-food application of the antioxidant-rich knotweed root.}
}

@article{christensen2008rosa,
  author   = {Christensen, R., Bartels, E.M., Altman, R.D., Astrup, A. and Bliddal, H.},
  title    = {Does the hip powder of Rosa canina (rosehip) reduce pain in osteoarthritis patients? - a meta-analysis of randomized controlled trials},
  journal  = {Osteoarthritis and Cartilage},
  year     = {2008},
  volume   = {16},
  number   = {9},
  pages    = {965-972},
  doi      = {10.1016/j.joca.2008.03.001},
  note     = {REF-0989},
  study_type = {meta-analysis},
  abstract = {This meta-analysis of three randomized controlled trials (287 osteoarthritis patients) found that Rosa canina (rosehip) powder significantly reduced pain compared with placebo (effect size 0.37), with patients twice as likely to respond to rosehip as to placebo, indicating rosehip reduces osteoarthritis pain.}
}

@article{gruenwald2019rosa,
  author   = {Gruenwald, J., Uebelhack, R. and More, M.I.},
  title    = {Rosa canina - Rose hip pharmacological ingredients and molecular mechanics counteracting osteoarthritis - A systematic review},
  journal  = {Phytomedicine},
  year     = {2019},
  volume   = {60},
  pages    = {152958},
  doi      = {10.1016/j.phymed.2019.152958},
  note     = {REF-0990},
  study_type = {systematic-review},
  abstract = {This systematic review of the molecular mechanisms behind rosehip's documented clinical effects in osteoarthritis found potent antioxidant radical-scavenging effects and anti-inflammatory activities, including reduction of pro-inflammatory cytokines, NF-kB signalling, COX-1/2, 5-LOX, iNOS and C-reactive protein, matching the clinical action of Rosa canina.}
}

@article{sanzlamora2024rosa,
  author   = {Sanz-Lamora, H., Nicola-Llorente, M., Torres-Oteros, D., Perez-Marti, A. and others},
  title    = {The Antiobesity Effects of Rosehip (Rosa canina) Flesh by Antagonizing the PPAR Gamma Activity in High-Fat Diet-Fed Mice},
  journal  = {Molecular Nutrition & Food Research},
  year     = {2024},
  volume   = {68},
  number   = {5},
  pages    = {e2300539},
  doi      = {10.1002/mnfr.202300539},
  note     = {REF-0991},
  study_type = {preclinical},
  abstract = {Rosa canina flesh supplementation prevented high-fat-diet-induced obesity in mice, reducing body-weight gain and improving hyperglycaemia and insulin resistance, with decreased hepatic lipogenesis, effects consistent with a PPAR-gamma antagonist in the rosehip flesh, supporting metabolic benefits of rosehip.}
}

@article{tumbas2011rosa,
  author   = {Tumbas, V.T., Canadanovic-Brunet, J.M., Cetojevic-Simin, D.D., Cetkovic, G.S. and others},
  title    = {Effect of rosehip (Rosa canina L.) phytochemicals on stable free radicals and human cancer cells},
  journal  = {Journal of the Science of Food and Agriculture},
  year     = {2011},
  volume   = {92},
  number   = {6},
  pages    = {1273-1281},
  doi      = {10.1002/jsfa.4695},
  note     = {REF-0992},
  study_type = {preclinical},
  abstract = {Rosehip (Rosa canina) tea was separated into vitamin C, flavonoid and phenolic-acid fractions. Rosehip flavonoids showed high antioxidant activity against DPPH radicals and inhibited growth of HeLa, MCF7 and HT-29 cancer cells, confirming that vitamin C and flavonoids drive antioxidant activity while polyphenols contribute antiproliferative activity.}
}

@article{pena2023rosa,
  author   = {Pena, F., Valencia, S., Tereucan, G., Nahuelcura, J. and others},
  title    = {Bioactive Compounds and Antioxidant Activity in the Fruit of Rosehip (Rosa canina L. and Rosa rubiginosa L.)},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {8},
  pages    = {3544},
  doi      = {10.3390/molecules28083544},
  note     = {REF-0993},
  study_type = {preclinical},
  abstract = {Rosehip fruits of Rosa canina and Rosa rubiginosa from southern Chile were analysed, revealing a high content of bioactive compounds (ascorbic acid, flavonols, catechin) and antioxidant activity, with antioxidant capacity primarily associated with Rosa canina samples.}
}

@article{hendrysiak2023rosa,
  author   = {Hendrysiak, A., Brzezowska, J., Nicolet, N., Bocquel, D. and others},
  title    = {Juice Powders from Rosehip (Rosa canina L.): Physical, Chemical, and Antiglycation Properties},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {4},
  pages    = {1674},
  doi      = {10.3390/molecules28041674},
  note     = {REF-0994},
  study_type = {preclinical},
  abstract = {Rosehip (Rosa canina) juice powders, distinct for antioxidant, immunomodulatory and anticancer properties, were produced with functional carriers. The powders retained antioxidant capacity (especially with inulin and palatinose) and showed a promising ability to inhibit protein glycation, relevant to metabolic health.}
}

@article{igual2022rosa,
  author   = {Igual, M., Garcia-Herrera, P., Camara, R.M., Martinez-Monzo, J. and others},
  title    = {Bioactive Compounds in Rosehip (Rosa canina) Powder with Encapsulating Agents},
  journal  = {Molecules},
  year     = {2022},
  volume   = {27},
  number   = {15},
  pages    = {4737},
  doi      = {10.3390/molecules27154737},
  note     = {REF-0995},
  study_type = {preclinical},
  abstract = {Rosehip (Rosa canina) pseudo-fruits were freeze-dried with different biopolymer encapsulating agents and evaluated for organic acids, minerals, fibre, phenols, carotenoids and antioxidant activity, showing rosehip powder is a functional food ingredient rich in ascorbic acid, minerals and antioxidants.}
}

@article{truong2023rosa,
  author   = {Truong, V.L. and Jeong, W.S.},
  title    = {Hair Growth-Promoting Effects of Rosehip (Rosa canina L.) Seed Oil in C57BL/6 Mice},
  journal  = {Preventive Nutrition and Food Science},
  year     = {2023},
  volume   = {28},
  number   = {4},
  pages    = {411-417},
  doi      = {10.3746/pnf.2023.28.4.411},
  note     = {REF-0996},
  study_type = {preclinical},
  abstract = {Rosehip (Rosa canina) seed oil, known for therapeutic effects in skin disorders, promoted hair growth in mice by inducing telogen-to-anagen transition of hair follicles and up-regulating hair-growth-associated genes, increasing follicle density and skin thickness.}
}

@article{michalska2025rosa,
  author   = {Michalska-Ciechanowska, A., Brzezowska, J., Nicolet, N., Haladyn, K. and others},
  title    = {Valorization of Rosehip (Rosa canina L.) Pomace Using Unconventional Carbohydrate Carriers for Beverage Obtainment},
  journal  = {Molecules},
  year     = {2025},
  volume   = {30},
  number   = {1},
  pages    = {141},
  doi      = {10.3390/molecules30010141},
  note     = {REF-0997},
  study_type = {preclinical},
  abstract = {Rosehip (Rosa canina) juice and pomace powders were produced with carbohydrate carriers for beverage development. Non-pasteurised pomace powders exhibited higher antioxidant capacity than juice counterparts, highlighting the value of rosehip pomace as an antioxidant-rich matrix for functional beverages.}
}

@article{vlaicu2022rosa,
  author   = {Vlaicu, P.A., Untea, A.E., Turcu, R.P., Panaite, T.D. and Saracila, M.},
  title    = {Rosehip (Rosa canina L.) Meal as a Natural Antioxidant on Lipid and Protein Quality and Shelf-Life of Polyunsaturated Fatty Acids Enriched Eggs},
  journal  = {Antioxidants (Basel)},
  year     = {2022},
  volume   = {11},
  number   = {10},
  pages    = {1948},
  doi      = {10.3390/antiox11101948},
  note     = {REF-0998},
  study_type = {preclinical},
  abstract = {Dietary rosehip (Rosa canina) meal increased total antioxidant capacity and polyphenol content and improved the lipid and protein quality and shelf-life of polyunsaturated-fatty-acid-enriched eggs, demonstrating the natural antioxidant activity of rosehip as a feed and food ingredient.}
}

@article{telichowska2020prunus,
  author   = {Telichowska, A., Kobus-Cisowska, J. and Szulc, P.},
  title    = {Phytopharmacological Possibilities of Bird Cherry Prunus padus L. and Prunus serotina L. Species and Their Bioactive Phytochemicals},
  journal  = {Nutrients},
  year     = {2020},
  volume   = {12},
  number   = {7},
  pages    = {1966},
  doi      = {10.3390/nu12071966},
  note     = {REF-0999},
  study_type = {traditional},
  abstract = {This review compiles in vitro and in vivo studies on the antioxidant, anti-inflammatory, antibacterial and antidiabetic activity of wild cherry Prunus serotina (and Prunus padus), and characterises the phytochemical content (tocopherols, vitamins, polyphenols, terpenes and cyanogenic glycosides) of the leaves, bark and fruits, indicating their health-promoting potential.}
}

@article{lunavazquez2016prunus,
  author   = {Luna-Vazquez, F.J., Ibarra-Alvarado, C., Rojas-Molina, A., Romo-Mancillas, A. and others},
  title    = {Role of Nitric Oxide and Hydrogen Sulfide in the Vasodilator Effect of Ursolic Acid and Uvaol from Black Cherry Prunus serotina Fruits},
  journal  = {Molecules},
  year     = {2016},
  volume   = {21},
  number   = {1},
  pages    = {78},
  doi      = {10.3390/molecules21010078},
  note     = {REF-1000},
  study_type = {preclinical},
  abstract = {Ursolic acid and uvaol, isolated from black cherry (Prunus serotina) fruits, produced significant endothelium-dependent vasodilation (smooth-muscle relaxation) in rat aorta via the NO/cGMP and H2S/KATP channel pathways, providing a mechanism relevant to the antispasmodic use of wild cherry.}
}

@article{robakowski2016prunus,
  author   = {Robakowski, P., Bielinis, E., Stachowiak, J., Mejza, I. and Bulaj, B.},
  title    = {Seasonal Changes Affect Root Prunasin Concentration in Prunus serotina and Override Species Interactions between P. serotina and Quercus petraea},
  journal  = {Journal of Chemical Ecology},
  year     = {2016},
  volume   = {42},
  number   = {3},
  pages    = {202-214},
  doi      = {10.1007/s10886-016-0678-y},
  note     = {REF-1001},
  study_type = {preclinical},
  abstract = {Prunasin, the cyanogenic glycoside characteristic of Prunus serotina (wild cherry) and the basis of its traditional antitussive action, was quantified in P. serotina roots across the growing season, showing that seasonal changes, light and temperature shape prunasin concentration more than interspecific competition.}
}

@article{gallardo2021prunus,
  author   = {Gallardo-Rivera, C.T., Lu, A., Trevino-Garza, M.Z., Garcia-Marquez, E. and others},
  title    = {Valorization of Capulin Almond (Prunus serotina) by Obtaining Bioactive Compounds},
  journal  = {Frontiers in Nutrition},
  year     = {2021},
  volume   = {8},
  pages    = {663953},
  doi      = {10.3389/fnut.2021.663953},
  note     = {REF-1002},
  study_type = {preclinical},
  abstract = {The shell, paste and oil of the Capulin almond (the seed of Prunus serotina) were valorised by extracting antioxidants. The by-products were a source of phenolic compounds and flavonoids with antioxidant activity (ABTS and DPPH), identifying P. serotina seed by-products as a source of antioxidant bioactive compounds.}
}

@article{sile2020prunuspadus,
  author   = {Sile, I., Videja, M., Makrecka-Kuka, M., Tirzite, D. and others},
  title    = {Chemical composition of Prunus padus L. flower extract and its anti-inflammatory activities in primary bone marrow-derived macrophages},
  journal  = {Journal of Ethnopharmacology},
  year     = {2020},
  volume   = {268},
  pages    = {113678},
  doi      = {10.1016/j.jep.2020.113678},
  note     = {REF-1003},
  study_type = {preclinical},
  abstract = {Prunus padus (European bird cherry, a wild-cherry congener of P. serotina with the same traditional use to reduce inflammation, pain and fever) flower extract, rich in quercetin diglycosides and chlorogenic acid, inhibited collagenase, shifted macrophages toward the anti-inflammatory M2 phenotype and reduced IL-6 release, supporting its anti-inflammatory use.}
}

@article{olszewska2011prunuspadus,
  author   = {Olszewska, M.A. and Kwapisz, A.},
  title    = {Metabolite profiling and antioxidant activity of Prunus padus L. flowers and leaves},
  journal  = {Natural Product Research},
  year     = {2011},
  volume   = {25},
  number   = {12},
  pages    = {1115-1131},
  doi      = {10.1080/14786410903230359},
  note     = {REF-1004},
  study_type = {preclinical},
  abstract = {Six phenolics (flavonol glycosides and chlorogenic acid) were isolated from the leaves of Prunus padus (European bird cherry, a wild-cherry congener of P. serotina), and the flowers and leaves showed antioxidant activity (DPPH and linoleic-acid peroxidation) correlated with their proanthocyanidin and phenolic content.}
}

@article{zhang2024rosarugosa,
  author   = {Zhang, Z., Hu, W., Yu, A., Bai, M. and others},
  title    = {Physicochemical properties, health benefits, and applications of the polysaccharides from Rosa rugosa Thunb.: A review},
  journal  = {International Journal of Biological Macromolecules},
  year     = {2024},
  volume   = {282},
  number   = {Pt 3},
  pages    = {136975},
  doi      = {10.1016/j.ijbiomac.2024.136975},
  note     = {REF-1005},
  study_type = {traditional},
  abstract = {Rosa rugosa has been used as food and medicine for nearly a thousand years. Its polysaccharides, a main bioactive ingredient, have anti-diabetes, antioxidation, anti-inflammation, anti-tumour, moisture-preserving and anti-alcoholic-liver-disease health benefits. This review summarises their extraction, structure, health benefits and applications.}
}

@article{dong2024rosarugosa,
  author   = {Dong, X., Li, Y., Yang, K., Zhang, L. and others},
  title    = {Total flavonoids from Rosa rugosa Thunb.: A comprehensive review of its extraction and purification process, chemical composition, biological effect and applications},
  journal  = {Naunyn-Schmiedeberg's Archives of Pharmacology},
  year     = {2024},
  volume   = {398},
  number   = {3},
  pages    = {2343-2363},
  doi      = {10.1007/s00210-024-03504-x},
  note     = {REF-1006},
  study_type = {traditional},
  abstract = {Rosa rugosa is a traditional Chinese medicine-food herb. Its total flavonoids (TFR) possess antioxidant, anti-inflammatory, hypoglycaemic, cardioprotective and other biological effects. This review comprehensively covers the extraction, purification, chemical composition, biological effects and applications of TFR.}
}

@article{kim2024rosarugosa,
  author   = {Kim, J., Lee, S., Park, H. and others},
  title    = {Hair Growth Effect and the Mechanisms of Rosa rugosa Extract in DHT-Induced Alopecia Mice Model},
  journal  = {International Journal of Molecular Sciences},
  year     = {2024},
  volume   = {25},
  number   = {21},
  pages    = {11362},
  doi      = {10.3390/ijms252111362},
  note     = {REF-1007},
  study_type = {preclinical},
  abstract = {Rosa rugosa, a medicinal plant with anti-inflammatory, antioxidant, anticancer and antimicrobial properties, was evaluated for hair-loss effects in a DHT-induced alopecia mouse model. The extract promoted hair growth, demonstrating its potential for treating androgenic alopecia and supporting skin/scalp applications.}
}

@article{baiyisaiti2019rosarugosa,
  author   = {Baiyisaiti, A., Liu, Y., Zhang, J. and Yang, R.},
  title    = {Rosa rugosa flavonoids exhibited PPAR-alpha agonist-like effects on genetic severe hypertriglyceridemia of mice},
  journal  = {Journal of Ethnopharmacology},
  year     = {2019},
  volume   = {240},
  pages    = {111952},
  doi      = {10.1016/j.jep.2019.111952},
  note     = {REF-1008},
  study_type = {preclinical},
  abstract = {Rosa rugosa, traditionally used to treat cardiovascular diseases and risk factors such as hyperlipidemia and hypertension, was tested in genetically severe hypertriglyceridemic mice. Its flavonoids exhibited PPAR-alpha agonist-like effects, lowering triglycerides, supporting the cardiovascular use of rugosa rose.}
}

@article{lei2023rosarugosa,
  author   = {Lei, L., Zhu, Y., Gao, W., Du, X. and others},
  title    = {Ethanol Extract of Rosa rugosa Ameliorates Acetaminophen-Induced Liver Injury via Upregulating Sirt1 and Subsequent Potentiation of LKB1/AMPK/Nrf2 Cascade in Hepatocytes},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {21},
  pages    = {7307},
  doi      = {10.3390/molecules28217307},
  note     = {REF-1009},
  study_type = {preclinical},
  abstract = {The flower bud of Rosa rugosa has a wide range of biological activities. An ethanol extract ameliorated acetaminophen-induced liver injury in hepatocytes by upregulating Sirt1 and potentiating the LKB1/AMPK/Nrf2 antioxidant cascade, demonstrating hepatoprotective and antioxidant activity.}
}

@article{dai2025rosarugosa,
  author   = {Dai, C., Zheng, X., Zhu, J., Zhang, H. and others},
  title    = {Polysaccharides derived from Rosa rugosa cv. Plena ameliorate colorectal cancer by regulating intestinal microbiota composition and lipid metabolism pathway},
  journal  = {NPJ Science of Food},
  year     = {2025},
  volume   = {9},
  number   = {1},
  pages    = {176},
  doi      = {10.1038/s41538-025-00544-2},
  note     = {REF-1010},
  study_type = {preclinical},
  abstract = {A Rosa rugosa cv. Plena polysaccharide (RPP1) ameliorated AOM/DSS-induced colorectal cancer in mice, reducing colonic polyps, normalising serum IL-1beta and TNF-alpha and remodelling gut microbiota and lipid metabolism, with activation of immune (NLR, PPAR) signalling, indicating immunomodulatory and anti-tumour effects.}
}

@article{chen2025rosarugosa,
  author   = {Chen, M., Peng, Y., Zhu, R., Luo, X. and others},
  title    = {Therapeutic potential of Rosa rugosa polysaccharide and its nanofiber membrane in psoriasis via PI3K-AKT/mTOR pathway inhibition},
  journal  = {International Journal of Biological Macromolecules},
  year     = {2025},
  volume   = {320},
  number   = {Pt 2},
  pages    = {145724},
  doi      = {10.1016/j.ijbiomac.2025.145724},
  note     = {REF-1011},
  study_type = {preclinical},
  abstract = {Rosa rugosa polysaccharide (RRPS) reduced nitric oxide production in macrophages (anti-inflammatory) and, in an imiquimod-induced psoriasis mouse model, improved symptoms, reduced transepidermal water loss and inhibited pro-inflammatory cytokines (TNF-alpha, IL-6, IL-17A) by suppressing the PI3K-AKT/mTOR pathway, supporting use in inflammatory skin disease.}
}

@article{park2025rosarugosa,
  author   = {Park, C.K., Choi, S.J., Kim, C.R., Shin, H.R. and others},
  title    = {Ethanolic Extract of Rosa rugosa Roots and Its Bioactive Compound, Oleamide, Prevented Amyloid beta-Induced Oxidative Stress and Improved Behavioral Tests in Mice},
  journal  = {International Journal of Molecular Sciences},
  year     = {2025},
  volume   = {26},
  number   = {9},
  pages    = {4214},
  doi      = {10.3390/ijms26094214},
  note     = {REF-1012},
  study_type = {preclinical},
  abstract = {Rosa rugosa root extract and its bioactive compound oleamide protected against amyloid-beta-induced neurotoxicity in mice, improving cognition in Y-maze and passive-avoidance tests, restoring acetylcholine and reducing malondialdehyde, indicating antioxidant and neuroprotective effects.}
}

@article{ashraf2025rosarugosa,
  author   = {Ashraf, S., Ashraf, M.Z., Miao, B. and Zhao, X.},
  title    = {Optimizing Extraction Methods for Bioactive Polysaccharides from Rosa rugosa and Rosa damascena},
  journal  = {Foods},
  year     = {2025},
  volume   = {14},
  number   = {18},
  pages    = {3211},
  doi      = {10.3390/foods14183211},
  note     = {REF-1013},
  study_type = {traditional},
  abstract = {Rosa rugosa and Rosa damascena polysaccharides are structurally diverse and show moisturizing, immunomodulation and antioxidant activities. This review compares conventional and novel extraction methods for these polysaccharides and summarises their distribution, antioxidant mechanisms and bioactive applications.}
}

@article{liu2022rosarugosa,
  author   = {Liu, X., Liu, H., Zhang, Y. and others},
  title    = {Rosa rugosa polysaccharide induces autophagy-mediated apoptosis in human cervical cancer cells via the PI3K/AKT/mTOR pathway},
  journal  = {International Journal of Biological Macromolecules},
  year     = {2022},
  volume   = {212},
  pages    = {257-274},
  doi      = {10.1016/j.ijbiomac.2022.05.023},
  note     = {REF-1014},
  study_type = {preclinical},
  abstract = {A novel polysaccharide from Rosa rugosa induced autophagy-mediated apoptosis in human cervical cancer cells via the PI3K/AKT/mTOR pathway, demonstrating an anti-tumour mechanism of rugosa rose polysaccharides.}
}

@article{liu2022sambucus,
  author   = {Liu, D., He, X.Q., Wu, D.T., Li, H.B. and others},
  title    = {Elderberry (Sambucus nigra L.): Bioactive Compounds, Health Functions, and Applications},
  journal  = {Journal of Agricultural and Food Chemistry},
  year     = {2022},
  volume   = {70},
  number   = {14},
  pages    = {4202-4220},
  doi      = {10.1021/acs.jafc.2c00010},
  note     = {REF-1015},
  study_type = {traditional},
  abstract = {Elderberry (Sambucus nigra) is rich in (poly)phenolic and terpenoid compounds and exhibits antioxidant, anti-inflammatory, anticancer, anti-influenza, antimicrobial, antidiabetic, cardiovascular-protective and neuroprotective activities. This review summarises its bioactive compounds, health functions and food applications.}
}

@article{hawkins2018sambucus,
  author   = {Hawkins, J., Baker, C., Cherry, L. and Dunne, E.},
  title    = {Black elderberry (Sambucus nigra) supplementation effectively treats upper respiratory symptoms: A meta-analysis of randomized, controlled clinical trials},
  journal  = {Complementary Therapies in Medicine},
  year     = {2018},
  volume   = {42},
  pages    = {361-365},
  doi      = {10.1016/j.ctim.2018.12.004},
  note     = {REF-1016},
  study_type = {meta-analysis},
  abstract = {This meta-analysis of randomized controlled trials (180 participants) found that black elderberry (Sambucus nigra) supplementation substantially reduced upper respiratory symptoms, with a large mean effect size, presenting an alternative to antibiotics for upper respiratory symptoms from viral infections such as the common cold and influenza.}
}

@article{uhl2024sambucus,
  author   = {Uhl, K. and Mitchell, A.E.},
  title    = {Elderberry, an Ancient Remedy: A Comprehensive Study of the Bioactive Compounds in Three Sambucus nigra L. Subspecies},
  journal  = {Annual Review of Food Science and Technology},
  year     = {2024},
  volume   = {15},
  number   = {1},
  pages    = {27-51},
  doi      = {10.1146/annurev-food-072023-034423},
  note     = {REF-1017},
  study_type = {traditional},
  abstract = {This review compares for the first time the composition (micronutrients, macronutrients, organic acids, phenolic compounds and cyanogenic glycosides) of three subspecies of elderberry (Sambucus nigra) - the European, American and blue elderberry - highlighting the unique qualities of each and identifying gaps in available data.}
}

@article{asgary2022sambucus,
  author   = {Asgary, S. and Pouramini, A.},
  title    = {The Pros and Cons of Using Elderberry (Sambucus nigra) for Prevention and Treatment of COVID-19},
  journal  = {Advanced Biomedical Research},
  year     = {2022},
  volume   = {11},
  pages    = {96},
  doi      = {10.4103/abr.abr_146_21},
  note     = {REF-1018},
  study_type = {traditional},
  abstract = {Elderberry (Sambucus nigra) has antiviral properties due to its ability to modulate inflammatory cytokines. This review concludes the current evidence suggests elderberry is appropriate for the prevention and initial treatment of viral disease, while noting a theoretical concern about over-stimulating the immune system in COVID-19.}
}

@article{ferreira2022sambucus,
  author   = {Ferreira, S.S., Martins-Gomes, C., Nunes, F.M. and Silva, A.M.},
  title    = {Elderberry (Sambucus nigra L.) extracts promote anti-inflammatory and cellular antioxidant activity},
  journal  = {Food Chemistry: X},
  year     = {2022},
  volume   = {15},
  pages    = {100437},
  doi      = {10.1016/j.fochx.2022.100437},
  note     = {REF-1019},
  study_type = {preclinical},
  abstract = {Extracts from three Portuguese elderberry (Sambucus nigra) cultivars dose-dependently inhibited nitric oxide release in LPS-stimulated macrophages (anti-inflammatory) and prevented up to 90% of oxidative toxicity in HepG2 and Caco-2 cells, preventing glutathione depletion and DNA fragmentation, demonstrating anti-inflammatory and antioxidant potential.}
}

@article{dominguez2021sambucus,
  author   = {Dominguez, R., Pateiro, M., Munekata, P.E.S., Santos Lopez, E.M. and others},
  title    = {Potential Use of Elderberry (Sambucus nigra L.) as Natural Colorant and Antioxidant in the Food Industry. A Review},
  journal  = {Foods},
  year     = {2021},
  volume   = {10},
  number   = {11},
  pages    = {2713},
  doi      = {10.3390/foods10112713},
  note     = {REF-1020},
  study_type = {traditional},
  abstract = {Elderberry (Sambucus nigra) is rich in anthocyanins, other polyphenols and vitamins, allowing it to be used by the food industry as both a natural colorant and antioxidant. This review summarises its main bioactive compounds and its potential uses, including production of functional foods with high antioxidant capacity.}
}

@article{sanlier2024sambucus,
  author   = {Sanlier, N., Ejder, Z.B. and Irmak, E.},
  title    = {Are the Effects of Bioactive Components on Human Health a Myth?: Black Elderberry (Sambucus nigra L.) from Exotic Fruits},
  journal  = {Current Nutrition Reports},
  year     = {2024},
  volume   = {13},
  number   = {4},
  pages    = {815-827},
  doi      = {10.1007/s13668-024-00572-6},
  note     = {REF-1021},
  study_type = {traditional},
  abstract = {Black elderberry (Sambucus nigra) fruit is rich in polyphenols, phenolic acids, flavonols, proanthocyanidins, anthocyanins, terpenes and lectins. This review examines evidence that it can prevent oxidative stress, reduce blood pressure and prevent cardiovascular, metabolic and neurodegenerative diseases, stimulate the immune system and show antitumour and antimicrobial effects.}
}

@article{ulbricht2014sambucus,
  author   = {Ulbricht, C., Basch, E., Cheung, L., Goldberg, H. and others},
  title    = {An evidence-based systematic review of elderberry and elderflower (Sambucus nigra) by the Natural Standard Research Collaboration},
  journal  = {Journal of Dietary Supplements},
  year     = {2014},
  volume   = {11},
  number   = {1},
  pages    = {80-120},
  doi      = {10.3109/19390211.2013.859852},
  note     = {REF-1022},
  study_type = {systematic-review},
  abstract = {This evidence-based systematic review of elderberry and elderflower (Sambucus nigra) by the Natural Standard Research Collaboration consolidates the safety and efficacy data in the scientific literature using a validated grading rationale, covering clinical trials, pharmacology, interactions, adverse effects, toxicology and dosing.}
}

@article{has2023sambucus,
  author   = {Has, I.M., Teleky, B.E., Szabo, K., Simon, E. and others},
  title    = {Bioactive Potential of Elderberry (Sambucus nigra L.): Antioxidant, Antimicrobial Activity, Bioaccessibility and Prebiotic Potential},
  journal  = {Molecules},
  year     = {2023},
  volume   = {28},
  number   = {7},
  pages    = {3099},
  doi      = {10.3390/molecules28073099},
  note     = {REF-1023},
  study_type = {preclinical},
  abstract = {Freeze-dried elderberry (Sambucus nigra) powder, rich in anthocyanins (cyanidin-sambubiosides and cyanidin-glucosides), showed high antioxidant activity and antimicrobial activity, and its polyphenols exerted a prebiotic effect, positively influencing the growth of five probiotic strains, with high bioaccessibility after simulated digestion.}
}

@article{kim2024sambucus,
  author   = {Kim, J., An, J., Song, Y., Jang, M. and others},
  title    = {Effect of Elderberry (Sambucus nigra L.) Extract Intake on Normalizing Testosterone Concentration in Testosterone Deficiency Syndrome Rat Model Through Regulation of 17beta-HSD, 5alpha-Reductase, and CYP19A1 Expression},
  journal  = {Nutrients},
  year     = {2024},
  volume   = {16},
  number   = {23},
  pages    = {4169},
  doi      = {10.3390/nu16234169},
  note     = {REF-1024},
  study_type = {preclinical},
  abstract = {Elderberry (Sambucus nigra) extract powder (rich in rutin and fructose-leucine) increased total and free testosterone and sperm motility in an aged rat model of testosterone-deficiency syndrome by upregulating testosterone-synthesis enzymes and reducing degradation enzymes, suggesting use as a functional ingredient for testosterone deficiency.}
}

@article{grzywaczyk2024saponaria,
  author   = {Grzywaczyk, A., Smulek, W. and Kaczorek, E.},
  title    = {Saponaria officinalis saponins as a factor increasing permeability of Candida yeasts' biomembrane},
  journal  = {World Journal of Microbiology & Biotechnology},
  year     = {2024},
  volume   = {40},
  number   = {5},
  pages    = {152},
  doi      = {10.1007/s11274-024-03961-9},
  note     = {REF-1025},
  study_type = {preclinical},
  abstract = {Saponins, which have antibacterial, anti-inflammatory and antifungal properties, were studied as a saponin-rich extract of Saponaria officinalis on Candida spheroplasts. The extract increased membrane permeability and lowered surface potential, proving the antifungal potential of soapwort saponins and their ability to permeabilise cells.}
}

@article{smulek2016saponaria,
  author   = {Smulek, W., Zdarta, A., Pacholak, A., Zgola-Grzeskowiak, A. and others},
  title    = {Saponaria officinalis L. extract: Surface active properties and impact on environmental bacterial strains},
  journal  = {Colloids and Surfaces B: Biointerfaces},
  year     = {2016},
  volume   = {150},
  pages    = {209-215},
  doi      = {10.1016/j.colsurfb.2016.11.035},
  note     = {REF-1026},
  study_type = {preclinical},
  abstract = {An extract from Saponaria officinalis containing saponins (gypsogenin, hederagenin, hydroxyhederagenin and quillaic acid aglycones) demonstrated good emulsification properties and modified bacterial cell-surface properties, decreasing hydrophobicity and increasing membrane permeability, characterising soapwort's natural-surfactant activity.}
}

@article{jurek2021saponaria,
  author   = {Jurek, I., Szuplewska, A., Chudy, M. and Wojciechowski, K.},
  title    = {Soapwort (Saponaria officinalis L.) Extract vs. Synthetic Surfactants - Effect on Skin-Mimetic Models},
  journal  = {Molecules},
  year     = {2021},
  volume   = {26},
  number   = {18},
  pages    = {5628},
  doi      = {10.3390/molecules26185628},
  note     = {REF-1027},
  study_type = {preclinical},
  abstract = {A saponin-rich soapwort (Saponaria officinalis) extract was compared with synthetic surfactants on human keratinocyte and skin-mimetic models. The soapwort extract had a much smaller protein- and lipid-solubilising (irritant) potential than the anionic synthetic surfactants, supporting its gentler use on skin.}
}

@article{yu2022saponaria,
  author   = {Yu, G.R., Lim, D.W., Karunarathne, W.A.H.M., Kim, G.Y. and others},
  title    = {A non-polar fraction of Saponaria officinalis L. acted as a TLR4/MD2 complex antagonist and inhibited TLR4/MyD88 signaling in vitro and in vivo},
  journal  = {FASEB Journal},
  year     = {2022},
  volume   = {36},
  number   = {7},
  pages    = {e22387},
  doi      = {10.1096/fj.202200018RR},
  note     = {REF-1028},
  study_type = {preclinical},
  abstract = {A hexane fraction of Saponaria officinalis and its constituent saponarin inhibited MAPK signalling, NF-kB activity and pro-inflammatory cytokine production in macrophages and reduced LPS-induced inflammation in zebrafish, acting as a TLR4/MD2 complex antagonist, demonstrating an anti-inflammatory mechanism of soapwort.}
}

@article{hedayati2022saponaria,
  author   = {Hedayati, A., Naseri, F., Nourozi, E., Hosseini, B. and others},
  title    = {Response of Saponaria officinalis L. hairy roots to the application of TiO2 nanoparticles in terms of production of valuable polyphenolic compounds and SO6 protein},
  journal  = {Plant Physiology and Biochemistry},
  year     = {2022},
  volume   = {178},
  pages    = {80-92},
  doi      = {10.1016/j.plaphy.2022.03.001},
  note     = {REF-1029},
  study_type = {preclinical},
  abstract = {Saponaria officinalis is used in traditional medicine to treat skin diseases and as a blood purifier, diuretic and sudorific. This study used titanium-dioxide-nanoparticle elicitation of soapwort hairy roots to increase production of valuable polyphenols (rosmarinic acid, cinnamic acid, rutin) and the SO6 ribosome-inactivating protein.}
}

@article{sefrioui2021saponaria,
  author   = {Sefrioui, M.R., El Othmani, I.S., Filali, H., Derfoufi, S. and others},
  title    = {Evaluation of spermicidal activity of saponosides from Saponaria officinalis (Caryophyllaceae), Glycyrrhiza glabra (Fabaceae) and Herniaria glabra (Caryophyllaceae)},
  journal  = {Medicine and Pharmacy Reports},
  year     = {2021},
  volume   = {94},
  number   = {2},
  pages    = {239-247},
  doi      = {10.15386/mpr-1879},
  note     = {REF-1030},
  study_type = {preclinical},
  abstract = {Methanolic saponin extracts from the roots of Saponaria officinalis (and Glycyrrhiza glabra, Herniaria glabra) showed potent dose- and time-dependent spermicidal activity, immobilising and devitalising spermatozoa, suggesting these natural saponosides could be safer alternatives to chemical spermicides.}
}

@article{petrovic2017saponaria,
  author   = {Petrovic, G.M., Ilic, M.D., Stankov-Jovanovic, V.P., Stojanovic, G.S. and Jovanovic, S.C.},
  title    = {Phytochemical analysis of Saponaria officinalis L. shoots and flowers essential oils},
  journal  = {Natural Product Research},
  year     = {2017},
  volume   = {32},
  number   = {3},
  pages    = {331-334},
  doi      = {10.1080/14786419.2017.1350668},
  note     = {REF-1031},
  study_type = {preclinical},
  abstract = {GC and GC/MS analysis of the essential oils from fresh shoots and flowers of Saponaria officinalis identified 96 components, with phytol, tricosane-6,8-dione, patchouli alcohol and tricosane as the major constituents, characterising the volatile chemistry of soapwort.}
}

@article{ashurova2025saponaria,
  author   = {Ashurova, L.N., Khurramov, A.R., Bobakulov, K.M., Sasmakov, S.A. and others},
  title    = {A new withanolide from Saponaria officinalis and its antimicrobial and cytotoxic activities},
  journal  = {Natural Product Research},
  year     = {2025},
  volume   = {40},
  number   = {9},
  pages    = {2392-2401},
  doi      = {10.1080/14786419.2025.2472276},
  note     = {REF-1032},
  study_type = {preclinical},
  abstract = {A new withanolide and two known compounds (gracillin and 5-alpha-hydroxylaxogenin) were isolated from the aerial part of Saponaria officinalis. The new withanolide showed antimicrobial activity against several bacterial strains and significant cytotoxicity against HEp-2 and HeLa cancer cell lines.}
}

@article{bolshakov2020saponaria,
  author   = {Bolshakov, A.P., Stepanichev, M.Y., Dobryakova, Y.V., Spivak, Y.S. and Markevich, V.A.},
  title    = {Saporin from Saponaria officinalis as a Tool for Experimental Research, Modeling, and Therapy in Neuroscience},
  journal  = {Toxins (Basel)},
  year     = {2020},
  volume   = {12},
  number   = {9},
  pages    = {546},
  doi      = {10.3390/toxins12090546},
  note     = {REF-1033},
  study_type = {traditional},
  abstract = {Saporin, a ribosome-inactivating protein extracted from Saponaria officinalis, becomes highly cell-specific when conjugated to ligands and is widely used in neuroscience to induce selective degeneration of cell subpopulations, to model neurodegenerative diseases (Parkinson's, Alzheimer's) and to study sleep, anesthesia, epilepsy and pain.}
}

@article{nujkic2020saponaria,
  author   = {Nujkic, M., Milic, S., Spalovic, B., Dardas, A. and others},
  title    = {Saponaria officinalis L. and Achillea millefolium L. as possible indicators of trace elements pollution caused by mining and metallurgical activities in Bor, Serbia},
  journal  = {Environmental Science and Pollution Research International},
  year     = {2020},
  volume   = {27},
  number   = {36},
  pages    = {44969-44982},
  doi      = {10.1007/s11356-020-10371-5},
  note     = {REF-1034},
  study_type = {preclinical},
  abstract = {Saponaria officinalis (soapwort) and Achillea millefolium were evaluated as bioindicators and phytoremediators of trace-element pollution near mining and metallurgical activities. Soapwort showed high enrichment of As and Cd and was recommended for phytoextraction of Pb-, As- and Cd-polluted soils, informing the safe sourcing of soapwort raw material.}
}

@article{stevenson2002scrophularia,
  author   = {Stevenson, P.C., Simmonds, M.S.J., Sampson, J., Houghton, P.J. and Grice, P.},
  title    = {Wound healing activity of acylated iridoid glycosides from Scrophularia nodosa},
  journal  = {Phytotherapy Research},
  year     = {2002},
  volume   = {16},
  number   = {1},
  pages    = {33-35},
  doi      = {10.1002/ptr.798},
  note     = {REF-1035},
  study_type = {preclinical},
  abstract = {Three acylated iridoid glycosides (scopolioside A, scrophuloside A4 and scrovalentinoside) were isolated from the dried seed pods of Scrophularia nodosa and shown in vitro to stimulate the growth of human dermal fibroblasts. The presence of these compounds may explain the European ethnobotanical use of figwort for healing wounds.}
}

@article{ahmad2012screeningscroph,
  author   = {Ahmad, M., Muhammad, N., Mehjabeen, Jahan, N. and others},
  title    = {Biological screening of Scrophularia nodosa extract and its fractions},
  journal  = {Pakistan Journal of Pharmaceutical Sciences},
  year     = {2012},
  volume   = {25},
  number   = {2},
  pages    = {307-313},
  note     = {REF-1036},
  study_type = {preclinical},
  abstract = {Biological screening of Scrophularia nodosa crude extract and its fractions assessed phytotoxic, cytotoxic, antibacterial, antifungal and analgesic activities. The fractions exhibited significant antibacterial and antifungal effects, the plant was non-toxic in the brine-shrimp assay, and the crude extract showed highly significant analgesic activity (65.6% inhibition at 500 mg/kg in the writhing test).}
}

@article{miyase1999scrophularia,
  author   = {Miyase, T. and Mimatsu, A.},
  title    = {Acylated iridoid and phenylethanoid glycosides from the aerial parts of Scrophularia nodosa},
  journal  = {Journal of Natural Products},
  year     = {1999},
  volume   = {62},
  number   = {8},
  pages    = {1079-1084},
  doi      = {10.1021/np9805746},
  note     = {REF-1037},
  study_type = {preclinical},
  abstract = {From the aerial parts of Scrophularia nodosa, eighteen acylated iridoid glycosides and nine phenylethanoid glycosides were isolated, including eight new iridoid and two new phenylethanoid glycosides, characterising the principal constituents of figwort.}
}

@article{sesterhenn2006scrophularia,
  author   = {Sesterhenn, K., Distl, M. and Wink, M.},
  title    = {Occurrence of iridoid glycosides in in vitro cultures and intact plants of Scrophularia nodosa L.},
  journal  = {Plant Cell Reports},
  year     = {2006},
  volume   = {26},
  number   = {3},
  pages    = {365-371},
  doi      = {10.1007/s00299-006-0233-3},
  note     = {REF-1038},
  study_type = {preclinical},
  abstract = {Shoot, root and callus cultures of Scrophularia nodosa were established and the iridoid glycosides harpagoside, aucubin and catalpol identified and quantified by LC-ESI-MS and HPLC. Harpagoside was highest in leaves of field plants (1.05%) and flowers of in vitro plantlets (1.10%); aucubin was highest in leaves of in vitro plantlets.}
}

@article{soualeh2019scrophularia,
  author   = {Soualeh, N., Stiévenard, A., Baudelaire, E., Bouayed, J. and Soulimani, R.},
  title    = {Powders with small microparticle size from Hedera helix and Scrophularia nodosa exhibited high preventive antioxidant activity against H2O2-induced oxidative stress in mouse primary spleen cells},
  journal  = {International Journal for Vitamin and Nutrition Research},
  year     = {2019},
  volume   = {88},
  number   = {3-4},
  pages    = {208-218},
  doi      = {10.1024/0300-9831/a000526},
  note     = {REF-1039},
  study_type = {preclinical},
  abstract = {Superfine powders of Scrophularia nodosa (figwort) and Hedera helix (ivy) protected mouse primary spleen cells against H2O2-induced oxidative stress, significantly decreasing reactive oxygen species and malondialdehyde and restoring glutathione peroxidase, catalase and superoxide dismutase activity, with the finest fractions most effective.}
}

@article{papp2022ethnoderm,
  author   = {Papp, N., Czégényi, D., Tóth, M., Dénes, T. and others},
  title    = {Ethnomedicine survey on folk dermatology in Transylvania, Romania},
  journal  = {Clinics in Dermatology},
  year     = {2022},
  volume   = {40},
  number   = {6},
  pages    = {651-664},
  doi      = {10.1016/j.clindermatol.2022.07.013},
  note     = {REF-1040},
  study_type = {traditional},
  abstract = {An ethnomedicine survey of 35 Transylvanian villages documented 180 remedies for 45 skin problems, including 112 plants. Scrophularia nodosa was among the species recorded for dermatological use, illustrating the persistence of figwort in folk treatment of skin disorders.}
}

@article{soulimani2021antiinflam,
  author   = {Soulimani, R., Dicko, A., Baudelaire, E. and Bouayed, J.},
  title    = {Increased anti-inflammatory activity and enhanced phytochemical concentrations in superfine powders obtained by controlled differential sieving process from four medicinal plants},
  journal  = {International Journal for Vitamin and Nutrition Research},
  year     = {2021},
  volume   = {93},
  number   = {4},
  pages    = {339-351},
  doi      = {10.1024/0300-9831/a000739},
  note     = {REF-1041},
  study_type = {preclinical},
  abstract = {Superfine powders (50-180 microns) of four medicinal plants including Scrophularia nodosa significantly inhibited TNF-alpha, IL-1beta, IL-6 and nitric oxide production in LPS-stimulated mouse peripheral blood mononuclear cells by at least 20% more than hydroethanolic extracts, and were more concentrated in phenolics, demonstrating an anti-inflammatory effect.}
}

@article{ohiienko2023antifungal,
  author   = {Ohiienko, T., Kutsyk, R., Kurovets, L., Ohiienko, S. and others},
  title    = {Screening of medicinal and aromatic plants extracts for the synergism with fluconazole against Candida albicans and Candida tropicalis fungi associated with denture stomatitis},
  journal  = {Wiadomosci Lekarskie},
  year     = {2023},
  volume   = {76},
  number   = {7},
  pages    = {1615-1620},
  doi      = {10.36740/WLek202307115},
  note     = {REF-1042},
  study_type = {preclinical},
  abstract = {A screening of 166 aqueous-ethanolic plant extracts for antifungal and fluconazole-potentiating activity against azole-resistant Candida albicans and Candida tropicalis associated with denture stomatitis found significant direct antifungal activity for the roots of Scrophularia nodosa and the herb of Betonica officinalis, among other species.}
}

@article{leclerc1949scrofular,
  author   = {Leclerc, H.},
  title    = {[The scrofular, Scrophularia nodosa L.]},
  journal  = {Revue de Phytotherapie},
  year     = {1949},
  volume   = {13},
  number   = {87},
  pages    = {381-383},
  note     = {REF-1043},
  study_type = {traditional},
  abstract = {An early French phytotherapy monograph on Scrophularia nodosa (figwort), reviewing its traditional medicinal uses, notably as an alterative for chronic skin conditions.}
}

@article{akerreta2007pyrenees,
  author   = {Akerreta, S., Cavero, R.Y. and Calvo, M.I.},
  title    = {First comprehensive contribution to medical ethnobotany of Western Pyrenees},
  journal  = {Journal of Ethnobiology and Ethnomedicine},
  year     = {2007},
  volume   = {3},
  pages    = {26},
  doi      = {10.1186/1746-4269-3-26},
  note     = {REF-1044},
  study_type = {traditional},
  abstract = {An ethnobotanical and medical study of the Navarre Pyrenees catalogued 92 species, highlighting the leaves of Scrophularia nodosa among the plants used in local traditional medicine and worth pharmacological evaluation.}
}

@article{fursenco2020solidago,
  author   = {Fursenco, C., Calalb, T., Uncu, L., Dinu, M. and others},
  title    = {Solidago virgaurea L.: A Review of Its Ethnomedicinal Uses, Phytochemistry, and Pharmacological Activities},
  journal  = {Biomolecules},
  year     = {2020},
  volume   = {10},
  number   = {12},
  pages    = {1619},
  doi      = {10.3390/biom10121619},
  note     = {REF-1045},
  study_type = {systematic-review},
  abstract = {European goldenrod (Solidago virgaurea, Asteraceae) is among the most-researched goldenrod species. This review summarises its ethnomedicinal uses, phytochemistry (flavonoids, phenolic acids, saponins, diterpenes) and pharmacological activities, including diuretic, anti-inflammatory, antioxidant, antimicrobial, spasmolytic and analgesic effects, supporting its use in urinary-tract complaints.}
}

@article{abdelmotaal2016solidago,
  author   = {Abdel Motaal, A., Ezzat, S.M., Tadros, M.G. and El-Askary, H.I.},
  title    = {In vivo anti-inflammatory activity of caffeoylquinic acid derivatives from Solidago virgaurea in rats},
  journal  = {Pharmaceutical Biology},
  year     = {2016},
  volume   = {54},
  number   = {12},
  pages    = {2864-2870},
  doi      = {10.1080/13880209.2016.1190381},
  note     = {REF-1046},
  study_type = {preclinical},
  abstract = {Caffeoylquinic acid derivatives isolated from Solidago virgaurea showed significant in vivo anti-inflammatory activity in the carrageenan-induced rat paw oedema model, providing pharmacological support for the traditional anti-inflammatory use of goldenrod.}
}

@article{precheur2020solidago,
  author   = {Précheur, I., Rolland, Y., Hasseine, L., Orange, F. and others},
  title    = {Solidago virgaurea L. Plant Extract Targeted Against Candida albicans to Reduce Oral Microbial Biomass: A Double Blind Randomized Trial on Healthy Adults},
  journal  = {Antibiotics},
  year     = {2020},
  volume   = {9},
  number   = {4},
  pages    = {137},
  doi      = {10.3390/antibiotics9040137},
  note     = {REF-1047},
  study_type = {rct},
  abstract = {In a double-blind randomized trial on healthy adults, a Solidago virgaurea extract mouthwash modulated the oral microbial biomass without eradicating the commensal flora, supporting a controlled antimicrobial action of goldenrod relevant to oral health.}
}

@article{wojnicz2021solidago,
  author   = {Wojnicz, D., Tichaczek-Goska, D., Glensk, M. and Hendrich, A.B.},
  title    = {Is It Worth Combining Solidago virgaurea Extract and Antibiotics against Uropathogenic Escherichia coli Rods? An In Vitro Model Study},
  journal  = {Pharmaceutics},
  year     = {2021},
  volume   = {13},
  number   = {4},
  pages    = {573},
  doi      = {10.3390/pharmaceutics13040573},
  note     = {REF-1048},
  study_type = {preclinical},
  abstract = {European goldenrod (Solidago virgaurea), long recommended for the prophylaxis of urinary-tract infections, was tested in vitro in combination with antibiotics against uropathogenic Escherichia coli. The extract influenced bacterial growth, biofilm formation and morphology, supporting goldenrod's traditional role in urinary-tract complaints.}
}

@article{eltantawy2013solidago,
  author   = {El-Tantawy, W.H.},
  title    = {Biochemical effects of Solidago virgaurea extract on experimental cardiotoxicity},
  journal  = {Journal of Physiology and Biochemistry},
  year     = {2013},
  volume   = {70},
  number   = {1},
  pages    = {33-42},
  doi      = {10.1007/s13105-013-0277-0},
  note     = {REF-1049},
  study_type = {preclinical},
  abstract = {A Solidago virgaurea extract was evaluated against experimental (isoprenaline-induced) cardiotoxicity in rats, improving cardiac and oxidative-stress biomarkers, indicating an antioxidant, cardioprotective effect of goldenrod.}
}

@article{gross2002solidago,
  author   = {Gross, S.C., Goodarzi, G., Watabe, M., Bandyopadhyay, S. and others},
  title    = {Antineoplastic activity of Solidago virgaurea on prostatic tumor cells in an SCID mouse model},
  journal  = {Nutrition and Cancer},
  year     = {2002},
  volume   = {43},
  number   = {1},
  pages    = {76-81},
  doi      = {10.1207/S15327914NC431_9},
  note     = {REF-1050},
  study_type = {preclinical},
  abstract = {Solidago virgaurea, traditionally used as an anti-inflammatory herb for prostatic disorders, inhibited the growth of prostatic tumour cells and showed antineoplastic activity in an SCID mouse model.}
}

@article{starks2009solidago,
  author   = {Starks, C.M., Williams, R.B., Goering, M.G., O'Neil-Johnson, M. and others},
  title    = {Antibacterial clerodane diterpenes from Goldenrod (Solidago virgaurea)},
  journal  = {Phytochemistry},
  year     = {2010},
  volume   = {71},
  number   = {1},
  pages    = {104-109},
  doi      = {10.1016/j.phytochem.2009.09.032},
  note     = {REF-1051},
  study_type = {preclinical},
  abstract = {Nine clerodane diterpenes (solidagoic acids C-I and two diolides) were isolated from goldenrod (Solidago virgaurea) and several showed antibacterial activity, characterising antimicrobial diterpene constituents of the plant.}
}

@article{malicanin2024solidago,
  author   = {Malicanin, M., Karabegovic, I., Dordevic, N., Mancic, S. and others},
  title    = {Influence of the Extraction Method on the Biological Potential of Solidago virgaurea L. Essential Oil and Hydrolates},
  journal  = {Plants},
  year     = {2024},
  volume   = {13},
  number   = {16},
  pages    = {2187},
  doi      = {10.3390/plants13162187},
  note     = {REF-1052},
  study_type = {preclinical},
  abstract = {Essential oils and hydrolates of European goldenrod (Solidago virgaurea) obtained by different extraction methods were evaluated for chemical composition and biological activity, showing antimicrobial and antioxidant potential consistent with the plant's traditional uses.}
}

@article{zehra2022solidago,
  author   = {Zehra, S.A., Bhattarai, P., Zhang, J., Liu, Y. and others},
  title    = {Phytochemical Analysis and Evaluation of the Antidiabetic Activity of Solidago virgaurea Extracts},
  journal  = {Current Bioactive Compounds},
  year     = {2022},
  volume   = {19},
  number   = {4},
  pages    = {e150622206146},
  doi      = {10.2174/1573407218666220615143502},
  note     = {REF-1053},
  study_type = {preclinical},
  abstract = {Solidago virgaurea, used for centuries for cystitis, nephritis, urolithiasis, rheumatism and inflammatory diseases, was analysed phytochemically and its extracts evaluated for antidiabetic activity, demonstrating hypoglycaemic potential of goldenrod.}
}

@article{jang2016solidago,
  author   = {Jang, Y.S., Wang, Z., Lee, J.M., Lee, J.Y. and others},
  title    = {Screening of Korean Natural Products for Anti-Adipogenesis Properties and Isolation of Kaempferol-3-O-rutinoside as a Potent Anti-Adipogenetic Compound from Solidago virgaurea},
  journal  = {Molecules},
  year     = {2016},
  volume   = {21},
  number   = {2},
  pages    = {226},
  doi      = {10.3390/molecules21020226},
  note     = {REF-1054},
  study_type = {preclinical},
  abstract = {A screen of 300 plant extracts identified Solidago virgaurea as a potent inhibitor of adipogenesis in 3T3-L1 cells, and kaempferol-3-O-rutinoside was isolated as a potent anti-adipogenetic constituent of goldenrod.}
}

@article{slapsyte2019stachys,
  author   = {Slapsyte, G., Dedonyte, V., Adomeniene, A., Lazutka, J.R. and others},
  title    = {Genotoxic properties of Betonica officinalis, Gratiola officinalis, Vincetoxicum luteum and Vincetoxicum hirundinaria extracts},
  journal  = {Food and Chemical Toxicology},
  year     = {2019},
  volume   = {134},
  pages    = {110815},
  doi      = {10.1016/j.fct.2019.110815},
  note     = {REF-1055},
  study_type = {preclinical},
  abstract = {Extracts of Betonica officinalis (wood betony) and three other species, all with strong antioxidant capacity, were tested for genotoxicity; the study characterises the antioxidant and safety profile of betony.}
}

@article{apostolescu2023stachys,
  author   = {Apostolescu, G.F., Popescu, D.I., Botoran, O., Sandru, D. and others},
  title    = {Chemical and Antioxidant Profile of Hydroalcoholic Extracts of Stachys officinalis L., Stachys palustris L., Stachys sylvatica L. from Romania},
  journal  = {Acta Chimica Slovenica},
  year     = {2023},
