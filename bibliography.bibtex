  volume   = {6},
  number   = {9},
  pages    = {1343-1346},
  note     = {REF-1057},
  study_type = {preclinical},
  abstract = {The essential oils of aerial parts and roots of Betonica officinalis from three Kosovo populations were analysed by GC and GC/MS, characterising the volatile-oil composition and its variability across wild populations of wood betony.}
}

@article{giuliani2016stachys,
  author   = {Giuliani, C., Pellegrino, R.M., Selvaggi, R., Tani, C. and others},
  title    = {Secretory structures and essential oil composition in Stachys officinalis (L.) Trevisan subsp. officinalis (Lamiaceae) from Italy},
