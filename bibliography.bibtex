  number   = {4},
  pages    = {505-509},
  doi      = {10.1002/ptr.3582},
  note     = {REF-1062},
  study_type = {preclinical},
  abstract = {Aqueous extracts of the aerial parts of ten Hungarian Stachys species, including S. officinalis, were tested in vivo in the carrageenan rat-paw-oedema model; several showed significant anti-inflammatory activity, attributed in part to their iridoid content.}
}

@article{bilusicvundac2019stachys,
