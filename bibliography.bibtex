  note     = {REF-1059},
  study_type = {preclinical},
  abstract = {Six Romanian Stachys species, including S. officinalis, were investigated for polyphenolic composition and antimicrobial and antioxidant potential, characterising the phenolics responsible for the antioxidant and antimicrobial activity of betony.}
}

@article{lazarevic2013stachys,
  author   = {Lazarevic, J.S., Dordevic, A.S., Kitic, D.V., Zlatkovic, B.K. and others},
