  doi      = {10.1089/107555302320825093},
  note     = {REF-1166},
  study_type = {preclinical},
  abstract = {Orally administered lentinan from shiitake (Lentinus edodes) significantly inhibited the development of human colon-carcinoma tumours in mice and acted via primed lymphocytes, demonstrating an antitumour, immunomodulatory effect retained by the oral route.}
}

@article{bisen2010lentinula,
  author   = {Bisen, P.S., Baghel, R.K., Sanodiya, B.S., Thakur, G.S. and Prasad, G.B.K.S.},
  title    = {Lentinus edodes: a macrofungus with pharmacological activities},
