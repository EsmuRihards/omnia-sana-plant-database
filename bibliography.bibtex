  note     = {REF-1167},
  study_type = {systematic-review},
  abstract = {This review of shiitake (Lentinus edodes) summarises its pharmacological activities and well-studied preparations (lentinan, eritadenine, LEM), covering immune-enhancing, anticancer, antimicrobial, antiviral, hypolipidaemic and hypoglycaemic effects.}
}

@article{stephany2016shiitake,
  author   = {Stephany, M.P., Chung, S., Handler, M.Z., Handler, N.S. and others},
  title    = {Shiitake Mushroom Dermatitis: A Review},
  journal  = {American Journal of Clinical Dermatology},
  year     = {2016},
  volume   = {17},
  number   = {5},
  pages    = {485-489},
  doi      = {10.1007/s40257-016-0212-6},
  note     = {REF-1168},
  study_type = {systematic-review},
  abstract = {This review describes shiitake (Lentinula edodes) mushroom dermatitis, a flagellate cutaneous reaction caused by lentinan from eating raw or undercooked shiitake, characterising a recognised safety consideration of the mushroom.}
}

@article{nguyen2017shiitake,
  author   = {Nguyen, A.H., Gonzaga, M.I., Lim, V.M., Adler, M.J. and others},
  title    = {Clinical features of shiitake dermatitis: a systematic review},
  journal  = {International Journal of Dermatology},
  year     = {2017},
  volume   = {56},
  number   = {6},
  pages    = {610-616},
  doi      = {10.1111/ijd.13433},
  note     = {REF-1169},
  study_type = {systematic-review},
  abstract = {This systematic review of 50 cases characterises the clinical features of shiitake (Lentinula edodes) dermatitis — a self-limiting flagellate eruption following raw/undercooked mushroom consumption — informing the safe use of shiitake as a food and medicine.}
}

@article{djordjevic2008lentinan,
  author   = {Djordjevic, B., Skugor, S., Jorgensen, S.M., Overland, M. and others},
  title    = {Modulation of splenic immune responses to bacterial lipopolysaccharide in rainbow trout (Oncorhynchus mykiss) fed lentinan, a beta-glucan from mushroom Lentinula edodes},
