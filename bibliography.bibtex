  doi      = {10.1016/j.jpba.2017.11.075},
  note     = {REF-1178},
  study_type = {preclinical},
  abstract = {Using 1H NMR-based metabolomics, the protoberberine alkaloids berberine and palmatine and the bisbenzylisoquinoline alkaloid berbamine were identified as the metabolites most responsible for the cytotoxic (anticancer) activity of Mahonia aquifolium stem-bark.}
