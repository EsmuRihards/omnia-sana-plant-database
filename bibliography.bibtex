  note     = {REF-1060},
  study_type = {preclinical},
  abstract = {The essential oil hydrodistilled from the aerial parts of Stachys officinalis was characterised by GC-FID and GC/MS and tested for antimicrobial activity, defining the volatile composition and antimicrobial potential of wood betony.}
}

@article{stegarus2021stachys,
  author   = {Stegarus, D.I., Lengyel, E., Apostolescu, G.F., Botoran, O.R. and others},
