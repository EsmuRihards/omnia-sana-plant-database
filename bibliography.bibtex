  note     = {REF-1175},
  study_type = {preclinical},
  abstract = {Non-toxic Mahonia aquifolium extracts acted synergistically with doxorubicin against lung adenocarcinoma cells in vitro, prolonging drug retention and reducing migration and colony formation, indicating an anticancer-potentiating activity of Oregon grape.}
}

@article{cernakova2002antimutagenic,
  author   = {Cernakova, M., Kostalova, D., Kettmann, V., Plodova, M. and others},
