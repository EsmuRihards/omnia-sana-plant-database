  doi      = {10.1002/ptr.1517},
  note     = {REF-1177},
  study_type = {preclinical},
  abstract = {Mahonia aquifolium stem-bark crude extract and its alkaloids berberine and jatrorrhizine inhibited staphylococci, Propionibacterium acnes and Candida from skin and mucosal infections, providing a rational basis for the traditional use of Oregon grape for localised skin and mucosal infections.}
