}

@article{haznagyradnai2011stachys,
  author   = {Háznagy-Radnai, E., Balogh, Á., Czigle, S., Máthé, I. and others},
  title    = {Antiinflammatory activities of Hungarian Stachys species and their iridoids},
  journal  = {Phytotherapy Research},
  year     = {2012},
