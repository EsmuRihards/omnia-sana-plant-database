  note     = {REF-1173},
  study_type = {clinical},
  abstract = {This report on three clinical trials and the worldwide experience with Mahonia aquifolium 10% topical cream concluded that Oregon grape is a safe and effective treatment for mild-to-moderate plaque psoriasis, improving PASI and quality-of-life scores.}
}

@article{cernakova2002berberine,
  author   = {Cernakova, M. and Kostalova, D.},
  title    = {Antimicrobial activity of berberine--a constituent of Mahonia aquifolium},
